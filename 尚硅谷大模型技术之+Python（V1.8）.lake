="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20items%E6%96%B9%E6%B3%95%EF%BC%9A%E8%8E%B7%E5%8F%96%E5%AD%97%E5%85%B8%E4%B8%AD%E6%89%80%E6%9C%89%E7%9A%84%E9%94%AE%E5%80%BC%E5%AF%B9%EF%BC%88%E6%AF%8F%E7%BB%84%E9%94%AE%E5%80%BC%E5%AF%B9%E4%BB%A5%E5%85%83%E7%BB%84%E7%9A%84%E5%BD%A2%E5%BC%8F%E5%91%88%E7%8E%B0%EF%BC%89%5Cnd1%20%3D%20%7B'%E5%BC%A0%E4%B8%89'%3A%2072%2C%20'%E6%9D%8E%E5%9B%9B'%3A%2060%2C%20'%E7%8E%8B%E4%BA%94'%3A%2085%7D%5Cn%5Cn%23%20items%E6%96%B9%E6%B3%95%E8%BF%94%E5%9B%9E%E7%9A%84%E7%B1%BB%E5%9E%8B%E6%98%AF%EF%BC%9Adict_items%EF%BC%8C%E5%AE%83%E7%9A%84%E7%89%B9%E7%82%B9%E4%B9%9F%E5%92%8Cdict_keys%E4%B8%80%E6%A0%B7%5Cnresult%20%3D%20d1.items()%5Cnprint(result)%5Cnprint(type(result))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22zu8br%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="G3Iks" id="G3Iks" data-lake-index-type="2"><span data-lake-id="u7cd33a8f" id="u7cd33a8f">字典的循环遍历</span></h3><p data-lake-id="ub84dfaa7" id="ub84dfaa7"><span data-lake-id="u18dce191" id="u18dce191">字典不能使用while循环遍历，但可以使用for循环遍历</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AD%97%E5%85%B8%E4%B8%8D%E8%83%BD%E4%BD%BF%E7%94%A8while%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%EF%BC%8C%E4%BD%86%E5%8F%AF%E4%BB%A5%E4%BD%BF%E7%94%A8for%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%5Cnd1%20%3D%20%7B'%E5%BC%A0%E4%B8%89'%3A%2072%2C%20'%E6%9D%8E%E5%9B%9B'%3A%2060%2C%20'%E7%8E%8B%E4%BA%94'%3A%2085%7D%5Cn%5Cnfor%20key%20in%20d1%3A%5Cn%20%20%20%20print(f'%7Bkey%7D%E7%9A%84%E6%88%90%E7%BB%A9%E6%98%AF%7Bd1%5Bkey%5D%7D')%5Cn%5Cnfor%20key%20in%20d1.keys()%3A%5Cn%20%20%20%20print(f'%7Bkey%7D%E7%9A%84%E6%88%90%E7%BB%A9%E6%98%AF%7Bd1%5Bkey%5D%7D')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22injXK%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="P8sjE" id="P8sjE" data-lake-index-type="2"><span data-lake-id="u53eb6a55" id="u53eb6a55">字典总结</span></h3><ol list="u735d1ee1"><li fid="ua784a3b8" data-lake-id="uf396bfe6" id="uf396bfe6"><span data-lake-id="u4adf6df7" id="u4adf6df7">键值对结构：字典中的数据以</span><code data-lake-id="u8cc25c37" id="u8cc25c37"><span data-lake-id="u869cdb4e" id="u869cdb4e">key:value</span></code><span data-lake-id="ufad19dd7" id="ufad19dd7">的形式存在，每个键都对应一个值。</span></li><li fid="ua784a3b8" data-lake-id="uab5379fc" id="uab5379fc"><span data-lake-id="ud43452b9" id="ud43452b9">键唯一：字典中的键（key）不能重复，若重复则后写的会覆盖前写的。</span></li><li fid="ua784a3b8" data-lake-id="u7b4cff93" id="u7b4cff93"><span data-lake-id="u682db8cf" id="u682db8cf">键不可变：：键必须是不可变类型（如数字、字符串、元组等），而值可以是任意类型。</span></li><li fid="ua784a3b8" data-lake-id="ud8efd53d" id="ud8efd53d"><span data-lake-id="u44fe42fe" id="u44fe42fe">不支持下标：字典中的元素不能通过下标取值。</span></li><li fid="ua784a3b8" data-lake-id="ued7b0683" id="ued7b0683"><span data-lake-id="u229c20e3" id="u229c20e3">支持增删改查，支持for循环遍历。</span></li></ol><blockquote data-lake-id="u345bf911" id="u345bf911" class="lake-alert lake-alert-info"><p data-lake-id="u84a56a32" id="u84a56a32"><strong><span data-lake-id="u67b238e4" id="u67b238e4">📍</span></strong><strong><span data-lake-id="u3e638fb7" id="u3e638fb7">一句话总结</span></strong><span data-lake-id="u7ddc09a5" id="u7ddc09a5">：字典是一种以“键”找“值”的映射型容器，当需要</span><code data-lake-id="u08005c21" id="u08005c21"><span data-lake-id="u75124c4d" id="u75124c4d">唯一标识 → 对应信息</span></code><span data-lake-id="u74b76b19" id="u74b76b19">的结构时，首选字典。</span></p></blockquote><h2 data-lake-id="TcaKF" id="TcaKF" data-lake-index-type="2"><span data-lake-id="ubb23a7cf" id="ubb23a7cf">数据容器_通用操作</span></h2><p data-lake-id="ub344c4ec" id="ub344c4ec"><span data-lake-id="u7040ea46" id="u7040ea46">我们之前在讲解【列表常用函数时】给大家总结过如下这些函数，这些函数也同样适用于其它数据容器</span></p><p data-lake-id="u1d26b7bd" id="u1d26b7bd"><card type="inline" name="image" value="data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2025%2Fpng%2F35780599%2F1760878859524-f300bdc1-74ec-4ec4-a190-17b2ec815b0a.png%22%2C%22taskId%22%3A%22ua2a3d6f4-38b5-4583-ae7f-39a0bc8b8a8%22%2C%22clientId%22%3A%22uebac531c-c172-4%22%2C%22originalType%22%3A%22binary%22%2C%22width%22%3A702.772705078125%2C%22height%22%3A213%2C%22linkTarget%22%3A%22_blank%22%2C%22name%22%3A%22image.png%22%2C%22size%22%3A167595%2C%22from%22%3A%22paste%22%2C%22originWidth%22%3A1886%2C%22originHeight%22%3A571%2C%22ratio%22%3A1.6500000953674316%2C%22status%22%3A%22done%22%2C%22style%22%3A%22none%22%2C%22ocrLocations%22%3A%5B%7B%22text%22%3A%22%E5%8E%9F%E5%88%97%E8%A1%A8%2CREVERSE%E5%8F%82%E6%95%B0%E7%94%A8%E4%BA%8E%E6%8E%A7%E5%88%B6%E6%8E%92%E5%BA%8F%E6%96%B9%E5%BC%8F.%22%2C%22x%22%3A806%2C%22y%22%3A160%2C%22width%22%3A730%2C%22height%22%3A44%7D%2C%7B%22text%22%3A%22%E5%AF%B9%E5%AE%B9%E5%99%A8%E6%8E%92%E5%BA%8F(%E9%BB%98%E8%AE%A4%E4%BB%8E%E5%B0%8F%E5%88%B0%E5%A4%A7%E6%8E%92%E5%88%97)%E4%B8%8D%E4%BC%9A%E6%94%B9%E5%8F%98%22%2C%22x%22%3A806%2C%22y%22%3A106%2C%22width%22%3A775%2C%22height%22%3A43%7D%2C%7B%22text%22%3A%22%E8%8E%B7%E5%8F%96%E5%AE%B9%E5%99%A8%E4%B8%AD%E5%85%83%E7%B4%A0%E7%9A%84%E6%80%BB%E6%95%B0%E9%87%8F.%22%2C%22x%22%3A802%2C%22y%22%3A245%2C%22width%22%3A451%2C%22height%22%3A45%7D%2C%7B%22text%22%3A%22%E8%8E%B7%E5%8F%96%E5%AE%B9%E5%99%A8%E4%B8%AD%E7%9A%84%E6%9C%80%E5%