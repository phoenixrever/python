rning%5Cn%E2%94%9C%E2%94%80%E2%94%80%20UnicodeWarning%5Cn%E2%94%94%E2%94%80%E2%94%80%20UserWarning%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22QKQJM%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="Ji9d6" id="Ji9d6" data-lake-index-type="2"><span data-lake-id="u582fe849" id="u582fe849">异常处理</span></h2><h3 data-lake-id="szsU8" id="szsU8"><span data-lake-id="u980c29ba" id="u980c29ba">1️⃣</span><span data-lake-id="u0d9b2268" id="u0d9b2268">为什么要进行异常处理</span></h3><ul list="ua7fe8d41"><li fid="u303f3e47" data-lake-id="u2e7d6ef4" id="u2e7d6ef4"><span data-lake-id="uf427726f" id="uf427726f">程序运行过程中出现的异常，如果得不到处理，那程序就会立即崩溃，导致后续代码无法执行。</span></li><li fid="u303f3e47" data-lake-id="uac31ea35" id="uac31ea35"><span data-lake-id="uafe98bcf" id="uafe98bcf">异常处理不是让异常消失，而是将异常捕获到，随后根据异常的具体情况，来执行指定的逻辑。</span></li></ul><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E3%80%90%E6%9C%AA%E8%BF%9B%E8%A1%8C%E3%80%91%E5%BC%82%E5%B8%B8%E5%A4%84%E7%90%86%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print('%E6%AC%A2%E8%BF%8E%E4%BD%BF%E7%94%A8%E6%9C%AC%E7%A8%8B%E5%BA%8F')%5Cna%20%3D%20int(input('%E8%AF%B7%E8%BE%93%E5%85%A5%E7%AC%AC%E4%B8%80%E4%B8%AA%E6%95%B0%EF%BC%9A'))%5Cnb%20%3D%20int(input('%E8%AF%B7%E8%BE%93%E5%85%A5%E7%AC%AC%E4%BA%8C%E4%B8%AA%E6%95%B0%EF%BC%9A'))%5Cnresult%20%3D%20a%20%2F%20b%5Cnprint(f'%7Ba%7D%E9%99%A4%E4%BB%A5%7Bb%7D%E7%9A%84%E7%BB%93%E6%9E%9C%E6%98%AF%EF%BC%9A%7Bresult%7D')%5Cnprint('*******%E6%88%91%E6%98%AF%E5%90%8E%E7%BB%AD%E7%9A%84%E5%85%B6%E5%AE%83%E9%80%BB%E8%BE%911*******')%5Cnprint('*******%E6%88%91%E6%98%AF%E5%90%8E%E7%BB%AD%E7%9A%84%E5%85%B6%E5%AE%83%E9%80%BB%E8%BE%912*******')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E3%80%90%E6%9C%AA%E8%BF%9B%E8%A1%8C%E3%80%91%E5%BC%82%E5%B8%B8%E5%A4%84%E7%90%86%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22UIBo0%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><h3 data-lake-id="aAiEd" id="aAiEd"><span data-lake-id="u2964d261" id="u2964d261">2️⃣</span><span data-lake-id="u0bfe4d65" id="u0bfe4d65">异常处理（初级）</span></h3><p data-lake-id="u8fac19fe" id="u8fac19fe"><span data-lake-id="u172ba70c" id="u172ba70c">核心规则如下：</span></p><blockquote data-lake-id="uafa4e2d5" id="uafa4e2d5" class="lake-alert lake-alert-info"><ol list="ufa2a036b"><li fid="udbf4b565" data-lake-id="ufee92961" id="ufee92961"><span data-lake-id="u9a129dc5" id="u9a129dc5">将可能出现异常的代码放在</span><code data-lake-id="u01418ff8" id="u01418ff8"><span data-lake-id="ue280c60a" id="ue280c60a">try</span></code><span data-lake-id="udabdf867" id="udabdf867">中，出现异常后的处理代码写在</span><code data-lake-id="u2ace4c6e" id="u2ace4c6e"><span data-lake-id="u15888f17" id="u15888f17">except</span></code><span data-lake-id="u4b9952a2" id="u4b9952a2">中。</span></li><li fid="udbf4b565" data-lake-id="u5a38d1e7" id="u5a38d1e7"><span data-lake-id="u3742c81d" id="u3742c81d">如果</span><code data-lake-id="uc05688ee" id="uc05688ee"><span data-lake-id="u0dcd5c10" id="u0dcd5c10">try</span></code><span data-lake-id="u4208b3b7" id="u4208b3b7">中的代码出现异常，那</span><code data-lake-id="u1d50f08f" id="u1d50f08f"><span data-lake-id="u5de6326d" id="u5de6326d">try</span></code><span data-lake-id="uf1aefbed" id="uf1aefbed">中的后续代码不会执行，并自动跳转到</span><code data-lake-id="uaf7d47e6" id="uaf7d47e6"><span data-lake-id="ufa24aff8" id="ufa24aff8">except</span></code><span data-lake-id="ue222bbaa" id="ue222bbaa">中。</span></li><li fid="udbf4b565" data-lake-id="u743d62f7" id="u743d62f7"><span data-lake-id="u17432b38" id="u17432b38">如果</span><code data-lake-id="u68fdf3ca" id="u68fdf3ca"><span data-lake-id="u1d0a2e1c" id="u1d0a2e1c">try</span></code><span data-lake-id="uc493fa83" id="uc493fa83">中的代码没有异常，那</span><code data-lake-id="uf24f2ba1" id="uf24f2ba1"><span data-lake-id="u2e55de8d" id="u2e55de8d">except</span></code><span data-lake-id="uefdcfc41" id="uefdcfc41">中的代码就不会执行。</span></li><li fid="udbf4b565" data-lake-id="u7eafd520" id="u7eafd520"><span data-lake-id="u96c0f66b" id="u96c0f66b">无论是否发生异常，</span><code data-lake-id="u96ae9bdb" id="u96ae9bdb"><span data-lake-id="u01ee9308" id="u01ee9308">try-except</span></code><span data-lake-id="ud5718f59" id="ud5718f59">后面的代码都会继续执行。</span></li><li fid="udbf4b565" data-lake-id="ub50f2273" id="ub50f2273"><span data-lake-id="u6f637cf9" id="u6f637cf9">直接写</span><code data-lake-id="uba97b063" id="uba97b063"><span data-lake-id="uad463d44" id="uad463d44">except</span></code><span data-lake-id="uca03a919" id="uca03a919">捕获到</span><code data-lake-id="u0280f458" id="u0280f458"><span data-lake-id="udcba34ce" id="udcba34ce">Python</span></code><span data-lake-id="ud2fafaf7" id="ud2fafaf7">中所有的异常 ———— 实际开发中不推荐这样做。</span></li></ol></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E3%80%90%E8%BF%9B%E8%A1%8C%E4%BA%86%E3%80%91%E5%BC%82%E5%B8%B8%E5%A4%84%E7%90%86%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print('%E6%AC%A2%E8%BF%8E%E4%BD%BF%E7%94%A8%E6%9C%AC%E7%A8%8B%E5%BA%8F')%5Cntry%3A%5Cn%20%20%20%20a%20%3D%20int(input('%E8%AF%B7%E8%BE%93%E5%85%A5%E7%AC%AC%E4%B8%80%E4%B8%AA%E6%95%B0%EF%BC%9A'))%5Cn%20%20%20%20b%20%3D%20int(input('%E8%AF%B7%E8%BE%93%E5%85%A5%E7%AC%AC%E4%BA%8C%E4%B8%AA%E6%95%B0%EF%BC%9A'))%5Cn%20%20%20%20result%20%3D%20a%20%2F%20b%5Cn%20%20%20%20print(f