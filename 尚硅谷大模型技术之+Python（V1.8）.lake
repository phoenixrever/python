t%22%3A75%7D%2C%7B%22text%22%3A%22HEX(463)0X1CF%22%2C%22x%22%3A1149%2C%22y%22%3A563%2C%22width%22%3A657%2C%22height%22%3A64%7D%2C%7B%22text%22%3A%22INT(0O1034%2C8)54%22%2C%22x%22%3A1677%2C%22y%22%3A882%2C%22width%22%3A658%2C%22height%22%3A58%7D%2C%7B%22text%22%3A%220CT(540)001034%22%2C%22x%22%3A1146%2C%22y%22%3A382%2C%22width%22%3A696%2C%22height%22%3A61%7D%2C%7B%22text%22%3A%22INT(OX1CF'%2C16)%22%2C%22x%22%3A1648%2C%22y%22%3A1031%2C%22width%22%3A634%2C%22height%22%3A60%7D%2C%7B%22text%22%3A%22%E5%8D%81%E5%85%AD%E8%BF%9B%E5%88%B6%E8%BD%AC%E5%8D%81%E8%BF%9B%E5%88%B6%22%2C%22x%22%3A1159%2C%22y%22%3A1021%2C%22width%22%3A489%2C%22height%22%3A72%7D%2C%7B%22text%22%3A%22%E5%85%AB%E8%BF%9B%E5%88%B6%E8%BD%AC%E5%8D%81%E8%BF%9B%E5%88%B6%22%2C%22x%22%3A1170%2C%22y%22%3A874%2C%22width%22%3A413%2C%22height%22%3A69%7D%2C%7B%22text%22%3A%22%E4%BA%8C%E8%BF%9B%E5%88%B6%E8%BD%AC%E5%8D%81%E8%BF%9B%E5%88%B6%22%2C%22x%22%3A1165%2C%22y%22%3A727%2C%22width%22%3A420%2C%22height%22%3A66%7D%2C%7B%22text%22%3A%220B11001%22%2C%22x%22%3A1581%2C%22y%22%3A193%2C%22width%22%3A287%2C%22height%22%3A60%7D%2C%7B%22text%22%3A%22BIN(25)%22%2C%22x%22%3A1151%2C%22y%22%3A194%2C%22width%22%3A277%2C%22height%22%3A66%7D%2C%7B%22text%22%3A%22BIN%22%2C%22x%22%3A65%2C%22y%22%3A184%2C%22width%22%3A204%2C%22height%22%3A78%7D%2C%7B%22text%22%3A%22INT)%22%2C%22x%22%3A69%2C%22y%22%3A881%2C%22width%22%3A199%2C%22height%22%3A83%7D%2C%7B%22text%22%3A%22OCT(%22%2C%22x%22%3A63%2C%22y%22%3A379%2C%22width%22%3A205%2C%22height%22%3A70%7D%2C%7B%22text%22%3A%22HEX()%22%2C%22x%22%3A60%2C%22y%22%3A559%2C%22width%22%3A216%2C%22height%22%3A76%7D%2C%7B%22text%22%3A%22%E5%8A%9F%E8%83%BD%22%2C%22x%22%3A680%2C%22y%22%3A24%2C%22width%22%3A145%2C%22height%22%3A78%7D%2C%7B%22text%22%3A%22%E7%A4%BA%E4%BE%8B%22%2C%22x%22%3A1753%2C%22y%22%3A24%2C%22width%22%3A137%2C%22height%22%3A75%7D%2C%7B%22text%22%3A%22463%22%2C%22x%22%3A2177%2C%22y%22%3A1035%2C%22width%22%3A196%2C%22height%22%3A52%7D%2C%7B%22text%22%3A%22%E5%86%99%E6%B3%95%22%2C%22x%22%3A105%2C%22y%22%3A26%2C%22width%22%3A142%2C%22height%22%3A76%7D%2C%7B%22text%22%3A%22540%22%2C%22x%22%3A2225%2C%22y%22%3A884%2C%22width%22%3A156%2C%22height%22%3A53%7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%234b4a47%22%2C%22id%22%3A%22NUhar%22%7D"></card></p><h2 data-lake-id="zvPJz" id="zvPJz" data-lake-index-type="2"><span data-lake-id="u50bc78a2" id="u50bc78a2">输入语句</span></h2><p data-lake-id="uab05cc4b" id="uab05cc4b"><span data-lake-id="ua8f89164" id="ua8f89164">在 Python 中，输入语句用于：从键盘接收用户输入的内容。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E4%BD%BF%E7%94%A8input()%E8%8E%B7%E5%8F%96%E7%94%A8%E6%88%B7%E7%9A%84%E8%BE%93%E5%85%A5%5Cnname%20%3D%20input('%E8%AF%B7%E8%BE%93%E5%85%A5%E4%BD%A0%E7%9A%84%E5%A7%93%E5%90%8D%EF%BC%9A')%5Cnage%20%3D%20input('%E8%AF%B7%E8%BE%93%E5%85%A5%E4%BD%A0%E7%9A%84%E5%B9%B4%E9%BE%84%EF%BC%9A')%5Cn%5Cn%23%20input()%E8%8E%B7%E5%8F%96%E5%88%B0%E7%9A%84%E5%86%85%E5%AE%B9%E5%85%A8%E9%83%BD%E6%98%AF%E5%AD%97%E7%AC%A6%E4%B8%B2%E7%B1%BB%E5%9E%8B%5Cnprint(type(age))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22BpmiG%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><blockquote data-lake-id="u43a7033d" id="u43a7033d" class="lake-alert lake-alert-tips"><p data-lake-id="uf1310d72" id="uf1310d72"><strong><span data-lake-id="u6526a5e5" id="u6526a5e5">📋</span></strong><strong><span data-lake-id="u98f2647e" id="u98f2647e">备注</span></strong><span data-lake-id="u15e6c1d8" id="u15e6c1d8">：程序执行到 </span><code data-lake-id="uccdcb190" id="uccdcb190"><span data-lake-id="ued5c8880" id="ued5c8880">input()</span></code><span data-lake-id="u53de3931" id="u53de3931"> 时，会暂停等待用户的输入，用户输入后敲下回车，程序继续运行。 </span></p></blockquote><p data-lake-id="uff2e864e" id="uff2e864e"><code data-lake-id="ufd2fd8e2" id="ufd2fd8e2"><span data-lake-id="u8d7b8be6" id="u8d7b8be6">input()</span></code><span data-lake-id="uf2eb1220" id="uf2eb1220">所获取到的内容全都是字符串类型，不过我们可以手动进行数据类型转换。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22age%20%3D%20int(input('%E8%AF%B7%E8%BE%93%E5%85%A5%E4%BD%A0%E7%9A%84%E5%B9%B4%E9%BE%84%EF%BC%9A'))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22tS1No%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h1 data-lake-id="NFHUv" id="NFHUv" collapsed="true"><span data-lake-id="u58e94fb2" id="u58e94fb2">第 4 章 流程控制语句</span></h1><p data-lake-id="ube8f6e42" id="ube8f6e42"><span data-lake-id="u3cd3c3b0" id="u3cd3c3b0">程序并不是简单的“从上到下”执行，很多时候，我们希望程序能根据不同的情况，做出不同的选择，比如：根据情况跳过某些代码，或者重复执行某些代码，那这时就需要用到『流程控制语句』，程序的执行流程大体上可分为三类：</span><strong><span data-lake-id="u6c9c9ec4" id="u6c9c9ec4" style="color: #117CEE">顺序</span></strong><span data-lake-id="udafb431a" id="udafb431a">、</span><strong><span data-lake-id="ubec5f165" id="ubec5f165" style="color: #117CEE">分之</span></strong><span data-lake-id="u7719755c" id="u7719755c">、</span><strong><span data-lake-id="u7f376e01" id="u7f376e01" style="color: #117CEE">循环</span></strong><span data-lake-id="u9b4678c5" id="u9b4678c5">。</span></p><blockquote data-lake-id="u98df3dfe" id="u98df3dfe" class="lake-alert lake-alert-tips"><p data-lake-id="u8a2a87f3" id="u8a2a87f3"><strong><span data-lake-id="ub7f1f114" id="ub7f1f114">📋</span></strong><strong><span data-lake-id="u5b18d3bd" id="u5b18d3bd">备注</span></strong><span data-lake-id="u618c67f9" id="u618c67f9">：其中顺序执行是最简单的，就是按照程序的编写顺序依次执行，所以我们不再探讨顺序执行。</span></p></blockquote><h2 data-lake-id="TmEe3" id="TmEe3" data-lake-index-type="2"><span data-lake-id="u422bc089" id="u422bc089">分之</span></h2><ul list="u7d299845"><li fid="uc40496e9" data-lake-id="u941bb350" id="u941bb350"><span data-lake-id="ub6d6fe56" id="ub6d6fe56">分支有很多其他的称呼，比如：条件控制语句、分支语句、选择语句。</span></li><li fid="uc40496e9" data-lake-id="u7005e689" id="u7005e689"><span data-lake-id="u7c32ff31" id="u7c32ff31">分之是通过条件判断，来决定执行哪些代码。</span></li></ul><h3 data-lake-id="lzg5I" id="lzg5I" data-lake-index-type="2"><span data-lake-id="u65cab1eb" id="u65cab1eb">单分支</span></h3><p data-lake-id="uadb815a2" id="uadb815a2" style="text-align: justify"><strong><span data-lake-id="u92b4361b" id="u92b4361b">1️⃣</span></strong><strong><span data-lake-id="u57a4ded7" id="u57a4ded7">语法格式：</span></strong></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22if%20%E5%88%A4%E6%96%AD%E6%9D%A1%E4%BB%B6%3A%5Cn%20%20%20%20%E6%9D%A1%E4%BB%B6%E3%80%90%E6%88%90%E7%AB%8B%E3%80%91%E6%97%B6%E6%89%A7%E8%A1%8C%E7%9A%84%E4%BB%A3%E7%A0%811%5Cn%20%20%20%20%E6%9D%A1%E4%BB%B6%E3%80%90%E6%88%90%E7%AB%8B%E3%80%91%E6%97%B6%E6%89%A7%E8%A1%8C%E7%9A%84%E4%BB%A3%E7%A0%812%5Cn%20%20%20%20......%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22TIqop%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u8529b344" id="u8529b344" style="text-align: justify"><strong><span data-lake-id="u81994139" id="u81994139">2️⃣</span></strong><strong><span data-lake-id="ubdbdee7a" id="ubdbdee7a">语法图解：</span></strong></p><p data-lake-id="uec196b83" id="uec196b83"><card type="inline" name="image" value="data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2025%2Fpng%2F35780599%2F1760693605673-67877fd2-c41f-4df7-a1a5-912807f65b62.png%22%2C%22taskId%22%3A%22u9fc8ae9f-b7d0-4dd5-8e7d-735ac948b75%22%2C%22clientId%22%3A%22u9dc15b59-c913-4%22%2C%22originalType%22%3A%22binary%22%2C%22width%22%3A365.1514892578125%2C%22height%22%3A161%2C%22linkTarget%22%3A%22_blank%22%2C%22name%22%3A%22image.png%22%2C%22size%22%3A275146%2C%22from%22%3A%22paste%22%2C%22originWidth%22%3A982%2C%22originHeight%22%3A433%2C%22ratio%22%3A1.6500000953674316%2C%22status%22%3A%22done%22%2C%22style%22%3A%22none%22%2C%22ocrLocations%22%3A%5B%7B%22text%22%3A%22%E5%A6%82%E6%9E%9C%E5%B9%B4%E9%BE%84%E5%A4%A7%E4%BA%8E%E7%AD%89%E4%BA%8E18%E5%B2%81%2C%E9%82%A3%E5%B0%B1%E6%98%AF%E6%88%90%E5%B9%B4%E4%BA%BA%E4%BA%86.%22%2C%22x%22%3A24%2C%22y%22%3A25%2C%22width%22%3A941%2C%22height%22%3A50%7D%2C%7B%22text%22%3A%22T(%E4%BD%A0%E6%98%AF%E6%88%90%E5%B9%B4%E4%BA%BA%5C%22)%22%2C%22x%22%3A412%2C%22y%22%3A338%2C%22width%22%3A465%2C%22height%22%3A63%7D%2C%7B%22text%22%3A%22PRINT%22%2C%22x%22%3A285%2C%22y%22%3A347%2C%22width%22%3A191%2C%22height%22%3A50%7D%2C%7B%22text%22%3A%22%3E%3D18%22%2C%22x%22%3A374%2C%22y%22%3A277%2C%22width%22%3A174%2C%22height%22%3A46%7D%2C%7B%22text%22%3A%22%E8%A6%81%E6%89%A7%E8%A1%8C%E7%9A%84%E6%93%8D%E4%BD%9C%22%2C%22x%22%3A659%2C%22y%22%3A206%2C%22width%22%3A140%2C%22height%22%3A25%7D%2C%7B%22text%22%3A%22AGE%22%2C%22x%22%3A245%2C%22y%22%3A284%2C%22width%22%3A129%2C%22height%22%3A45%7D%2C%7B%22text%22%3A%22%E6%9D%A1%E4%BB%B6%E6%88%90%E7%AB%8B%E6%97%B6%22%2C%22x%22%3A659%2C%22y%22%3A178%2C%22width%22%3A120%2C%22height%22%3A25%7D%2C%7B%22text%22%3A%22%E5%88%A4%E6%96%AD%E6%9D%A1%E4%BB%B6%22%2C%22x%22%3A279%2C%22y%22%3A157%2C%22width%22%3A100%2C%22height%22%3A25%7D%2C%7B%22text%22%3A%22%E5%B8%83%E5%B0%94%E7%B1%BB%E5%9E%8B%22%2C%22x%22%3A282%2C%22y%22%3A200%2C%22width%22%3A95%2C%22height%22%3A26%7D%2C%7B%22text%22%3A%22%E4%BA%94F%22%2C%22x%22%3A149%2C%22y%22%3A275%2C%22width%22%3A81%2C%22height%22%3A55%7D%2C%7B%22text%22%3A%22%E7%A6%8F%22%2C%22x%22%3A52%2C%22y%22%3A145%2C%22width%22%3A25%2C%22height%22%3A89%7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%236a6662%22%2C%22id%22%3A%22gmjpC%22%7D"></card></p><blockquote data-lake-id="u84f64f0e" id="u84f64f0e" class="lake-alert lake-alert-color4"><p data-lake-id="u5c9c8850" id="u5c9c8850"><span data-lake-id="uebf0d435" id="uebf0d435" style="color: #AD1A2B">⚠️</span><strong><span data-lake-id="u134f28f8" id="u134f28f8" style="color: #AD1A2B">注意：</span></strong><span data-lake-id="u2b678512" id="u2b678512">Python 靠代码缩进来识别代码范围，所以条件成立时要执行的代码前，必须加空格。</span></p></blockquote><p data-lake-id="ubdc2b66d" id="ubdc2b66d" style="text-align: justify"><strong><span data-lake-id="u32d01f86" id="u32d01f86">3️⃣</span></strong><strong><span data-lake-id="u8d5a7fe3" id="u8d5a7fe3">示例代码：</span></strong></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22age%20%3D%20int(input('%E8%AF%B7%E8%BE%93%E5%85%A5%E4%BD%A0%E7%9A%84%E5%B9%B4%E9%BE%84%EF%BC%9A'))%5Cnif%20age%20%3E%3D%2018%3A%5Cn%20%20%20%20print('%E4%BD%A0%E6%98%AF%E6%88%90%E5%B9%B4%E4%BA%BA')%5Cn%20%20%20%20print('%E6%88%90%E5%B9%B4%E4%BA%BA%E7%9A%84%E4%B8%96%E7%95%8C%EF%BC%8C%E8%99%BD%E4%B8%8D%E5%AE%B9%E6%98%93%EF%BC%8C%E4%BD%86%E5%BE%88%E7%B2%BE%E5%BD%A9%EF%BC%81')%5Cnprint('%E6%AC%A2%E8%BF%8E%E4%BD%A0%E6%9D%A5%E5%AD%A6%E4%B9%A0Python%EF%BC%81')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse