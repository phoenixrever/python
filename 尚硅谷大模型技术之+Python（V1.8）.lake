ata-lake-id="u3b10b3a6" id="u3b10b3a6"><strong><span data-lake-id="ude4a4059" id="ude4a4059">测试代码</span></strong><span data-lake-id="ub301e6a8" id="ub301e6a8">：</span></li></ul><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22import%20time%5Cnwith%20open('demo.txt'%2C%20'at'%2C%20encoding%3D'utf-8')%20as%20file%3A%5Cn%20%20%20%20file.write('%E4%BD%A0%E5%A5%BD1')%5Cn%20%20%20%20file.write('%E4%BD%A0%E5%A5%BD2')%5Cn%20%20%20%20file.flush()%5Cn%20%20%20%20time.sleep(10000)%5Cn%20%20%20%20file.write('%E4%BD%A0%E5%A5%BD3')%5Cn%20%20%20%20file.write('%E4%BD%A0%E5%A5%BD4')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22customStyle%22%3A%5B%5D%2C%22fontSize%22%3A14%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22Y7fNN%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h2 data-lake-id="Yxxu4" id="Yxxu4" data-lake-index-type="2"><span data-lake-id="u86179901" id="u86179901">组合模式</span></h2><h3 data-lake-id="IlfwF" id="IlfwF"><span data-lake-id="u8bbc323f" id="u8bbc323f">1️⃣</span><code data-lake-id="uf39695f9" id="uf39695f9"><span data-lake-id="u04c26b28" id="u04c26b28">rt+</span></code><span data-lake-id="u7306e8d7" id="u7306e8d7">模式</span></h3><ul list="ubd2d8dfd"><li fid="u19db3f44" data-lake-id="ue81eb4fa" id="ue81eb4fa"><strong><span data-lake-id="u11679876" id="u11679876">概述：</span></strong><code data-lake-id="u24ad9408" id="u24ad9408"><span data-lake-id="u519a9a88" id="u519a9a88">r</span></code><span data-lake-id="u3d122fa7" id="u3d122fa7">模式可以读取，</span><code data-lake-id="u2285a8ea" id="u2285a8ea"><span data-lake-id="u9e86cb07" id="u9e86cb07">+</span></code><span data-lake-id="uf3bcee1b" id="uf3bcee1b">模式可以更新（读取或写入），所以</span><code data-lake-id="u6fa39c16" id="u6fa39c16"><span data-lake-id="ue6860fe7" id="ue6860fe7">rt+</span></code><span data-lake-id="u59b43756" id="u59b43756">模式可读可写。</span></li><li fid="u19db3f44" data-lake-id="u669cf20b" id="u669cf20b"><strong><span data-lake-id="u41cbbafd" id="u41cbbafd">注意：</span></strong><code data-lake-id="uf989615d" id="uf989615d"><span data-lake-id="u70ddd1f7" id="u70ddd1f7">r</span></code><span data-lake-id="u0c8b4c74" id="u0c8b4c74">模式打开文件后，文件指针在起始位置。</span></li><li fid="u19db3f44" data-lake-id="ud4a8feed" id="ud4a8feed"><strong><span data-lake-id="uadbf8399" id="uadbf8399">备注：</span></strong><span data-lake-id="u755321d1" id="u755321d1">由于</span><code data-lake-id="udcc2528c" id="udcc2528c"><span data-lake-id="udf399a06" id="udf399a06">t</span></code><span data-lake-id="ue302a6a8" id="ue302a6a8">是默认值，所以</span><code data-lake-id="u287f612f" id="u287f612f"><span data-lake-id="u46ae2f95" id="u46ae2f95">rt+</span></code><span data-lake-id="u346cb70e" id="u346cb70e">中的</span><code data-lake-id="uf76c0dba" id="uf76c0dba"><span data-lake-id="u495f52a0" id="u495f52a0">t</span></code><span data-lake-id="u4ce190ae" id="u4ce190ae">可以省略。</span></li><li fid="u19db3f44" data-lake-id="u9badccdc" id="u9badccdc"><strong><span data-lake-id="u41507747" id="u41507747">代码：</span></strong></li></ul><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22with%20open('a.txt'%2C%20'rt%2B'%2C%20encoding%3D'utf-8')%20as%20file%3A%5Cn%20%20%20%20%23%20seek(offset%2C%20whence)%E6%96%B9%E6%B3%95%EF%BC%9A%E7%94%A8%E4%BA%8E%E6%94%B9%E5%8F%98%E6%96%87%E4%BB%B6%E5%AF%B9%E8%B1%A1%E6%8C%87%E9%92%88%E7%9A%84%E4%BD%8D%E7%BD%AE%EF%BC%8C%E5%8F%82%E6%95%B0%E8%AF%B4%E6%98%8E%E5%A6%82%E4%B8%8B%EF%BC%9A%5Cn%20%20%20%20%23%20%20%20offset%EF%BC%9A%E5%81%8F%E7%A7%BB%E9%87%8F%EF%BC%8C%E8%A6%81%E7%A7%BB%E5%8A%A8%E5%A4%9A%E5%B0%91%E8%B7%9