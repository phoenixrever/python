%9A%E6%8C%87%E5%AE%9A%E5%AD%97%E7%AC%A6%E4%B8%B2%E4%B8%AD%E7%9A%84%E4%BB%BB%E6%84%8F%E5%AD%97%E7%AC%A6%5Cn%23%20%E8%A7%84%E5%88%99%EF%BC%9A%E4%BB%8E%E5%AD%97%E7%AC%A6%E4%B8%B2%E4%B8%A4%E7%AB%AF%E5%BC%80%E5%A7%8B%E5%88%A0%E9%99%A4%EF%BC%8C%E7%9B%B4%E5%88%B0%E9%81%87%E5%88%B0%E7%AC%AC%E4%B8%80%E4%B8%AA%E4%B8%8D%E5%9C%A8%E5%AD%97%E7%AC%A6%E4%B8%B2%E4%B8%AD%E7%9A%84%E5%AD%97%E7%AC%A6%E5%B0%B1%E5%81%9C%E4%B8%8B%5Cnmsg%20%3D%20'666%E5%B0%9A6%E7%A1%856%E8%B0%B7666'%5Cnresult%20%3D%20msg.strip('6')%5Cnprint(msg)%20%20%20%20%23%20666%E5%B0%9A6%E7%A1%856%E8%B0%B7666%5Cnprint(result)%20%23%20%E5%B0%9A6%E7%A1%856%E8%B0%B7%20%5Cn%5Cnmsg%20%3D%20'1234%E5%B0%9A12%E7%A1%8534%E8%B0%B74321'%5Cnresult%20%3D%20msg.strip('1324')%5Cnprint(msg)%20%20%20%20%20%23%201234%E5%B0%9A12%E7%A1%8534%E8%B0%B74321%5Cnprint(result)%20%20%23%20%E5%B0%9A12%E7%A1%8534%E8%B0%B7%5Cn%5Cnmsg%20%3D%20'34215%E5%B0%9A12%E7%A1%8534%E8%B0%B74132'%5Cnresult%20%3D%20msg.strip('5432')%5Cnprint(msg)%20%20%20%23%2034215%E5%B0%9A12%E7%A1%8534%E8%B0%B74132%5Cnprint(result)%23%2015%E5%B0%9A12%E7%A1%8534%E8%B0%B741%5Cn%5Cnmsg%20%3D%20'%20%20%E5%B0%9A%E7%A1%85%E8%B0%B7%20%20'%5Cnresult%20%3D%20msg.strip()%5Cnprint(msg)%20%20%20%23%20%20%20%E5%B0%9A%E7%A1%85%E8%B0%B7%20%20%5Cnprint(result)%23%20%E5%B0%9A%E7%A1%85%E8%B0%B7%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22zTeIW%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="fsqzP" id="fsqzP" data-lake-index-type="2"><span data-lake-id="ucaa9ce23" id="ucaa9ce23">字符串常用内置函数</span></h3><p data-lake-id="u91eb8b4f" id="u91eb8b4f"><span data-lake-id="uff635adf" id="uff635adf">字符串也可以使用：</span><code data-lake-id="u6dd437bf" id="u6dd437bf"><span data-lake-id="ud1f262a0" id="ud1f262a0">max</span></code><span data-lake-id="u4c182294" id="u4c182294">、</span><code data-lake-id="u2489a6b3" id="u2489a6b3"><span data-lake-id="u4a10059d" id="u4a10059d">min</span></code><span data-lake-id="u1a14dd18" id="u1a14dd18">、</span><code data-lake-id="u0f535b1c" id="u0f535b1c"><span data-lake-id="u1bcbed4b" id="u1bcbed4b">len</span></code><span data-lake-id="u2d7b7998" id="u2d7b7998">、</span><code data-lake-id="ub0664862" id="ub0664862"><span data-lake-id="u4ba70c57" id="u4ba70c57">sorted</span></code><span data-lake-id="ueea8ada6" id="ueea8ada6">、</span><code data-lake-id="u8c66525c" id="u8c66525c"><span data-lake-id="u2d131784" id="u2d131784">sum</span></code><span data-lake-id="u440af06d" id="u440af06d">函数，但实际开发中</span><code data-lake-id="uf4905df0" id="uf4905df0"><span data-lake-id="u074aa1b4" id="u074aa1b4">len</span></code><span data-lake-id="u41039c75" id="u41039c75">函数最常用。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20len%20%E5%87%BD%E6%95%B0%EF%BC%9A%E7%BB%9F%E8%AE%A1%E5%AD%97%E7%AC%A6%E4%B8%B2%E4%B8%AD%E5%AD%97%E7%AC%A6%E7%9A%84%E4%B8%AA%E6%95%B0%EF%BC%88%E5%AD%97%E7%AC%A6%E4%B8%B2%E9%95%BF%E5%BA%A6%EF%BC%89%5Cnmsg%20%3D%20'welcome%20to%20atguigu'%5Cnresult%20%3D%20len(msg)%5Cnprint(result)%20%23%2018%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22laFKu%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="vX5OZ" id="vX5OZ" data-lake-index-type="2"><span data-lake-id="u865fc1f9" id="u865fc1f9">遍历字符串</span></h3><p data-lake-id="u0316a716" id="u0316a716"><span data-lake-id="u8d4a37ee" id="u8d4a37ee">字符串的遍历，与列表一样，可以使用</span><code data-lake-id="u183dc992" id="u183dc992"><span data-lake-id="ub46de7bf" id="ub46de7bf">while</span></code><span data-lake-id="u299d1db5" id="u299d1db5">循环遍历，或</span><code data-lake-id="u400967c0" id="u400967c0"><span data-lake-id="ub7732dc5" id="ub7732dc5">for</span></code><span data-lake-id="u729e696e" id="u729e696e">循环遍历。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E4%BD%BF%E7%94%A8%20while%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%AD%97%E7%AC%A6%E4%B8%B2%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22msg%20%3D%20'welcome%20to%20atguigu'%5Cn%23%20while%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%5Cnindex%20%3D%200%5Cnwhile%20index%20%3C%20len(msg)%3A%5Cn%20%20%20%20print(msg%5Bindex%5D)%5Cn%20%20%20%20index%20%2B%3D%201%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E4%BD%BF%E7%94%A8%20while%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%AD%97%E7%AC%A6%E4%B8%B2%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Bae0r%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E4%BD%BF%E7%94%A8%20for%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%AD%97%E7%AC%A6%E4%B8%B2%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22msg%20%3D%20'welcome%20to%20atguigu'%5Cn%5Cn%23%20for%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%5Cnfor%20item%20in%20msg%3A%5Cn%20%20%20%20print(item)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E4%BD%BF%E7%94%A8%20for%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%AD%97%E7%AC%A6%E4%B8%B2%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22jxMio%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="wAI0t" id="wAI0t" data-lake-index-type="2"><span data-lake-id="uf3288e2e" id="uf3288e2e">序列的切片操作</span></h2><h3 data-lake-id="K5BYX" id="K5BYX" data-lake-index-type="2"><span data-lake-id="u5d7f218b" id="u5d7f218b">概述</span></h3><p data-lake-id="u8461e00f" id="u8461e00f"><strong><span data-lake-id="u29613a4a" id="u29613a4a">何为序列？</span></strong><span data-lake-id="u92d74c19" id="u92d74c19">—— 能连续存放元素的数据容器，而且元素有</span><strong><span data-lake-id="u68cdfbdf" id="u68cdfbdf" style="color: #AD1A2B">先后顺序</span></strong><span data-lake-id="u04d87187" id="u04d87187">，而且可以通过</span><strong><span data-lake-id="u0818efaf" id="u0818efaf" style="color: #AD1A2B">下标访问</span></strong><span data-lake-id="u1b2a321d" id="u1b2a321d">，所以我们学过的：列表、元组、字符串，都是序列。</span></p><p data-lake-id="u659a6923" id="u659a6923"><strong><span data-lake-id="ud73ff967" id="ud73ff967">何为切片？</span></strong><span data-lake-id="ufd2ae8ee" id="ufd2ae8ee">—— 从序列中按照指定范围，取出一部分元素，形成一个新的序列的操作。</span></p><h3 data-lake-id="UuaSM" id="UuaSM" data-lake-index-type="2"><span data-lake-id="u3cea49dd" id="u3cea49dd">基本语法</span></h3><p data-lake-id="u1b22780c" id="u1b22780c"><span data-lake-id="uf48395ac" id="uf48395ac">语法格式为：</span><code data-lake-id="u08fbfb79" id="u08fbfb79"><strong><span data-lake-id="u27cfa95d" id="u27cfa95d">序列[起始索引:结束索引:步长]</span></strong></code></p><p data-lake-id="ud812bbc4" id="ud812bbc4"><span data-lake-id="ufe554592" id="ufe554592">相关注意点如下：</span></p><blockquote data-lake-id="u2d04c546" id="u2d04c546" class="lake-alert lake-alert-info"><ol list="u647e9da2"><li fid="u2a9606f6" data-lake-id="ud4f3139c" id="ud4f3139c"><span data-lake-id="u3c396d66" id="u3c396d66">切片操作的区间是</span><strong><span data-lake-id="u34eeb050" id="u34eeb050" style="color: #AD1A2B">左闭右开</span></strong><span data-lake-id="u675f87fd" id="u675f87fd">的，即：截取时包含起始位置，但不包含结束位置。</span></li><li fid="u2a9606f6" data-lake-id="uf78681b5" id="uf78681b5"><span data-lake-id="u97387300" id="u97387300">步长是指取出元素时的间隔，例如：</span></li></ol><ul list="u7907c66f" data-lake-indent="1"><li fid="ufff259fb" data-lake-id="u1437309f" id="u1437309f"><span data-lake-id="uce50af58" id="uce50af58">步长为 1，就是一个一个取出。</span></li><li fid="ufff259fb" data-lake-id="u945f4d5b" id="u945f4d5b"><span data-lake-id="u93820b87" id="u93820b87">步长为 2，就是每次越过 1 个元素取出。</span></li><li fid="ufff259fb" data-lake-id="uff96ed3d" id="uff96ed3d"><span data-lake-id="uf72c0f62" id="uf72c0f62">步长为 3，就是每次越过 2 个元素取出。</span></li><li fid="ufff259fb" data-lake-id="u80182dfd" id="u80182dfd"><span data-lake-id="u982d715d" id="u982d715d">步长为 n，就是每次越过 n-1 个元素取出。</span></li></ul><ol list="uf52fd808" start="3"><li fid="u8b7b5ad4" data-lake-id="ua3b09acc" id="ua3b09acc"><span data-lake-id="ub60ffbc4" id="ub60ffbc4">起始索引默认值为 0，结束索引默认截取到末尾，步长默认值为 1。</span></li><li fid="u8b7b5ad4" data-lake-id="u511b98eb" id="u511b98eb"><span data-lake-id="u2c9f8d7a" id="u2c9f8d7a">当起始索引大于结束索引时，步长必须为负数，否则结果是空列表。</span></li></ol></blockquote><p data-lake-id="u59a5feb0" id="u59a5feb0"><span data-lake-id="u7d554ae4" id="u7d554ae4">测试代码：</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AF%B9%E5%88%97%E8%A1%A8%E8%BF%9B%E8%A1%8C%E5%88%87%E7%89%87%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B0%3A5%3A1%5D%5Cnprint(list2)%20%20%23%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%5D%5Cn%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B1%3A8%3A2%5D%5Cnprint(list2)%20%20%23%20%5B20%2C%2040%2C%2060%2C%2080%5D%5Cn%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B1%3A8%3A3%5D%5Cnprint(list2)%20%20%23%20%5B20%2C%2040%2C%2060%2C%2080%5D%5Cn%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B%3A%3A%5D%20%20%23%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnprint(list2)%5Cn%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B%3A999%3A%5D%20%5Cnprint(list2)%20%23%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cn%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B3%3A%3A%5D%20%20%5Cnprint(list2)%20%20%23%20%5B40%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cn%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B%3A5%3A%5D%5Cnprint(list2)%20%20%23%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%5D%5Cn%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B%3A%3A4%5D%5Cnprint(list2)%20%20%23%20%5B10%2C%2050%2C%2090%5D%5Cn%5Cn%23%20%E5%BD%93%E8%B5%B7%E5%A7%8B%E7%B4%A2%E5%BC%95%E5%A4%A7%E4%BA%8E%E7%BB%93%E6%9D%9F%E7%B4%A2%E5%BC%95%E6%97%B6%EF%BC%8C%E6%AD%A5%E9%95%BF%E5%BF%85%E9%A1%BB%E4%B8%BA%E8%B4%9F%E6%95%B0%EF%BC%8C%E5%90%A6%E5%88%99%E7%BB%93%E6%9E%9C%E6%98%AF%E7%A9%BA%E5%88%97%E8%A1%A8%E3%80%82%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B7%3A2%3A-1%5D%5Cnprint(list2)%20%20%23%20%5B80%2C%2070%2C%2060%2C%2050%2C%2040%5D%5Cn%5Cn%23%20%E4%B8%80%E4%B8%AA%E7%89%B9%E6%AE%8A%E6%83%85%E5%86%B5%EF%BC%9A%E5%BD%93%E5%90%8C%E6%97%B6%E7%9C%81%E7%95%A5%E8%B5%B7%E5%A7%8B%E7%B4%A2%E5%BC%95%E5%92%8C%E7%BB%93%E6%9D%9F%E7%B4%A2%E5%BC%95%E6%97%B6%EF%BC%8C%E5%A6%82%E6%9E%9C%E6%AD%A5%E9%95%BF%E4%B8%BA%E8%B4%9F%E6%95%B0%EF%BC%8C%E9%82%A3Python%E4%BC%9A%E8%87%AA%E5%8A%A8%E5%AF%B9%E8%B0%83%EF%BC%9A%E8%B5%B7%E5%A7%8B%E4%BD%8D%E7%BD%AE%E5%92%8C%E7%BB%93%E6%9D%9F%E4%BD%8D%E7%BD%AE%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%5D%5Cnlist2%20%3D%20list1%5B%3A%3A-1%5D%5Cnprint(list2)%20%20%23%20%5B100%2C%2090%2C%2080%2C%2070%2C%2060%2C%2050%2C%2040%2C%2030%2C%2020%2C%2010%5D%5Cn%5Cn%23%20%E5%AF%B9%E5%85%83%E7%BB%84%E8%BF%9B%E8%A1%8C%E5%88%87%E7%89%87%5Cntuple1%20%3D%20(10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100)%5Cntuple2%20%3D%20tuple1%5B0%3A5%3A1%5D%5Cnprint(tuple2)%20%20%23%20(10%2C%2020%2C%2030%2C%2040%2C%2050)%5Cn%5Cn%23%20%E5%AF%B9%E5%AD%97%E7%AC%A6%E4%B8%B2%E8%BF%9B%E8%A1%8C%E5%88%87%E7%89%87%5Cnmsg1%20%3D%20'welcome%20to%20atguigu'%5Cnmsg2%20%3D%20msg1%5B2%3A9%3A2%5D%5Cnprint(msg2)%20%20%23%20(10%2C%2020%2C%2030%2C%2040%2C%2050)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22LO1pV%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="nXrMv" id="nXrMv" data-lake-index-type="2"><span data-lake-id="udd132b39" id="udd132b39">序列的其他操作</span></h2><p data-lake-id="ua9a3c67f" id="ua9a3c67f"><span data-lake-id="u0b235c12" id="u0b235c12">1️⃣</span><strong><span data-lake-id="u33c38c24" id="u33c38c24">序列相加： </span></strong><span data-lake-id="u2cb502a6" id="u2cb502a6">把两个序列拼接在一起。</span></p><blockquote data-lake-id="u2f0cc4cf" id="u2f0cc4cf" class="lake-alert lake-alert-color4"><p data-lake-id="u24663d5d" id="u24663d5d"><span data-lake-id="u3b2e0b1e" id="u3b2e0b1e">📢</span><strong><span data-lake-id="ud2d10204" id="ud2d10204">注意：</span></strong><span data-lake-id="u3125be46" id="u3125be46">只有同类型的序列才能相加（字符串+字符串、列表+列表、元组+元组）</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%88%97%E8%A1%A8%E7%9B%B8%E5%8A%A0%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%5D%5Cnlist2%20%3D%20%5B50%2C%2060%2C%2070%2C%2080%5D%5Cnlist3%20%3D%20list1%20%2B%20list2%5Cnprint(list3)%20%20%23%20%5B10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080%5D%5Cn%5Cn%23%20%E5%85%83%E7%BB%84%E7%9B%B8%E5%8A%A0%5Cntuple1%20%3D%20(10%2C%2020%2C%2030%2C%2040)%5Cntuple2%20%3D%20(50%2C%2060%2C%2070%2C%2080)%5Cntuple3%20%3D%20tuple1%20%2B%20tuple2%5Cnprint(tuple3)%20%20%23%20(10%2C%2020%2C%2030%2C%2040%2C%2050%2C%2060%2C%2070%2C%2080)%5Cn%5Cn%23%20%E5%AD%97%E7%AC%A6%E6%8D%A2%E7%9B%B8%E5%8A%A0%5Cnstr1%20%3D%20'hello'%5Cnstr2%20%3D%20'atguigu'%5Cnstr3%20%3D%20str1%20%2B%20str2%5Cnprint(str3)%20%23%20helloatguigu%5Cn%5Cn%23%20%E9%94%99%E8%AF%AF%E7%A4%BA%E4%BE%8B%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%5D%5Cnstr1%20%3D%20'hello'%5Cnprint(list1%20%2B%20str1)%20%23%20%E6%8A%A5%E9%94%99%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Kp81F%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u645802a7" id="u645802a7"><span data-lake-id="u972348ae" id="u972348ae">2️⃣</span><strong><span data-lake-id="u670d6219" id="u670d6219">序列相乘（重复）：</span></strong><span data-lake-id="u39ce4026" id="u39ce4026">把序列重复指定的次数。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%BA%8F%E5%88%97%E7%9B%B8%E4%B9%98%EF%BC%88%E9%87%8D%E5%A4%8D%EF%BC%89%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%5D%5Cnlist2%20%3D%20list1%20*%203%5Cnprint(list2)%20%20%23%20%5B10%2C%2020%2C%2030%2C%2040%2C%2010%2C%2020%2C%2030%2C%2040%2C%2010%2C%2020%2C%2030%2C%2040%5D%5Cn%5Cntuple1%20%3D%20(10%2C%2020%2C%2030%2C%2040)%5Cntuple2%20%3D%20tuple1%20*%203%5Cnprint(tuple2)%20%20%23%20(10%2C%2020%2C%2030%2C%2040%2C%2010%2C%2020%2C%2030%2C%2040%2C%2010%2C%2020%2C%2030%2C%2040)%5Cn%5Cnstr1%20%3D%20'hello'%5Cnstr2%20%3D%20str1%20*%206%5Cnprint(str2)%20%20%23%20hellohellohellohellohellohello%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22dnxM0%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="DZFW6" id="DZFW6" data-lake-index-type="2"><span data-lake-id="u3128eb57" id="u3128eb57">集合</span></h2><h3 data-lake-id="PQsEw" id="PQsEw" data-lake-index-type="2"><span data-lake-id="ua8af057f" id="ua8af057f">概述</span></h3><p data-lake-id="u922a8c05" id="u922a8c05"><span data-lake-id="u3f08e621" id="u3f08e621">集合是一种：</span><strong><span data-lake-id="u48513666" id="u48513666" style="color: #117CEE">无序</span></strong><span data-lake-id="u60979ed8" id="u60979ed8">、</span><strong><span data-lake-id="u1bfda42c" id="u1bfda42c" style="color: #117CEE">元素唯一</span></strong><span data-lake-id="u4bb61215" id="u4bb61215">的容器类型。</span></p><blockquote data-lake-id="u53ff8220" id="u53ff8220" class="lake-alert lake-alert-tips"><p data-lake-id="uc8e7b11a" id="uc8e7b11a"><span data-lake-id="ucec87e1d" id="ucec87e1d">📋</span><strong><span data-lake-id="udc4f6831" id="udc4f6831">备注：</span></strong><span data-lake-id="u994791e1" id="u994791e1">无序是指从集合中取出元素的顺序，与定义集合时存入的顺序不一定一致。</span></p></blockquote><p data-lake-id="ue4b67c96" id="ue4b67c96"><span data-lake-id="ue52b3f14" id="ue52b3f14">集合分为两种，分别是：</span></p><ol list="u67b1d902"><li fid="u2adb919b" data-lake-id="ued7ab00a" id="ued7ab00a"><strong><span data-lake-id="u416e776b" id="u416e776b">可变集合（set）</span></strong><span data-lake-id="u6dc0821a" id="u6dc0821a">：内部的元素无序（不保证顺序）、不能通过下标访问元素、会自动去除重复元素。</span></li><li fid="u2adb919b" data-lake-id="ud9b71435" id="ud9b71435"><strong><span data-lake-id="ufd489d79" id="ufd489d79">不可变集合（forzenset）</span></strong><span data-lake-id="u55f30932" id="u55f30932">：特点和可变集合一样，唯一的区别就是：其中的元素不可修改。</span></li></ol><h3 data-lake-id="Ka2g6" id="Ka2g6" data-lake-index-type="2"><span data-lake-id="uf225cd24" id="uf225cd24">定义集合</span></h3><p data-lake-id="ud92c7648" id="ud92c7648"><span data-lake-id="u12bbbe2c" id="u12bbbe2c">1️⃣</span><span data-lake-id="u4e531c6e" id="u4e531c6e">可变集合的定义方式：使用花括号</span><code data-lake-id="u187f0f65" id="u187f0f65"><span data-lake-id="u47005790" id="u47005790">{}</span></code><span data-lake-id="ub0202e5b" id="ub0202e5b">包裹，不同的数据项之间，用</span><code data-lake-id="u27a9de6b" id="u27a9de6b"><span data-lake-id="uae6f671a" id="uae6f671a">,</span></code><span data-lake-id="u23cd8d8c" id="u23cd8d8c">做分隔。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E6%9C%89%E5%86%85%E5%AE%B9%E7%9A%84%E3%80%90%E5%8F%AF%E5%8F%98%E9%9B%86%E5%90%88%E3%80%91%5Cns1%20%3D%20%7B10%2C%2020%2C%2020%2C%2030%2C%2040%2C%2040%2C%2050%2C%2060%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%7D%5Cns2%20%3D%20%7B'%E4%BD%A0%E5%A5%BD'%2C%20'hello'%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20'atguigu'%2C%20'%E5%8C%97%E4%BA%AC'%7D%5Cns3%20%3D%20%7B10%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20True%2C%201%2C%2012.4%7D%5Cnprint(type(s1)%2C%20s1)%20%20%23%20%3Cclass%20'set'%3E%20%7B100%2C%2070%2C%2040%2C%2010%2C%2080%2C%2050%2C%2020%2C%2090%2C%2060%2C%2030%7D%5Cnprint(type(s2)%2C%20s2)%20%20%23%20%3Cclass%20'set'%3E%20%7B'atguigu'%2C%20'hello'%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20'%E5%8C%97%E4%BA%AC'%7D%5Cnprint(type(s3)%2C%20s3)%20%20%23%20%3Cclass%20'set'%3E%20%7BTrue%2C%2010%2C%20'%E4%BD%A0%E5%A5%BD'%2C%2012.4%7D%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E7%A9%BA%E9%9B%86%E5%90%88%EF%BC%88%E5%8F%AF%E5%8F%98%E9%9B%86%E5%90%88%EF%BC%89%5Cns1%20%3D%20set()%5Cnprint(type(s1)%2C%20s1)%20%20%23%20%3Cclass%20'set'%3E%20set()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22vyCDA%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><blockquote data-lake-id="u75447812" id="u75447812" class="lake-alert lake-alert-color4"><p data-lake-id="u2ead6dc6" id="u2ead6dc6"><strong><span data-lake-id="ue1cfc8c6" id="ue1cfc8c6" style="color: #AD1A2B">📢</span></strong><strong><span data-lake-id="u22e74396" id="u22e74396" style="color: #AD1A2B">注意：</span></strong><span data-lake-id="u5a3b4f01" id="u5a3b4f01">不能直接写</span><code data-lake-id="uecc26842" id="uecc26842"><span data-lake-id="u61a7ec64" id="u61a7ec64">{}</span></code><span data-lake-id="u347e09fc" id="u347e09fc">来定义空集合，因为直接写</span><code data-lake-id="u084fbbf1" id="u084fbbf1"><span data-lake-id="u2f57d1d7" id="u2f57d1d7">{}</span></code><span data-lake-id="udcc21cfd" id="udcc21cfd">定义的是：空字典。</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E4%B8%8D%E8%83%BD%E7%9B%B4%E6%8E%A5%E5%86%99%7B%7D%E6%9D%A5%E5%AE%9A%E4%B9%89%E7%A9%BA%E9%9B%86%E5%90%88%EF%BC%8C%E5%9B%A0%E4%B8%BA%E7%9B%B4%E6%8E%A5%E5%86%99%7B%7D%E5%AE%9A%E4%B9%89%E7%9A%84%E6%98%AF%EF%BC%9A%E7%A9%BA%E5%AD%97%E5%85%B8%5Cns2%20%3D%20%7B%7D%5Cnprint(type(s2)%2C%20s2)%20%20%23%20%3Cclass%20'dict'%3E%20%7B%7D%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22FJW9m%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u770b46fe" id="u770b46fe"><span data-lake-id="ua10b396a" id="ua10b396a">2️⃣</span><span data-lake-id="u69c3e751" id="u69c3e751">不可变集合的定义方式：借助内置的</span><code data-lake-id="u60397692" id="u60397692"><span data-lake-id="ub8d44c00" id="ub8d44c00">forzenset</span></code><span data-lake-id="u9ddfdd8a" id="u9ddfdd8a">函数。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E6%9C%89%E5%86%85%E5%AE%B9%E7%9A%84%E3%80%90%E4%B8%8D%E5%8F%AF%E5%8F%98%E9%9B%86%E5%90%88%E3%80%91%5Cns1%20%3D%20frozenset(%7B10%2C%2020%2C%2020%2C%2030%2C%2040%2C%2040%2C%2050%2C%2060%2C%2060%2C%2070%2C%2080%2C%2090%2C%20100%7D)%5Cns2%20%3D%20frozenset(%7B'%E4%BD%A0%E5%A5%BD'%2C%20'hello'%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20'atguigu'%2C%20'%E5%8C%97%E4%BA%AC'%7D)%5Cns3%20%3D%20frozenset(%7B10%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20True%2C%201%2C%2012.4%7D)%5Cnprint(type(s1)%2C%20s1)%5Cnprint(type(s2)%2C%20s2)%5Cnprint(type(s3)%2C%20s3)%5Cn%5Cn%23%20frozenset%20%E6%8E%A5%E6%94%B6%E7%9A%84%E5%8F%82%E6%95%B0%EF%BC%8C%E5%8F%AF%E4%BB%A5%E6%98%AF%E4%BB%BB%E6%84%8F%E5%8F%AF%E8%BF%AD%E4%BB%A3%E5%AF%B9%E8%B1%A1%EF%BC%8C%E4%BD%86%E6%9C%80%E7%BB%88%E8%BF%94%E5%9B%9E%E7%9A%84%E4%B8%80%E5%AE%9A%E6%98%AF%E3%80%90%E4%B8%8D%E5%8F%AF%E5%8F%98%E9%9B%86%E5%90%88%E3%80%91%5Cns1%20%3D%20frozenset(%5B10%2C%2020%2C%2030%2C%2040%2C%2050%5D)%5Cns2%20%3D%20frozenset((10%2C%2020%2C%2030%2C%2040%2C%2050))%5Cns3%20%3D%20frozenset('hello')%5Cnprint(type(s1)%2C%20s1)%5Cnprint(type(s2)%2C%20s2)%5Cnprint(type(s3)%2C%20s3)%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E7%A9%BA%E9%9B%86%E5%90%88%EF%BC%88%E4%B8%8D%E5%8F%AF%E5%8F%98%E9%9B%86%E5%90%88%EF%BC%89%5Cns3%20%3D%20frozenset()%5Cnprint(type(s3)%2C%20s3)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22S6BMX%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u8c5934d8" id="u8c5934d8"><span data-lake-id="u10d7b232" id="u10d7b232">3️⃣</span><span data-lake-id="u8b94718c" id="u8b94718c">集合中不能嵌套【可变集合】，但可以嵌套【不可变集合】</span></p><blockquote data-lake-id="u765600de" id="u765600de"><p data-lake-id="u22bd54ea" id="u22bd54ea"><span data-lake-id="u726d16cf" id="u726d16cf">为什么会这样？—— 只有“不可变”的东西，才能安全的放进集合里。</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E9%9B%86%E5%90%88%E4%B8%AD%E4%B8%8D%E8%83%BD%E5%B5%8C%E5%A5%97%E3%80%90%E5%8F%AF%E5%8F%98%E9%9B%86%E5%90%88%E3%80%91%EF%BC%8C%E4%BD%86%E5%8F%AF%E4%BB%A5%E5%B5%8C%E5%A5%97%E3%80%90%E4%B8%8D%E5%8F%AF%E5%8F%98%E9%9B%86%E5%90%88%E3%80%91%5Cn%23%20%E9%80%9A%E4%BF%97%E7%90%86%E8%A7%A3%EF%BC%9A%E5%8F%AA%E6%9C%89%E2%80%9C%E4%B8%8D%E5%8F%AF%E5%8F%98%E2%80%9D%E7%9A%84%E4%B8%9C%E8%A5%BF%EF%BC%8C%E6%89%8D%E8%83%BD%E5%AE%89%E5%85%A8%E7%9A%84%E6%94%BE%E8%BF%9B%E9%9B%86%E5%90%88%E9%87%8C%5Cns1%20%3D%20%7B10%2C%2020%2C%2030%2C%2040%2C%2050%7D%5Cns2%20%3D%20frozenset(%7B100%2C%20200%2C%20300%2C%20400%2C%20500%7D)%5Cnl1%20%3D%20%5B666%2C%20777%2C%20888%5D%5Cnt1%20%3D%20('hello'%2C%20'atguigu'%2C%20'%E5%8C%97%E4%BA%AC')%5Cn%5Cns3%20%3D%20%7B11%2C%2022%2C%2033%2C%20s1%7D%20%20%23%20%E6%8A%A5%E9%94%99%5Cns3%20%3D%20%7B11%2C%2022%2C%2033%2C%20s2%7D%20%20%23%20%E6%B2%A1%E9%97%AE%E9%A2%98%5Cns3%20%3D%20%7B11%2C%2022%2C%2033%2C%20l1%7D%20%20%23%20%E6%8A%A5%E9%94%99%5Cns3%20%3D%20%7B11%2C%2022%2C%2033%2C%20t1%7D%20%20%23%20%E6%B2%A1%E9%97%AE%E9%A2%98%5Cnprint(s3)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22S1ECN%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="BvwHn" id="BvwHn" data-lake-index-type="2"><span data-lake-id="u95e29bca" id="u95e29bca">增删</span><span data-lake-id="u62b70805" id="u62b70805" style="color: #8A8F8D">改查</span></h3><p data-lake-id="u4a2eeec2" id="u4a2eeec2"><span data-lake-id="ubb4e1f28" id="ubb4e1f28">1️⃣</span><strong><span data-lake-id="u7fc8cad8" id="u7fc8cad8">新增</span></strong></p><p data-lake-id="ubd8dc3f0" id="ubd8dc3f0"><strong><span data-lake-id="u998de1a6" id="u998de1a6">方式1：</span></strong><span data-lake-id="u50398cd2" id="u50398cd2">使用</span><code data-lake-id="u480e2447" id="u480e2447"><span data-lake-id="u721d9f80" id="u721d9f80">集合.add(元素)</span></code><span data-lake-id="u27ae4bf6" id="u27ae4bf6">，向集合中添加元素，无返回值。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode