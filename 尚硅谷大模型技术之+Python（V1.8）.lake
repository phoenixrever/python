B%E4%BD%95%E6%88%90%E7%BB%A9%EF%BC%81')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22C0czy%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="UZQNZ" id="UZQNZ" data-lake-index-type="2"><span data-lake-id="u0708701c" id="u0708701c">元组</span></h2><h3 data-lake-id="ExDvU" id="ExDvU" data-lake-index-type="2"><span data-lake-id="u3ac90c36" id="u3ac90c36">概述</span></h3><p data-lake-id="u35ec6812" id="u35ec6812"><strong><span data-lake-id="u1d78f029" id="u1d78f029">元组：</span></strong><span data-lake-id="u7c6694fe" id="u7c6694fe">用来存放一组有序的数据，但其中的内容一旦创建就</span><strong><span data-lake-id="ub1eb6200" id="ub1eb6200" style="color: #AD1A2B">不可修改</span></strong><span data-lake-id="u22b4badd" id="u22b4badd">（不能增、删、改，只能查）。</span></p><blockquote data-lake-id="u68fe7d8f" id="u68fe7d8f" class="lake-alert lake-alert-tips"><p data-lake-id="u466eceac" id="u466eceac"><span data-lake-id="u495bd77d" id="u495bd77d" style="color: #585A5A">由于元组不可变，所以元组不能使用</span><code data-lake-id="u4c2314fd" id="u4c2314fd"><span data-lake-id="u59c1293d" id="u59c1293d" style="color: #585A5A">append()</span></code><span data-lake-id="u63358142" id="u63358142" style="color: #585A5A">、</span><code data-lake-id="u4b859d0f" id="u4b859d0f"><span data-lake-id="ucab4ee9e" id="ucab4ee9e" style="color: #585A5A">insert()</span></code><span data-lake-id="u274d22ad" id="u274d22ad" style="color: #585A5A">这些方法，它里面的元素也不能被重新赋值。</span></p></blockquote><h3 data-lake-id="bPag9" id="bPag9" data-lake-index-type="2"><span data-lake-id="uda43de0f" id="uda43de0f">定义元组</span></h3><p data-lake-id="u84950b76" id="u84950b76"><span data-lake-id="u2b3c566c" id="u2b3c566c">使用方括号</span><code data-lake-id="u78b1f39f" id="u78b1f39f"><span data-lake-id="ua69effc2" id="ua69effc2">()</span></code><span data-lake-id="u72c057b8" id="u72c057b8">来定义一个列表，用</span><code data-lake-id="u52c8d121" id="u52c8d121"><span data-lake-id="ud4f2c4d5" id="ud4f2c4d5">,</span></code><span data-lake-id="u8d2f48f4" id="u8d2f48f4">去分隔不同的元素：</span></p><p data-lake-id="u58fdf627" id="u58fdf627"><card type="inline" name="image" value="data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2025%2Fpng%2F35780599%2F1760880506287-8a927eb5-b697-4e35-beaa-1ebaf62a39bd.png%22%2C%22taskId%22%3A%22u4732ac57-2c84-4437-95a6-5228b6f0329%22%2C%22clientId%22%3A%22uebac531c-c172-4%22%2C%22originalType%22%3A%22binary%22%2C%22width%22%3A379.3863220214844%2C%22height%22%3A35%2C%22linkTarget%22%3A%22_blank%22%2C%22name%22%3A%22image.png%22%2C%22size%22%3A9350%2C%22from%22%3A%22paste%22%2C%22originWidth%22%3A725%2C%22originHeight%22%3A66%2C%22ratio%22%3A1.6500000953674316%2C%22status%22%3A%22done%22%2C%22style%22%3A%22none%22%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%23595959%22%2C%22id%22%3A%22u3349c9d8%22%7D"></card></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E5%AE%9A%E4%B9%89%E5%85%83%E7%BB%84%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E6%9C%89%E5%86%85%E5%AE%B9%E7%9A%84%E5%85%83%E7%BB%84%5Cnt1%20%3D%20(28%2C%2067%2C%2021%2C%2067%2C%2011)%5Cnt2%20%3D%20('%E5%8C%97%E4%BA%AC'%2C%20'%E5%B0%9A%E7%A1%85%E8%B0%B7'%2C%20'%E4%BD%A0%E5%A5%BD')%5Cnt3%20%3D%20(100%2C%20True%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20None)%5Cnt4%20%3D%20(100%2C%20True%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20None%2C%20(50%2C%2060%2C%2070))%5Cnprint(type(t1)%2C%20t1)%20%20%23%20%3Cclass%20'tuple'%3E%20(28%2C%2067%2C%2021%2C%2067%2C%2011)%5Cnprint(type(t2)%2C%20t2)%20%20%23%20%3Cclass%20'tuple'%3E%20('%E5%8C%97%E4%BA%AC'%2C%20'%E5%B0%9A%E7%A1%85%E8%B0%B7'%2C%20'%E4%BD%A0%E5%A5%BD')%5Cnprint(type(t3)%2C%20t3)%20%20%23%20%3Cclass%20'tuple'%3E%20(100%2C%20True%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20None)%5Cnprint(type(t4)%2C%20t4)%20%20%23%20%3Cclass%20'tuple'%3E%20(100%2C%20True%2C%20'%E4%BD%A0%E5%A5%BD'%2C%20None%2C%20(50%2C%2060%2C%2070))%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E7%A9%BA%E5%85%83%E7%BB%84%5Cnt1%20%3D%20()%5Cnt2%20%3D%20tuple()%5Cnprint(type(t1)%2C%20t1)%20%20%23%20%3Cclass%20'tuple'%3E%20()%5Cnprint(type(t2)%2C%20t2)%20%20%23%20%3Cclass%20'tuple'%3E%20()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E5%AE%9A%E4%B9%89%E5%85%83%E7%BB%84%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22VXLS4%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><p data-lake-id="u95c88bba" id="u95c88bba"><span data-lake-id="u0b0e6d4a" id="u0b0e6d4a">当元组中只有一个元素时，末尾必须写上</span><code data-lake-id="u40e3370c" id="u40e3370c"><span data-lake-id="u340a1323" id="u340a1323">,</span></code></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E5%AE%9A%E4%B9%89%E5%8F%AA%E6%9C%89%E4%B8%80%E4%B8%AA%E5%85%83%E7%B4%A0%E7%9A%84%E5%85%83%E7%BB%84%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E5%8F%AA%E6%9C%89%E4%B8%80%E4%B8%AA%E5%85%83%E7%B4%A0%E7%9A%84%E5%85%83%E7%BB%84%5Cnt1%20%3D%20('%E4%BD%A0%E5%A5%BD'%2C)%5Cnt2%20%3D%20(18%2C)%5Cnprint(type(t1)%2C%20t1)%20%20%23%20%3Cclass%20'tuple'%3E%20('%E4%BD%A0%E5%A5%BD'%2C)%5Cnprint(type(t2)%2C%20t2)%20%20%23%20%3Cclass%20'tuple'%3E%20(18%2C)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E5%AE%9A%E4%B9%89%E5%8F%AA%E6%9C%89%E4%B8%80%E4%B8%AA%E5%85%83%E7%B4%A0%E7%9A%84%E5%85%83%E7%BB%84%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22NL6Kx%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u58136e2a" id="u58136e2a"><span data-lake-id="ufb3fa21d" id="ufb3fa21d">实际开发中的元组，不一定是我们自己定义的，比如函数的可变参数</span><code data-lake-id="ubb36bc94" id="ubb36bc94"><span data-lake-id="u9f819467" id="u9f819467">*args</span></code><span data-lake-id="u996edbf4" id="u996edbf4">就是一个元组</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9E%E9%99%85%E5%BC%80%E5%8F%91%E4%B8%AD%E7%9A%84%E5%85%83%E7%BB%84%EF%BC%8C%E4%B8%8D%E4%B8%80%E5%AE%9A%E6%98%AF%E6%88%91%E4%BB%AC%E8%87%AA%E5%B7%B1%E5%AE%9A%E4%B9%89%E7%9A%84%EF%BC%8C%E6%AF%94%E5%A6%82%E5%87%BD%E6%95%B0%E7%9A%84%E5%8F%AF%E5%8F%98%E5%8F%82%E6%95%B0*args%E5%B0%B1%E6%98%AF%E4%B8%80%E4%B8%AA%E5%85%83%E7%BB%84%5Cndef%20demo(*args)%3A%5Cn%20%20%20%20return%20sum(args)%5Cnresult%20%3D%20demo(100%2C%20200%2C%20300)%5Cnprint(result)%20%20%23%20600%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22kb1Xp%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="KHEcV" id="KHEcV" data-lake-index-type="2"><span data-lake-id="u323bc8b2" id="u323bc8b2">读取数据</span></h3><p data-lake-id="ub873a519" id="ub873a519"><span data-lake-id="ue5be5bf3" id="ue5be5bf3">元组也支持下标，所以使用</span><code data-lake-id="ub0820c64" id="ub0820c64"><span data-lake-id="ub24eb49b" id="ub24eb49b">元组名[索引值]</span></code><span data-lake-id="u8a003982" id="u8a003982">的方式来读取值。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%85%83%E7%BB%84%E7%9A%84%E4%B8%8B%E6%A0%87%5Cnt1%20%3D%20(28%2C%2067%2C%2021%2C%2067%2C%2011)%5Cnprint(t1%5B3%5D)%20%20%23%2067%5Cnprint(t1%5B-1%5D)%20%23%2011%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22y9y0P%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><h3 data-lake-id="JAaWL" id="JAaWL" data-lake-index-type="2"><span data-lake-id="ub3440e63" id="ub3440e63">元组不可修改</span></h3><p data-lake-id="uc1881a5a" id="uc1881a5a"><span data-lake-id="ue22e1fbf" id="ue22e1fbf">元组中的元素，不可修改，但元组中如果存放了可变类型（如：列表），那可变类型中的内容仍可修改。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%85%83%E7%BB%84%E4%B8%AD%E7%9A%84%E5%85%83%E7%B4%A0%EF%BC%8C%E4%B8%8D%E5%8F%AF%E4%BF%AE%E6%94%B9%5Cnt1%20%3D%20(28%2C%2067%2C%2021%2C%2067%2C%2011)%5Cnt1%5B0%5D%20%3D%20100%5Cn%5Cn%23%20%E5%85%83%E7%BB%84%E4%B8%AD%E7%9A%84%E5%85%83%E7%B4%A0%EF%BC%8C%E4%B8%8D%E5%8F%AF%E4%BF%AE%E6%94%B9%EF%BC%8C%E4%BD%86%E5%85%83%E7%BB%84%E4%B8%AD%E5%A6%82%E6%9E%9C%E5%AD%98%E6%94%BE%E4%BA%86%E5%8F%AF%E5%8F%98%E7%B1%BB%E5%9E%8B%EF%BC%88%E5%88%97%E8%A1%A8%EF%BC%89%EF%BC%8C%E9%82%A3%E5%8F%AF%E5%8F%98%E7%B1%BB%E5%9E%8B%E4%B8%AD%E7%9A%84%E5%86%85%E5%AE%B9%E4%BB%8D%E5%8F%AF%E4%BF%AE%E6%94%B9%5Cnt2%20%3D%20(28%2C%2067%2C%2021%2C%2067%2C%2011%2C%20%5B100%2C%20200%2C%20300%2C%20('%E4%BD%A0%E5%A5%BD'%2C%20'%E5%B0%9A%E7%A1%85%E8%B0%B7')%5D)%5Cnt2%5B5%5D%20%3D%20400%5Cnt2%5B5%5D%5B2%5D%20%3D%20400%5Cnt2%5B5%5D%5B3%5D%5B0%5D%20%3D%20'hello'%5Cnprint(t2)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22dxz49%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="cevVR" id="cevVR" data-lake-index-type="2"><span data-lake-id="u71272baa" id="u71272baa">元组的常用方法</span></h3><p data-lake-id="ue1f792a6" id="ue1f792a6"><span data-lake-id="u13f15bce" id="u13f15bce">由于元组不可修改，所以它的常用方法只有两个：</span></p><p data-lake-id="u4118ad93" id="u4118ad93"><span data-lake-id="u5e8a8c2a" id="u5e8a8c2a">1️⃣</span><span data-lake-id="u0b6a2d3f" id="u0b6a2d3f">使用</span><code data-lake-id="u6e34cc86" id="u6e34cc86"><span data-lake-id="u4783a269" id="u4783a269">元组.index(元素)</span></code><span data-lake-id="ufaa44ce7" id="ufaa44ce7">，获取指定元素在元组中第一次出现的下标。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20index%20%E6%96%B9%E6%B3%95%EF%BC%9A%E8%8E%B7%E5%8F%96%E6%8C%87%E5%AE%9A%E5%85%83%E7%B4%A0%E5%9C%A8%E5%85%83%E7%BB%84%E4%B8%AD%E7%AC%AC%E4%B8%80%E6%AC%A1%E5%87%BA%E7%8E%B0%E7%9A%84%E4%B8%8B%E6%A0%87%E3%80%82%5Cnt1%20%3D%20(28%2C%2067%2C%2021%2C%2067%2C%2011)%5Cnresult%20%3D%20t1.index(67)%5Cnprint(result)%20%20%23%201%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Oscv4%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u9dcd9689" id="u9dcd9689"><span data-lake-id="u4cea5746" id="u4cea5746">2️⃣</span><span data-lake-id="ua064960b" id="ua064960b">使用</span><code data-lake-id="u47219d3c" id="u47219d3c"><span data-lake-id="u28ab97c7" id="u28ab97c7">元组.count(元组)</span></code><span data-lake-id="u5ca38999" id="u5ca38999">，统计指定元素在元组中出现的次数。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20count%20%E6%96%B9%E6%B3%95%EF%BC%9A%E7%BB%9F%E8%AE%A1%E6%8C%87%E5%AE%9A%E5%85%83%E7%B4%A0%E5%9C%A8%E5%85%83%E7%BB%84%E4%B8%AD%E5%87%BA%E7%8E%B0%E7%9A%84%E6%AC%A1%E6%95%B0%E3%80%82%5Cnt1%20%3D%20(28%2C%2067%2C%2021%2C%2067%2C%2011)%5Cnresult%20%3D%20t1.count(67)%5Cnprint(result)%20%20%23%202%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22ilfwa%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="VwBlN" id="VwBlN" data-lake-index-type="2"><span data-lake-id="u4f889556" id="u4f889556">元组的常用内置函数</span></h3><p data-lake-id="u9448bd78" id="u9448bd78"><span data-lake-id="uc245a00c" id="uc245a00c">元组的常用内置函数和列表一样，依然是这几个：</span><code data-lake-id="u8ea1046b" id="u8ea1046b"><span data-lake-id="ua2addba3" id="ua2addba3">max</span></code><span data-lake-id="ude91ec60" id="ude91ec60">、</span><code data-lake-id="u575831ce" id="u575831ce"><span data-lake-id="u9f1c0fcb" id="u9f1c0fcb">min</span></code><span data-lake-id="u926ac54e" id="u926ac54e">、</span><code data-lake-id="u2d1fa2ee" id="u2d1fa2ee"><span data-lake-id="udf69d716" id="udf69d716">len</span></code><span data-lake-id="u03be55f3" id="u03be55f3">、</span><code data-lake-id="ucd29e9ca" id="ucd29e9ca"><span data-lake-id="uee24d8d7" id="uee24d8d7">sorted</span></code><span data-lake-id="u908170c0" id="u908170c0">、</span><code data-lake-id="u8680eb5a" id="u8680eb5a"><span data-lake-id="uc1b81c18" id="uc1b81c18">sum</span></code><span data-lake-id="ucb7e7ca4" id="ucb7e7ca4">。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%B8%B8%E7%94%A8%E5%86%85%E7%BD%AE%E5%87%BD%E6%95%B0%5Cn%23%20max%20%E5%87%BD%E6%95%B0%EF%BC%8C%E8%BF%94%E5%9B%9E%E5%85%83%E7%BB%84%E4%B8%AD%E7%9A%84%E6%9C%80%E5%A4%A7%E5%80%BC%5Cnt1%20%3D%20(23%2C%2011%2C%2032%2C%2030%2C%2017)%5Cnresult%20%3D%20max(t1)%5Cnprint(result)%20%20%23%2032%5Cn%5Cn%23%20min%20%E5%87%BD%E6%95%B0%EF%BC%8C%E8%BF%94%E5%9B%9E%E5%85%83%E7%BB%84%E4%B8%AD%E7%9A%84%E6%9C%80%E5%B0%8F%E5%80%BC%5Cnt1%20%3D%20(23%2C%2011%2C%2032%2C%2030%2C%2017)%5Cnresult%20%3D%20min(t1)%5Cnprint(result)%20%20%23%2011%5Cn%5Cn%23%20len%20%E5%87%BD%E6%95%B0%EF%BC%8C%E8%BF%94%E5%9B%9E%E5%85%83%E7%BB%84%E4%B8%AD%E5%85%83%E7%B4%A0%E7%9A%84%E4%B8%AA%E6%95%B0%EF%BC%88%E5%85%83%E7%BB%84%E9%95%BF%E5%BA%A6%EF%BC%89%5Cnt1%20%3D%20(23%2C%2011%2C%2032%2C%2030%2C%2017)%5Cnresult%20%3D%20len(t1)%5Cnprint(result)%20%20%23%205%5Cn%5Cn%23%20sorted%20%E5%87%BD%E6%95%B0%EF%BC%8C%E5%AF%B9%E5%85%83%E7%BB%84%E8%BF%9B%E8%A1%8C%E6%8E%92%E5%BA%8F%EF%BC%88%E4%B8%8D%E4%BF%AE%E6%94%B9%E5%8E%9F%E5%85%83%E7%BB%84%EF%BC%8C%E8%BF%94%E5%9B%9E%E4%B8%80%E4%B8%AA%E6%96%B0%E7%9A%84%E5%88%97%E8%A1%A8%EF%BC%89%5Cnt1%20%3D%20(23%2C%2011%2C%2032%2C%2030%2C%2017)%5Cnresult%20%3D%20sorted(t1%2C%20reverse%3DTrue)%5Cnprint(tuple(result))%20%23%20(32%2C%2030%2C%2023%2C%2017%2C%2011)%5Cn%5Cn%23%20sum%20%E5%87%BD%E6%95%B0%EF%BC%8C%E7%BB%9F%E8%AE%A1%E5%85%83%E7%BB%84%E4%B8%AD%E6%89%80%E6%9C%89%E5%85%83%E7%B4%A0%E7%9A%84%E5%92%8C%EF%BC%88%E5%85%83%E7%B4%A0%E5%BF%85%E9%A1%BB%E6%98%AF%E7%BA%AF%E6%95%B0%E5%AD%97%EF%BC%89%5Cnt1%20%3D%20(23%2C%2011%2C%2032%2C%2030%2C%2017)%5Cnresult%20%3D%20sum(t1)%5Cnprint(result)%20%23%20113%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Oqhir%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="um1vY" id="um1vY" data-lake-index-type="2"><span data-lake-id="u61a0db4b" id="u61a0db4b">元组的循环遍历</span></h3><p data-lake-id="uf848d0f6" id="uf848d0f6"><span data-lake-id="ua41427d0" id="ua41427d0">元组的遍历与列表一样，可以使用</span><code data-lake-id="u1c708492" id="u1c708492"><span data-lake-id="ue341163b" id="ue341163b">while</span></code><span data-lake-id="ua0f85dbe" id="ua0f85dbe">循环遍历，或</span><code data-lake-id="uaa354227" id="uaa354227"><span data-lake-id="u59bf687f" id="u59bf687f">for</span></code><span data-lake-id="u0592b675" id="u0592b675">循环遍历。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E4%BD%BF%E7%94%A8%20while%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%88%97%E8%A1%A8%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%85%83%E7%BB%84%E7%9A%84%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%5Cnt1%20%3D%20(23%2C%2011%2C%2032%2C%2030%2C%2017)%5Cn%5Cn%23%20while%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%5Cnindex%20%3D%200%5Cnwhile%20index%20%3C%20len(t1)%3A%5Cn%20%20%20%20print(t1%5Bindex%5D)%5Cn%20%20%20%20index%20%2B%3D%201%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E4%BD%BF%E7%94%A8%20while%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%88%97%E8%A1%A8%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22bfCd1%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E4%BD%BF%E7%94%A8%20for%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%88%97%E8%A1%A8%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%85%83%E7%BB%84%E7%9A%84%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%5Cnt1%20%3D%20(23%2C%2011%2C%2032%2C%2030%2C%2017)%5Cn%5Cn%23%20for%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%5Cnfor%20item%20in%20t1%3A%5Cn%20%20%20%20print(item)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E4%BD%BF%E7%94%A8%20for%20%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86%E5%88%97%E8%A1%A8%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22hmizz%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><h3 data-lake-id="aA41F" id="aA41F" data-lake-index-type="2"><span data-lake-id="uc837a2ff" id="uc837a2ff">解包列表或元组传参</span></h3><p data-lake-id="u2d23b3bf" id="u2d23b3bf"><span data-lake-id="u3bec4663" id="u3bec4663">解包列表、解包元组传参，就是把其中的元素依次取出，作为多个独立的参数传入函数。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E5%87%BD%E6%95%B0%E6%97%B6%EF%BC%8C%E4%BD%BF%E7%94%A8*args%EF%BC%88%E5%8F%98%E9%87%8F%E4%B8%8D%E4%B8%80%E5%AE%9A%E9%9D%9E%E8%A6%81%E7%94%A8args%EF%BC%8C%E6%AF%94%E5%A6%82%E5%86%99%EF%BC%9A*data%E4%B9%9F%E8%A1%8C%EF%BC%89%EF%BC%8C%E5%B0%86%E6%94%B6%E5%88%B0%E7%9A%84%E5%A4%9A%E4%B8%AA%E5%8F%82%E6%95%B0%EF%BC%8C%E6%89%93%E5%8C%85%E6%88%90%E4%B8%80%E4%B8%AA%E5%85%83%E7%BB%84%5Cndef%20test(*args)%3A%5Cn%20%20%20%20print(f'%E6%88%91%E6%98%AFtest%E5%87%BD%E6%95%B0%EF%BC%8C%E6%88%91%E6%94%B6%E5%88%B0%E7%9A%84%E5%8F%82%E6%95%B0%E6%98%AF%EF%BC%9A%7Bargs%7D%EF%BC%8C%E5%8F%82%E6%95%B0%E7%B1%BB%E5%9E%8B%E6%98%AF%EF%BC%9A%7Btype(args)%7D')%5Cn%5Cnlist1%20%3D%20%5B100%2C%20200%2C%20300%2C%20400%5D%5Cntuple1%20%3D%20('%E4%BD%A0%E5%A5%BD'%2C%20'%E5%8C%97%E4%BA%AC'%2C%20'%E5%B0%9A%E7%A1%85%E8%B0%B7')%5Cn%5Cn%23%20%E5%87%BD%E6%95%B0%E8%B0%83%E7%94%A8%E6%97%B6%EF%BC%8C%E6%AD%A3%E5%B8%B8%E4%BC%A0%E9%80%92%EF%BC%9A%E5%88%97%E8%A1%A8%20%E6%88%96%20%E5%85%83%E7%BB%84%5Cn%23%20test(list1)%5Cn%23%20test(tuple1)%5Cn%5Cn%23%20%E5%87%BD%E6%95%B0%E8%B0%83%E7%94%A8%E6%97%B6%EF%BC%8C%E4%BD%BF%E7%94%A8*%E5%AF%B9%EF%BC%9A%E5%88%97%E8%A1%A8%20%E6%88%96%20%E5%85%83%E7%BB%84%E8%BF%9B%E8%A1%8C%E8%A7%A3%E5%8C%85%E5%90%8E%EF%BC%8C%E5%86%8D%E4%BC%A0%E9%80%92%E5%8F%82%E6%95%B0%5Cntest(*list1)%20%20%23%20%E6%AD%A4%E7%A7%8D%E5%86%99%E6%B3%95%E7%9B%B8%E5%BD%93%E4%BA%8E%EF%BC%9Atest(100%2C%20200%2C%20300%2C%20400)%5Cntest(*tuple1)%20%20%23%20%E6%AD%A4%E7%A7%8D%E5%86%99%E6%B3%95%E7%9B%B8%E5%BD%93%E4%BA%8E%EF%BC%9Atest('%E4%BD%A0%E5%A5%BD'%2C%20'%E5%8C%97%E4%BA%AC'%2C%20'%E5%B0%9A%E7%A1%85%E8%B0%B7')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22QoIa3%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="uuNRR" id="uuNRR" data-lake-index-type="2"><span data-lake-id="u98761844" id="u98761844">元组特点总结</span></h3><ol list="u663a7084"><li fid="u2d86aa7a" data-lake-id="u7de0c7f9" id="u7de0c7f9"><span data-lake-id="ub80cc6d8" id="ub80cc6d8">可存放不同类型的元素。</span></li><li fid="u2d86aa7a" data-lake-id="u23332ae7" id="u23332ae7"><span data-lake-id="uf5c1ddc3" id="uf5c1ddc3">元素是有序存储的（正索引、负索引）。</span></li><li fid="u2d86aa7a" data-lake-id="u1df11e6b" id="u1df11e6b"><span data-lake-id="ua03c807e" id="ua03c807e">元组中的元素允许重复。</span></li><li fid="u2d86aa7a" data-lake-id="ucdbcdad0" id="ucdbcdad0"><span data-lake-id="u5e453537" id="u5e453537">元素不允许修改文（不能：增、删、改、只能：查）。</span></li><li fid="u2d86aa7a" data-lake-id="uaa3df435" id="uaa3df435"><span data-lake-id="u1e972b11" id="u1e972b11">长度固定定（一旦创建，元素个数不能增减）。</span></li></ol><blockquote data-lake-id="ua7ade7c4" id="ua7ade7c4" class="lake-alert lake-alert-info"><p data-lake-id="u68c7fc8a" id="u68c7fc8a"><strong><span data-lake-id="u72e4dd8d" id="u72e4dd8d">📍</span></strong><strong><span data-lake-id="u8c5a9c37" id="u8c5a9c37">一句话总结</span></strong><span data-lake-id="ubabae084" id="ubabae084">：元组是一种“只读”的数据容器，想保存一批“不会变的数据”时，首选元组。</span></p></blockquote><h3 data-lake-id="xCFfX" id="xCFfX" data-lake-index-type="2"><span data-lake-id="u3fd8dce0" id="u3fd8dce0">元组 VS 列表</span></h3><table data-lake-id="oTGNn" id="oTGNn" margin="true" row-head="#074A92;#FFFFFF" hindent="2em" class="lake-table" style="width: 591px"><colgroup><col width="133"><col width="207"><col width="251"></colgroup><tbody><tr data-lake-id="u3be1c3db" id="u3be1c3db"><td data-lake-id="u9e8e4641" id="u9e8e4641"><p data-lake-id="u2bb2b0ff" id="u2bb2b0ff" style="text-align: center"><span data-lake-id="ucb46d484" id="ucb46d484">区别点</span></p></td><td data-lake-id="u223f1cea" id="u223f1cea"><p data-lake-id="u57970c33" id="u57970c33" style="text-align: center"><span data-lake-id="u5342942c" id="u5342942c">列表（list）</span></p></td><td data-lake-id="ub47030fb" id="ub47030fb"><p data-lake-id="u5ced6bc7" id="u5ced6bc7" style="text-align: center"><span data-lake-id="ue30e4ae3" id="ue30e4ae3">元组（tuple）</span></p></td></tr><tr data-lake-id="ubfde8038" id="ubfde8038"><td data-lake-id="u1f4e0a32" id="u1f4e0a32"><p data-lake-id="u76f20a90" id="u76f20a90" style="text-align: center"><strong><span data-lake-id="u2dd66880" id="u2dd66880">是否可变</span></strong></p></td><td data-lake-id="uc7cb7488" id="uc7cb7488"><p data-lake-id="u38d62217" id="u38d62217" style="text-align: center"><span data-lake-id="u18f500f2" id="u18f500f2">​</span><span data-lake-id="u78c0d755" id="u78c0d755">可变</span></p></td><td data-lake-id="u3748a1cd" id="u3748a1cd"><p data-lake-id="ue4488e9a" id="ue4488e9a" style="text-align: center"><span data-lake-id="u8fca13e1" id="u8fca13e1">​</span><span data-lake-id="u62006123" id="u62006123">不可变</span></p></td></tr><tr data-lake-id="u0d3d6ad6" id="u0d3d6ad6"><td data-lake-id="u23841226" id="u23841226"><p data-lake-id="u9a58397e" id="u9a58397e" style="text-align: center"><strong><span data-lake-id="ua64e8c2a" id="ua64e8c2a">使用场景</span></strong></p></td><td data-lake-id="u428ec9b4" id="u428ec9b4"><p data-lake-id="u65e7fe20" id="u65e7fe20" style="text-align: center"><span data-lake-id="u9fa2b817" id="u9fa2b817">可变数据集合</span></p></td><td data-lake-id="uea314de1" id="uea314de1"><p data-lake-id="u127bbc94" id="u127bbc94" style="text-align: center"><span data-lake-id="u04c4d785" id="u04c4d785">不变的结构化数据，安全性更高</span></p></td></tr><tr data-lake-id="u741d4024" id="u741d4024"><td data-lake-id="ud6eb7eb4" id="ud6eb7eb4"><p data-lake-id="uae9e0a90" id="uae9e0a90" style="text-align: center"><strong><span data-lake-id="u544ce417" id="u544ce417">语义</span></strong></p></td><td data-lake-id="u6b55b4c4" id="u6b55b4c4"><p data-lake-id="u81f45b52" id="u81f45b52" style="text-align: center"><span data-lake-id="u37a8715c" id="u37a8715c">表示一组可能变化的数据</span></p></td><td data-lake-id="u00ed937d" id="u00ed937d"><p data-lake-id="uc966bac6" id="uc966bac6" style="text-align: center"><span data-lake-id="u97250bdc" id="u97250bdc">表示一组固定结构的数据</span></p></td></tr></tbody></table><blockquote data-lake-id="u9843f11e" id="u9843f11e" hindent="2em" class="lake-alert lake-alert-info"><p data-lake-id="u255b2563" id="u255b2563"><strong><span data-lake-id="ua63961ae" id="ua63961ae" class="lake-fontsize-1515" style="color: #AD1A2B">📢</span></strong><strong><span data-lake-id="u139c4184" id="u139c4184" class="lake-fontsize-1515" style="color: #AD1A2B">注意：</span></strong><span data-lake-id="u33b27e63" id="u33b27e63" class="lake-fontsize-1515">元组不是用来替代列表的，而是用来在数据不需要修改的情况下，作为列表的补充选择。  </span></p></blockquote><h2 data-lake-id="hJPlw" id="hJPlw" data-lake-index-type="2"><span data-lake-id="ua39da758" id="ua39da758">字符串</span></h2><h3 data-lake-id="xBdfX" id="xBdfX" data-lake-index-type="2"><span data-lake-id="uc3884e75" id="uc3884e75">概述</span></h3><p data-lake-id="u04414fc2" id="u04414fc2"><strong><span data-lake-id="u783d505f" id="u783d505f">字符串（str）</span></strong><span data-lake-id="uf5de9e35" id="uf5de9e35">：用来存放一组有序的字符数据，但其中的内容不可修改（只能查，不能增删改）， 我们之前讲解了一部分字符串的相关知识，如：字符串的定义方式、字符串的格式化输出等，这些内容就不在本小节重复讲解了。</span></p><h3 data-lake-id="a51Mc" id="a51Mc" data-lake-index-type="2"><span data-lake-id="u56f25adc" id="u56f25adc">字符串的特点</span></h3><p data-lake-id="ue5831732" id="ue5831732"><span data-lake-id="u563b461b" id="u563b461b">1️⃣</span><span data-lake-id="u5d20b464" id="u5d20b464">字符串和列表、元组一样，也支持下标</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AD%97%E7%AC%A6%E4%B8%B2%E7%9A%84%E4%B8%8B%E6%A0%87%5Cnmsg%20%3D%20'welcome%20to%20atguigu'%5Cnprint(msg%5B3%5D)%20%20%23%20c%5Cnprint(msg%5B-1%5D)%20%23%20u%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22YiPJY%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u19d4b243" id="u19d4b243"><span data-lake-id="u71bd5917" id="u71bd5917">2️⃣</span><span data-lake-id="ua3ff341d" id="ua3ff341d">字符串不可修改，不可嵌套</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AD%97%E7%AC%A6%E4%B8%B2%E4%B8%AD%E7%9A%84%E5%AD%97%E7%AC%A6%EF%BC%8C%E4%B8%8D%E5%8F%AF%E4%BF%AE%E6%94%B9%5Cnmsg%20%3D%20'welcome%20to%20atguigu'%5Cnmsg%5B0%5D%20%3D%20'a'%5Cn%5Cn%23%20%E5%AD%97%E7%AC%A6%E4%B8%B2%E4%B8%8D%E8%83%BD%E5%B5%8C%E5%A5%97%5Cnmsg%20%3D%20'welcome%20to'hello'%20atguigu'%5Cnmsg%20%3D%20'welcome%20to%5C%22hello%5C%22%20atguigu'%5Cnmsg%20%3D%20'welcome%20to%5C%5C'hello%5C%5C'%20atguigu'%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22uWWg0%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="cizkw" id="cizkw" data-lake-index-type="2"><span data-lake-id="u1af3892e" id="u1af3892e">字符串常用方法</span></h3><p data-lake-id="ub46a9c66" id="ub46a9c66"><span data-lake-id="uf0a98206" id="uf0a98206">1️⃣</span><span data-lake-id="u89b959e6" id="u89b959e6">使用</span><code data-lake-id="u740be367" id="u740be367"><span data-lake-id="uf4125aed" id="uf4125aed">字符串.index(字符)</span></code><span data-lake-id="uf90f204d" id="uf90f204d">，获取『指定字符』在字符串中『第一次』出现的下标，返回值：下标。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20index%20%E6%96%B9%E6%B3%95%EF%BC%9A%E8%8E%B7%E5%8F%96%E6%8C%87%E5%AE%9A%E5%AD%97%E7%AC%A6%EF%BC%8C%E5%9C%A8%E5%AD%97%E7%AC%A6%E4%B8%B2%E4%B8%AD%E7%AC%AC%E4%B8%80%E6%AC%A1%E5%87%BA%E7%8E%B0%E7%9A%84%E4%B8%8B%E6%A0%87%5Cnmsg%20%3D%20'welcome%20to%20atguigu'%5Cnresult%20%3D%20msg.index('t')%5Cnprint(result)%20%20%23%208%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22mVKbX%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="uac5703af" id="uac5703af"><span data-lake-id="u8d5c6c4e" id="u8d5c6c4e">2️⃣</span><span data-lake-id="u2fc06cda" id="u2fc06cda">使用</span><code data-lake-id="u8b8f2ac4" id="u8b8f2ac4"><span data-lake-id="ue31737be" id="ue31737be">字符串.split(字符)</span></code><span data-lake-id="u48bea5f4" id="u48bea5f4">，将字符串按照『指定字符』进行分隔，返回值：列表。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20split%20%E6%96%B9%E6%B3%95%EF%BC%9A%E5%B0%86%E5%AD%97%E7%AC%A6%E4%B8%B2%E6%8C%89%E7%85%A7%E6%8C%87%E5%AE%9A%E5%AD%97%E7%AC%A6%E8%BF%9B%E8%A1%8C%E5%88%86%E9%9A%94%EF%BC%8C%E5%B9%B6%E5%B0%86%E5%88%86%E9%9A%94%E5%90%8E%E7%9A%84%E5%86%85%E5%AE%B9%E5%AD%98%E5%85%A5%E4%B8%80%E4%B8%AA%E5%88%97%E8%A1%A8%5Cnmsg%20%20%3D%20'%E5%B0%9A%E7%A1%85%E8%B0%B7%40atguigu%40%E4%BD%A0%E5%A5%BD'%5Cnresult%20%3D%20msg.split('%40')%5Cnprint(msg)%20%20%23%20%E5%B0%9A%E7%A1%85%E8%B0%B7%40atguigu%40%E4%BD%A0%E5%A5%BD%5Cnprint(result)%20%20%23%20%5B'%E5%B0%9A%E7%A1%85%E8%B0%B7'%2C%