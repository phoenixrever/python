C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAPerson%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnp2%20%3D%20Person('%E6%9D%8E%E5%9B%9B'%2C%2022%2C%20'%E5%A5%B3')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22AoEJh%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="ubab63551" id="ubab63551"><span data-lake-id="u46c1f658" id="u46c1f658">3️⃣</span><span data-lake-id="uadfe94e1" id="uadfe94e1">通过实例的“点”语法，可以『访问』或『修改』实例的属性。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%A6%82%E6%9E%9C%E7%9B%B4%E6%8E%A5%E6%89%93%E5%8D%B0%E4%B8%80%E4%B8%AA%E5%AE%9E%E4%BE%8B%E7%9A%84%E8%AF%9D%EF%BC%8C%E6%88%91%E4%BB%AC%E6%98%AF%E7%9C%8B%E4%B8%8D%E5%88%B0%E5%AE%9E%E4%BE%8B%E8%BA%AB%E4%B8%8A%E7%9A%84%E5%B1%9E%E6%80%A7%E7%9A%84%5Cnprint(p1)%5Cnprint(p2)%5Cn%5Cn%23%20%E9%80%9A%E8%BF%87%E7%82%B9%E8%AF%AD%E6%B3%95%E5%8F%AF%E4%BB%A5%E8%AE%BF%E9%97%AE%E6%88%96%E4%BF%AE%E6%94%B9%E5%AE%9E%E4%BE%8B%E8%BA%AB%E4%B8%8A%E7%9A%84%E5%B1%9E%E6%80%A7%5Cnprint(p1.name)%5Cnprint(p1.age)%5Cnprint(p1.gender)%5Cnprint('-'%20*%2020)%5Cnprint(p2.name)%5Cnprint(p2.age)%5Cnprint(p2.gender)%5Cnp1.name%20%3D%20'%E9%98%BF%E4%B8%89'%5Cnprint(p1.name)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22guAED%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u7316b7f9" id="u7316b7f9"><span data-lake-id="u3b64cafd" id="u3b64cafd">4️⃣</span><span data-lake-id="u007285cb" id="u007285cb">通过</span><code data-lake-id="u5318517e" id="u5318517e"><strong><span data-lake-id="uc90803fc" id="uc90803fc">实例.__dict__</span></strong></code><strong><span data-lake-id="u2dc49cff" id="u2dc49cff"> </span></strong><span data-lake-id="u32472f22" id="u32472f22">的方式，可以查看实例身上的所有属性。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E9%80%9A%E8%BF%87%20%E5%AE%9E%E4%BE%8B.__dict__%20%E5%8F%AF%E4%BB%A5%E6%9F%A5%E7%9C%8B%E5%AE%9E%E4%BE%8B%E8%BA%AB%E4%B8%8A%E7%9A%84%E6%89%80%E6%9C%89%E5%B1%9E%E6%80%A7%5Cnprint(p1.__dict__)%5Cnprint(p2.__dict__)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22ZpVcJ%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="uea4c2cd4" id="uea4c2cd4"><span data-lake-id="ufe07dff2" id="ufe07dff2">5️⃣</span><span data-lake-id="ud6fd0c21" id="ud6fd0c21">在实例创建完毕后，也可以通过</span><code data-lake-id="u4a541a65" id="u4a541a65"><strong><span data-lake-id="u95dea7b1" id="u95dea7b1">实例.属性名 = 值</span></strong></code><span data-lake-id="uc234be8d" id="uc234be8d">的形式，给实例追加属性。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9E%E4%BE%8B%E5%88%9B%E5%BB%BA%E5%AE%8C%E6%AF%95%E5%90%8E%EF%BC%8C%E4%BE%9D%E7%84%B6%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%20%E5%AE%9E%E4%BE%8B.%E5%B1%9E%E6%80%A7%E5%90%8D%20%3D%20%E5%80%BC%20%E5%8E%BB%E7%BB%99%E5%AE%9E%E4%BE%8B%E8%BF%BD%E5%8A%A0%E5%B1%9E%E6%80%A7%5Cnp1.address%20%3D%20'%E5%8C%97%E4%BA%AC%E6%98%8C%E5%B9%B3%E5%AE%8F%E7%A6%8F%E7%A7%91%E6%8A%80%E5%9B%AD'%5Cnprint(p1.__dict__)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22rNlmM%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="uecb803a5" id="uecb803a5"><span data-lake-id="ubd17748f" id="ubd17748f">6️⃣</span><span data-lake-id="uaa41a54c" id="uaa41a54c">通过</span><code data-lake-id="ud710e4aa" id="ud710e4aa"><span data-lake-id="u06e33c4e" id="u06e33c4e">type()</span></code><span data-lake-id="u62d6636d" id="u62d6636d"> 函数，可以查看某个实例对象，是由哪个类创建出来的。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E9%80%9A%E8%BF%87type%E5%87%BD%E6%95%B0%EF%BC%8C%E5%8F%AF%E4%BB%A5%E6%9F%A5%E7%9C%8B%E6%9F%90%E4%B8%AA%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%EF%BC%8C%E6%98%AF%E7%94%B1%E5%93%AA%E4%B8%AA%E7%B1%BB%E5%88%9B%E5%BB%BA%E5%87%BA%E6%9D%A5%E7%9A%84%5Cnprint(type(p1))%5Cnprint(type(p2))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22eOGcq%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="b8DJo" id="b8DJo" data-lake-index-type="2"><strong><span data-lake-id="u9cfe2d43" id="u9cfe2d43">自定义方法（行为）</span></strong></h3><blockquote data-lake-id="ud8223f52" id="ud8223f52"><p data-lake-id="u94b91610" id="u94b91610"><span data-lake-id="u9795c997" id="u9795c997">我们之前提到过：类是用来规定一类事物所具有的『属性』和『行为』，在上一小节中，我们已经通过 </span><code data-lake-id="u04d86d56" id="u04d86d56"><strong><span data-lake-id="u1935f8a4" id="u1935f8a4">self.属性名 = 值</span></strong></code><span data-lake-id="u77c7141a" id="u77c7141a">的形式，为实例对象添加了『属性』；接下来，要想让对象具备相应的『行为』，就需要通过『自定义方法』来实现。</span></p></blockquote><blockquote data-lake-id="u2b79a614" id="u2b79a614" class="lake-alert lake-alert-info"><p data-lake-id="u16b321d9" id="u16b321d9"><span data-lake-id="u7ff9a267" id="u7ff9a267">『自定义方法』的第一个参数也是</span><code data-lake-id="u6cf79d66" id="u6cf79d66"><span data-lake-id="u04bda7b6" id="u04bda7b6">self</span></code><span data-lake-id="u36f0b10b" id="u36f0b10b">，是调用该方法的实例对象。</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20%23%20%E5%88%9D%E5%A7%8B%E5%8C%96%E6%96%B9%E6%B3%95%EF%BC%88%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E5%B1%9E%E6%80%A7%EF%BC%89%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%20%20%20%20%23%20%E8%87%AA%E5%AE%9A%E4%B9%89%E6%96%B9%E6%B3%95%EF%BC%88%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E8%A1%8C%E4%B8%BA%EF%BC%89%5Cn%20%20%20%20%23%20speak%E6%96%B9%E6%B3%95%E6%94%B6%E5%88%B0%E7%9A%84%E5%8F%82%E6%95%B0%E6%98%AF%EF%BC%9A%E8%B0%83%E7%94%A8speak%E6%96%B9%E6%B3%95%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%EF%BC%88self%EF%BC%89%E3%80%81%E5%85%B6%E5%AE%83%E5%8F%82%E6%95%B0%5Cn%20%20%20%20%23%20speak%E6%96%B9%E6%B3%95%E5%8F%AA%E6%9C%89%E4%B8%80%E4%BB%BD%EF%BC%8C%E4%BF%9D%E5%AD%98%E5%9C%A8Person%E7%B1%BB%E8%BA%AB%E4%B8%8A%E7%9A%84%EF%BC%8C%E6%89%80%E6%9C%89Person%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%EF%BC%8C%E9%83%BD%E5%8F%AF%E4%BB%A5%E8%B0%83%E7%94%A8%E5%88%B0speak%E6%96%B9%E6%B3%95%5Cn%20%20%20%20def%20speak(self%2C%20msg)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%8F%AB%7Bself.name%7D%EF%BC%8C%20%E5%B9%B4%E9%BE%84%E6%98%AF%7Bself.age%7D%EF%BC%8C%20%E6%80%A7%E5%88%AB%E6%98%AF%7Bself.gender%7D%EF%BC%8C%E6%88%91%E6%83%B3%E8%AF%B4%EF%BC%9A%7Bmsg%7D')%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%EF%BC%9Aspeak%E6%96%B9%E6%B3%95%E6%98%AF%E5%AD%98%E5%9C%A8Person%E7%B1%BB%E8%BA%AB%E4%B8%8A%E7%9A%84%5Cn%23%20print(Person.__dict__)%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAPerson%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnp2%20%3D%20Person('%E6%9D%8E%E5%9B%9B'%2C%2022%2C%20'%E5%A5%B3')%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%EF%BC%9APerson%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%E8%BA%AB%E4%B8%8A%E6%98%AF%E6%B2%A1%E6%9C%89speak%E6%96%B9%E6%B3%95%E7%9A%84%5Cn%23%20print(p1.__dict__)%5Cn%23%20print(p2.__dict__)%5Cn%5Cn%23%20%E6%89%80%E6%9C%89Person%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%EF%BC%8C%E9%83%BD%E5%8F%AF%E4%BB%A5%E8%B0%83%E7%94%A8%E5%88%B0speak%E6%96%B9%E6%B3%95%5Cn%23%20%E5%BD%93%E6%89%A7%E8%A1%8Cp1.speak()%E7%9A%84%E6%97%B6%E5%80%99%EF%BC%8C%E6%9F%A5%E6%89%BEspeak%E6%96%B9%E6%B3%95%E7%9A%84%E8%BF%87%E7%A8%8B%EF%BC%9A1.%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%E8%87%AA%E8%BA%AB(p1)%20%20%3D%3E%20%202.%E5%AE%9E%E4%BE%8B%E7%9A%84%E2%80%9C%E7%BC%94%E9%80%A0%E8%80%85%E2%80%9D%E7%9A%84%E8%BA%AB%E4%B8%8A(Person)%5Cn%23%20p1.speak('%E5%A5%BD%E5%A5%BD%E5%AD%A6%E4%B9%A0')%5Cn%23%20p2.speak('%E5%A4%A9%E5%A4%A9%E5%90%91%E4%B8%8A')%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%E4%B8%8A%E8%BF%B0%E7%9A%84%E6%9F%A5%E6%89%BE%E8%BF%87%E7%A8%8B%5Cndef%20speak()%3A%5Cn%20%20%20%20print('%E5%B7%B4%E6%8B%89%E5%B7%B4%E6%8B%89%E5%B7%B4%E6%8B%89%E5%B7%B4%E6%8B%89%E5%B7%B4%E6%8B%89')%5Cnp1.speak%20%3D%20speak%5Cnprint(Person.__dict__)%5Cnprint(p1.__dict__)%5Cnprint(p2.__dict__)%5Cnp1.speak()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22hwA9M%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="K83UB" id="K83UB" data-lake-index-type="2"><span data-lake-id="u76488c78" id="u76488c78">实例属性、类属性</span></h2><h3 data-lake-id="F3gpI" id="F3gpI" data-lake-index-type="2"><span data-lake-id="u2cb8f8c2" id="u2cb8f8c2">实例属性</span></h3><p data-lake-id="u71d7a91a" id="u71d7a91a"><strong><span data-lake-id="u12d80d32" id="u12d80d32">1️⃣</span></strong><strong><span data-lake-id="u7f9ed42b" id="u7f9ed42b">定义：</span></strong><span data-lake-id="u6e1867b6" id="u6e1867b6">通过</span><code data-lake-id="u9d8bc287" id="u9d8bc287"><strong><span data-lake-id="u0a900ed7" id="u0a900ed7">实例.属性名 = 值</span></strong></code><span data-lake-id="u21f008b8" id="u21f008b8">定义在实例身上的属性，称为：实例属性。</span></p><p data-lake-id="ufe526f75" id="ufe526f75"><strong><span data-lake-id="udbe18387" id="udbe18387">2️⃣</span></strong><strong><span data-lake-id="u4dcae409" id="u4dcae409">特点：</span></strong></p><blockquote data-lake-id="u1f401b45" id="u1f401b45" class="lake-alert lake-alert-info"><ol list="u76e34d3a"><li fid="u05f24684" data-lake-id="ufbbd0984" id="ufbbd0984"><span data-lake-id="ue6df4291" id="ue6df4291">每个实例都有自己『独立的一份』实例属性，各个实例之间是互不影响的。  </span></li><li fid="u05f24684" data-lake-id="u3edef148" id="u3edef148"><span data-lake-id="u952b8a07" id="u952b8a07">实例属性只能通过</span><code data-lake-id="ub4250f4e" id="ub4250f4e"><strong><span data-lake-id="u50d81443" id="u50d81443">实例.xxxx</span></strong></code><span data-lake-id="ufd78c2ea" id="ufd78c2ea">访问和修改，不能通过『类名』访问或修改。</span></li></ol></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20%23%20%E5%88%9D%E5%A7%8B%E5%8C%96%E6%96%B9%E6%B3%95%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20%23%20%E9%80%9A%E8%BF%87%E3%80%90%E5%AE%9E%E4%BE%8B.%E5%B1%9E%E6%80%A7%E5%90%8D%20%3D%20%E5%80%BC%E3%80%91%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E7%9A%84%E5%B1%9E%E6%80%A7%EF%BC%8C%E5%B0%B1%E5%8F%AB%E5%AE%9E%E4%BE%8B%E5%B1%9E%E6%80%A7%5Cn%20%20%20%20%20%20%20%20%23%20%E5%AE%9E%E4%BE%8B%E5%B1%9E%E6%80%A7%E5%8F%AA%E8%83%BD%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E8%AE%BF%E9%97%AE%EF%BC%8C%E4%B8%8D%E8%83%BD%E9%80%9A%E8%BF%87%E7%B1%BB%E8%AE%BF%E9%97%AE%5Cn%20%20%20%20%20%20%20%20%23%20%E6%AF%8F%E4%B8%AA%E5%AE%9E%E4%BE%8B%E9%83%BD%E6%9C%89%E8%87%AA%E5%B7%B1%E3%80%90%E7%8B%AC%E4%B8%80%E4%BB%BD%E7%9A%84%E3%80%91%E5%AE%9E%E4%BE%8B%E5%B1%9E%E6%80%A7%EF%BC%8C%E5%90%84%E4%B8%AA%E5%AE%9E%E4%BE%8B%E4%B9%8B%E9%97%B4%E6%98%AF%E4%BA%92%E4%B8%8D%E5%B9%B2%E6%89%B0%E7%9A%84%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAPerson%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnp2%20%3D%20Person('%E6%9D%8E%E5%9B%9B'%2C%2022%2C%20'%E5%A5%B3')%5Cn%5Cn%23%20%E5%AE%9E%E4%BE%8B%E5%B1%9E%E6%80%A7%E5%8F%AA%E8%83%BD%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E8%AE%BF%E9%97%AE%EF%BC%8C%E4%B8%8D%E8%83%BD%E9%80%9A%E8%BF%87%E7%B1%BB%E8%AE%BF%E9%97%AE%5Cnprint(p1.name)%5Cnprint(Person.name)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22B7l63%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><h3 data-lake-id="Txv5F" id="Txv5F" data-lake-index-type="2"><strong><span data-lake-id="uf3efb52d" id="uf3efb52d">类属性</span></strong></h3><p data-lake-id="ud10878b5" id="ud10878b5"><strong><span data-lake-id="ua6038b5f" id="ua6038b5f">1️⃣</span></strong><strong><span data-lake-id="u0a9e6243" id="u0a9e6243">定义：</span></strong><span data-lake-id="u4717a01f" id="u4717a01f"> 在类中直接写赋值语句（例如：</span><code data-lake-id="ufcc3f8ff" id="ufcc3f8ff"><span data-lake-id="u4b94f3be" id="u4b94f3be">a = 100</span></code><span data-lake-id="uf9f6b6ae" id="uf9f6b6ae">），就会在类身上添加一个</span><code data-lake-id="u64510e23" id="u64510e23"><span data-lake-id="u9b22ba40" id="u9b22ba40">a</span></code><span data-lake-id="ubd211b65" id="ubd211b65">属性，值为 </span><code data-lake-id="ud42835b4" id="ud42835b4"><span data-lake-id="ucd35057a" id="ucd35057a">100</span></code><span data-lake-id="ub79e5aff" id="ub79e5aff">，此时的</span><code data-lake-id="u5f4e7cca" id="u5f4e7cca"><span data-lake-id="ub12a8aa5" id="ub12a8aa5">a</span></code><span data-lake-id="u6d565ecf" id="u6d565ecf">就是『类属性』，它属于类本身，由类所拥有，并且该类创建出来的</span><strong><span data-lake-id="u21eab7f9" id="u21eab7f9" style="color: #AD1A2B">所有实例对象</span></strong><span data-lake-id="u7704bfb6" id="u7704bfb6">，都能去访问</span><code data-lake-id="u15cfa735" id="u15cfa735"><span data-lake-id="u8cab1c13" id="u8cab1c13">a</span></code><span data-lake-id="ubab19dd2" id="ubab19dd2">属性。  </span></p><p data-lake-id="u57879d74" id="u57879d74"><strong><span data-lake-id="ucc939b99" id="ucc939b99">​</span></strong><strong><span data-lake-id="ub7ef4e2c" id="ub7ef4e2c">2️⃣</span></strong><strong><span data-lake-id="ub439796f" id="ub439796f">特点：</span></strong></p><blockquote data-lake-id="u73547ea7" id="u73547ea7" class="lake-alert lake-alert-info"><ol list="u68791cc6"><li fid="u3f9af792" data-lake-id="u72ce4196" id="u72ce4196"><span data-lake-id="u85439c67" id="u85439c67">所有实例访问的，都是同一个类属性，所以类属性通常用于：存放公共数据。</span></li><li fid="u3f9af792" data-lake-id="u917049c1" id="u917049c1"><span data-lake-id="u4fa4902f" id="u4fa4902f">类属性即可以通过『类』访问，也可以『实例』访问。</span></li></ol></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20%23%20max_age%E3%80%81planet%20%E4%BB%96%E4%BB%AC%E9%83%BD%E6%98%AF%E7%B1%BB%E5%B1%9E%E6%80%A7%EF%BC%8C%E7%B1%BB%E5%B1%9E%E6%80%A7%E6%98%AF%E4%BF%9D%E5%AD%98%E5%9C%A8%E7%B1%BB%E8%BA%AB%E4%B8%8A%E7%9A%84%5Cn%20%20%20%20%23%20%E7%B1%BB%E5%B1%9E%E6%80%A7%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%E7%B1%BB%E8%AE%BF%E9%97%AE%EF%BC%8C%E4%B9%9F%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E8%AE%BF%E9%97%AE%5Cn%20%20%20%20%23%20%E7%B1%BB%E5%B1%9E%E6%80%A7%E9%80%9A%E5%B8%B8%E7%94%A8%E4%BA%8E%E4%BF%9D%E5%AD%98%EF%BC%9A%E5%85%AC%E5%85%B1%E6%95%B0%E6%8D%AE%5Cn%20%20%20%20max_age%20%3D%20120%5Cn%20%20%20%20planet%20%3D%20'%E5%9C%B0%E7%90%83'%5Cn%5Cn%20%20%20%20%23%20%E5%88%9D%E5%A7%8B%E5%8C%96%E6%96%B9%E6%B3%95%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20%23%20%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E5%B1%9E%E6%80%A7%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%20%20%20%20%20%20%20%20%23%20%E9%99%90%E5%88%B6age%E7%9A%84%E6%9C%80%E5%A4%A7%E5%80%BC%5Cn%20%20%20%20%20%20%20%20if%20age%20%3C%3D%20Person.max_age%3A%5Cn%20%20%20%20%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20else%3A%5Cn%20%20%20%20%20%20%20%20%20%20%20%20print(f'%E5%B9%B4%E9%BE%84%E8%B6%85%E5%87%BA%E8%8C%83%E5%9B%B4%E4%BA%86%EF%BC%8C%E5%B7%B2%E7%BB%8F%E5%B0%86%E5%B9%B4%E9%BE%84%E8%AE%BE%E7%BD%AE%E4%B8%BA%E6%9C%80%E5%A4%A7%E5%80%BC%EF%BC%9A%7BPerson.max_age%7D')%5Cn%20%20%20%20%20%20%20%20%20%20%20%20self.age%20%3D%20Person.max_age%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%EF%BC%9A%E7%B1%BB%E5%B1%9E%E6%80%A7%E6%98%AF%E4%BF%9D%E5%AD%98%E5%9C%A8%E7%B1%BB%E8%BA%AB%E4%B8%8A%E7%9A%84%5Cn%23%20print(Person.__dict__)%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAPerson%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnp2%20%3D%20Person('%E6%9D%8E%E5%9B%9B'%2C%2022%2C%20'%E5%A5%B3')%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%EF%BC%9A%E5%AE%9E%E4%BE%8B%E8%BA%AB%E4%B8%8A%E6%98%AF%E6%B2%A1%E6%9C%89%E7%B1%BB%E5%B1%9E%E6%80%A7%E7%9A%84%5Cn%23%20print(p1.__dict__)%5Cn%23%20print(p2.__dict__)%5Cn%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%EF%BC%9A%E7%B1%BB%E5%B1%9E%E6%80%A7%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%E7%B1%BB%E8%AE%BF%E9%97%AE%EF%BC%8C%E4%B9%9F%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E8%AE%BF%E9%97%AE%5Cn%23%20print(Person.max_age)%5Cn%23%20print(p1.max_age)%20%20%23%20%E6%9F%A5%E6%89%BEmax_age%E7%9A%84%E8%BF%87%E7%A8%8B%EF%BC%9A1.%E5%AE%9E%E4%BE%8B%E8%87%AA%E8%BA%AB(p1)%20%20%3D%3E%202.%E5%AE%9E%E4%BE%8B%E7%9A%84%E2%80%9C%E7%BC%94%E9%80%A0%E8%80%85%E2%80%9D(Person)%5Cn%23%20print(p2.planet)%5Cn%5Cn%23%20%E6%B5%8B%E8%AF%95%E4%B8%80%E4%B8%8B%E5%B9%B4%E9%BE%84%E8%B6%85%E5%87%BA%E8%8C%83%E5%9B%B4%5Cn%23%20p3%20%3D%20Person('%E7%8E%8B%E4%BA%94'%2C%20170%2C%20'%E5%A5%B3')%5Cn%23%20print(p3.__dict__)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22btnfI%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><p data-lake-id="u76766bd9" id="u76766bd9"><strong><span data-lake-id="ue68873c2" id="ue68873c2">3️⃣</span></strong><strong><span data-lake-id="u1940b54e" id="u1940b54e">特别注意：</span></strong></p><blockquote data-lake-id="u3f747a2d" id="u3f747a2d" class="lake-alert lake-alert-color4"><p data-lake-id="uf4cdefa3" id="uf4cdefa3"><span data-lake-id="u6bf9e0dc" id="u6bf9e0dc">进行</span><code data-lake-id="u6ddba1b2" id="u6ddba1b2"><strong><span data-lake-id="u2a8b7329" id="u2a8b7329">实例.属性名 = xxx</span></strong></code><span data-lake-id="u6321589c" id="u6321589c">操作时，只会对</span><strong><span data-lake-id="ube40766f" id="ube40766f" style="color: #AD1A2B">实例自身</span></strong><span data-lake-id="u05045fc8" id="u05045fc8">的属性起作用（有则修改，无则添加）！</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E6%B3%A8%E6%84%8F%E7%82%B9%EF%BC%9A%E8%BF%9B%E8%A1%8C%E3%80%90%E5%AE%9E%E4%BE%8B.%E5%B1%9E%E6%80%A7%E5%90%8D%20%3D%20%E5%80%BC%E3%80%91%E6%93%8D%E4%BD%9C%E6%97%B6%EF%BC%8C%E5%8F%AA%E4%BC%9A%E5%AF%B9%E5%AE%9E%E4%BE%8B%E8%87%AA%E8%BA%AB%E7%9A%84%E5%B1%9E%E6%80%A7%E8%B5%B7%E4%BD%9C%E7%94%A8%EF%BC%8C%E4%B8%8D%E4%BC%9A%E5%BD%B1%E5%93%8D%E7%B1%BB%E5%B1%9E%E6%80%A7%5Cnp1.planet%20%3D%20'%E7%81%AB%E6%98%9F'%5Cnprint(Person.__dict__)%5Cnprint(p1.__dict__)%5Cnprint(p2.__dict__)%5Cnprint(p1.planet)%5Cnprint(p2.planet)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22y9gte%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><h2 data-lake-id="paNM5" id="paNM5" data-lake-index-type="2"><span data-lake-id="uef3d3f1e" id="uef3d3f1e">实例方法、类方法、静态方法</span></h2><h3 data-lake-id="foMdd" id="foMdd" data-lake-index-type="2"><span data-lake-id="u0ba05502" id="u0ba05502"> 实例方法  </span></h3><p data-lake-id="uc7b0770b" id="uc7b0770b" style="text-indent: 2em"><strong><span data-lake-id="ubec38d4b" id="ubec38d4b">定义：</span></strong><span data-lake-id="ud6c26d98" id="ud6c26d98">类中所定义的方法，最终会保存在类身上，并且主要是通过</span><strong><span data-lake-id="u88d514de" id="u88d514de" style="color: #AD1A2B">实例调用</span></strong><span data-lake-id="uec8fa76f" id="uec8fa76f">，所以叫：实例方法。</span></p><p data-lake-id="u534088d1" id="u534088d1" style="text-indent: 2em"><strong><span data-lake-id="uc44713b9" id="uc44713b9">特点：</span></strong></p><blockquote data-lake-id="u2ba14fee" id="u2ba14fee" hindent="2em" class="lake-alert lake-alert-info"><ol list="ue4b5314b"><li fid="ub480c30f" data-lake-id="u6a6b482a" id="u6a6b482a"><span data-lake-id="u43f63d8e" id="u43f63d8e">实例方法虽然最终会</span><strong><span data-lake-id="uc658cf6e" id="uc658cf6e" style="color: #AD1A2B">保存在类身上</span></strong><span data-lake-id="u7f99e263" id="u7f99e263">，但它主要是</span><strong><span data-lake-id="u7e98a3c4" id="u7e98a3c4" style="color: #AD1A2B">供实例使用</span></strong><span data-lake-id="uded577b3" id="uded577b3">的，所以才叫实例方法。</span></li><li fid="ub480c30f" data-lake-id="u89fa633f" id="u89fa633f"><span data-lake-id="ude1fe549" id="ude1fe549">因为收到了</span><code data-lake-id="u2836d6c3" id="u2836d6c3"><span data-lake-id="u84d1f467" id="u84d1f467">self</span></code><span data-lake-id="u9a29fc0f" id="u9a29fc0f">参数，所以其内部可以：访问实例属性，调用实例方法。</span></li><li fid="ub480c30f" data-lake-id="ua0b29856" id="ua0b29856"><span data-lake-id="u46533f7e" id="u46533f7e">实例方法的主要作用：定义</span><strong><span data-lake-id="ua18a1e61" id="ua18a1e61">实例对象</span></strong><span data-lake-id="u47f87d64" id="u47f87d64">的</span><strong><span data-lake-id="u1ca50544" id="u1ca50544" style="color: #AD1A2B">具体行为</span></strong><span data-lake-id="ua0c58d19" id="ua0c58d19">。</span></li></ol></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20%23%20%E5%88%9D%E5%A7%8B%E5%8C%96%E6%96%B9%E6%B3%95%EF%BC%88%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E5%B1%9E%E6%80%A7%EF%BC%89%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%20%20%20%20%23%20%E4%B8%8B%E9%9D%A2%E7%9A%84speak%E6%96%B9%E6%B3%95%E3%80%81run%E6%96%B9%E6%B3%95%EF%BC%8C%E9%83%BD%E4%BF%9D%E5%AD%98%E5%9C%A8%E7%B1%BB%E8%BA%AB%E4%B8%8A%EF%BC%8C%E4%BD%86%E4%BB%96%E4%BB%AC%E4%B8%BB%E8%A6%81%E6%98%AF%E4%BE%9B%E5%AE%9E%E4%BE%8B%E8%B0%83%E7%94%A8%EF%BC%8C%E6%89%80%E4%BB%A5%E4%BB%96%E4%BB%AC%E9%83%BD%E5%8F%AB%EF%BC%9A%E5%AE%9E%E4%BE%8B%E6%96%B9%E6%B3%95%5Cn%20%20%20%20%23%20%E8%87%AA%E5%AE%9A%E4%B9%89%E6%96%B9%E6%B3%95%EF%BC%88%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E8%A1%8C%E4%B8%BA%EF%BC%89%5Cn%20%20%20%20def%20speak(self%2C%20msg)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%8F%AB%7Bself.name%7D%EF%BC%8C%20%E5%B9%B4%E9%BE%84%E6%98%AF%7Bself.age%7D%EF%BC%8C%20%E6%80%A7%E5%88%AB%E6%98%AF%7Bself.gender%7D%EF%BC%8C%E6%88%91%E6%83%B3%E8%AF%B4%EF%BC%9A%7Bmsg%7D')%5Cn%5Cn%20%20%20%20%23%20%E8%87%AA%E5%AE%9A%E4%B9%89%E6%96%B9%E6%B3%95%EF%BC%88%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E8%A1%8C%E4%B8%BA%EF%BC%89%5Cn%20%20%20%20def%20run(self%2C%20distance)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%7Bself.name%7D%E7%96%AF%E7%8B%82%E7%9A%84%E5%A5%94%E8%B7%91%E4%BA%86%7Bdistance%7D%E7%B1%B3')%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAPerson%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnp2%20%3D%20Person('%E6%9D%8E%E5%9B%9B'%2C%2022%2C%20'%E5%A5%B3')%5Cn%5Cnprint(Person.__dict__)%5Cnprint(p1.__dict__)%5Cnprint(p2.__dict__)%5Cn%5Cn%23%20%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E8%B0%83%E7%94%A8%E5%AE%9E%E4%BE%8B%E6%96%B9%E6%B3%95%5Cnp1.speak('%E4%BD%A0%E5%A5%BD')%5Cnp1.run(300)%5Cn%5Cn%23%20%E9%80%9A%E8%BF%87%E7%B1%BB%E5%8E%BB%E8%B0%83%E7%94%A8%E5%AE%9E%E4%BE%8B%E6%96%B9%E6%B3%95(%E8%83%BD%E8%B0%83%E7%94%A8%EF%BC%8C%E4%BD%86%E4%B8%8D%E6%8E%A8%E8%8D%90)%5CnPerson.run(p2%2C%20100)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22d7BcD%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h3 data-lake-id="BsCkw" id="BsCkw" data-lake-index-type="2"><span data-lake-id="u4829048d" id="u4829048d">类方法</span></h3><p data-lake-id="ue8ff6c65" id="ue8ff6c65" style="text-indent: 2em"><strong><span data-lake-id="ub8d8d9fe" id="ub8d8d9fe">定义：</span></strong><span data-lake-id="u45198357" id="u45198357">使用</span><code data-lake-id="u8bdc3107" id="u8bdc3107"><span data-lake-id="ub621a138" id="ub621a138">@classmethod</span></code><span data-lake-id="u66f520c4" id="u66f520c4">装饰器修饰，第一个参数是</span><strong><span data-lake-id="ubbea971c" id="ubbea971c" style="color: #AD1A2B">类本身</span></strong><span data-lake-id="u80166528" id="u80166528">，通常用形参</span><code data-lake-id="u3d81c6a4" id="u3d81c6a4"><span data-lake-id="ub9117172" id="ub9117172">cls</span></code><span data-lake-id="u4fdd1ded" id="u4fdd1ded">接收。</span></p><p data-lake-id="u4ab14ffc" id="u4ab14ffc" style="text-indent: 2em"><strong><span data-lake-id="u10e6cef5" id="u10e6cef5">特点：</span></strong></p><blockquote data-lake-id="u25a43f88" id="u25a43f88" hindent="2em" class="lake-alert lake-alert-info"><ol list="u7ca58c60"><li fid="u8399a20e" data-lake-id="ube4d8594" id="ube4d8594"><span data-lake-id="u2e9a63b1" id="u2e9a63b1">可通过『类名』或『实例名』调用，但</span><strong><span data-lake-id="u249c1749" id="u249c1749">强烈推荐</span></strong><strong><span data-lake-id="u339c615f" id="u339c615f" style="color: #AD1A2B">通过类名调用</span></strong><span data-lake-id="u5d798c0d" id="u5d798c0d">以体现语义。</span></li><li fid="u8399a20e" data-lake-id="u58ef7d15" id="u58ef7d15"><span data-lake-id="ua75abf9f" id="ua75abf9f">因为收到了</span><code data-lake-id="u7647dcff" id="u7647dcff"><span data-lake-id="uaf74e320" id="uaf74e320">cls</span></code><span data-lake-id="u53b56406" id="u53b56406">参数，所以内部可以访问类属性。</span></li><li fid="u8399a20e" data-lake-id="u10eb0d58" id="u10eb0d58"><span data-lake-id="u8d3a26dd" id="u8d3a26dd"> 一般用于：实现</span><strong><span data-lake-id="u84fb69e9" id="u84fb69e9" style="color: #AD1A2B">与类相关的逻辑</span></strong><span data-lake-id="udb139eb9" id="udb139eb9">，如：操作类级别的信息、工厂方法等。</span></li></ol></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22from%20datetime%20import%20datetime%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20%23%20%E7%B1%BB%E5%B1%9E%E6%80%A7%5Cn%20%20%20%20max_age%20%3D%20120%5Cn%20%20%20%20planet%20%3D%20'%E5%9C%B0%E7%90%83'%5Cn%5Cn%20%20%20%20%23%20%E5%88%9D%E5%A7%8B%E5%8C%96%E6%96%B9%E6%B3%95%EF%BC%88%E7%BB%99%E5%AE%9E%E4%BE%8B%E6%B7%BB%E5%8A%A0%E5%B1%9E%E6%80%A7%EF%BC%89%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%20%20%20%20%23%20speak%E6%96%B9%E6%B3%95%E3%80%81run%E6%96%B9%E6%B3%95%EF%BC%8C%E4%BB%96%E4%BB%AC%E9%83%BD%E5%B1%9E%E4%BA%8E%EF%BC%9A%E5%AE%9E%E4%BE%8B%E6%96%B9%E6%B3%95%5Cn%20%20%20%20def%20speak(self%2C%20msg)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%8F%AB%7Bself.name%7D%EF%BC%8C%20%E5%B9%B4%E9%BE%84%E6%98%AF%7Bself.age%7D%EF%BC%8C%20%E6%80%A7%E5%88%AB%E6%98%AF%7Bself.gender%7D%EF%BC%8C%E6%88%91%E6%83%B3%E8%AF%B4%EF%BC%9A%7Bmsg%7D')%5Cn%5Cn%20%20%20%20def%20run(self%2C%20distance)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%7Bself.name%7D%E7%96%AF%E7%8B%82%E7%9A%84%E5%A5%94%E8%B7%91%E4%BA%86%7Bdistance%7D%E7%B1%B3')%5Cn%5Cn%20%20%20%20%23%20%E4%BD%BF%E7%94%A8%20%40classmethod%20%E8%A3%85%E9%A5%B0%E8%BF%87%E7%9A%84%E6%96%B9%E6%B3%95%EF%BC%8C%E5%B0%B1%E5%8F%AB%EF%BC%9A%E7%B1%BB%E6%96%B9%E6%B3%95%EF%BC%8C%E7%B1%BB%E6%96%B9%E6%B3%95%E4%BF%9D%E5%AD%98%E5%9C%A8%E7%B1%BB%E8%BA%AB%E4%B8%8A%E7%9A%84%5Cn%20%20%20%20%23%20%E7%B1%BB%E6%96%B9%E6%B3%95%E6%94%B6%E5%88%B0%E7%9A%84%E5%8F%82%E6%95%B0%EF%BC%9A%E5%BD%93%E5%89%8D%E7%B1%BB%E6%9C%AC%E8%BA%AB%EF%BC%88cls%EF%BC%89%E3%80%81%E8%87%AA%E5%AE%9A%E4%B9%89%E7%9A%84%E5%8F%82%E6%95%B0%5Cn%20%20%20%20%23%20%E5%9B%A0%E4%B8%BA%E6%94%B6%E5%88%B0%E4%BA%86cls%E5%8F%82%E6%95%B0%EF%BC%8C%E6%89%80%E4%BB%A5%E7%B1%BB%E6%96%B9%E6%B3%95%E4%B8%AD%E6%98%AF%E5%8F%AF%E4%BB%A5%E8%AE%BF%E9%97%AE%E7%B1%BB%E5%B1%9E%E6%80%A7%E7%9A%84%5Cn%20%20%20%20%23%20%E7%B1%BB%E6%96%B9%E6%B3%95%E9%80%9A%E5%B8%B8%E7%94%A8%E4%BA%8E%E5%AE%9E%E7%8E%B0%EF%BC%9A%E4%B8%8E%E7%B1%BB%E7%9B%B8%E5%85%B3%E7%9A%84%E9%80%BB%E8%BE%91%EF%BC%8C%E4%BE%8B%E5%A6%82%EF%BC%9A%E6%93%8D%E4%BD%9C%E7%B1%BB%E7%BA%A7%E5%88%AB%E7