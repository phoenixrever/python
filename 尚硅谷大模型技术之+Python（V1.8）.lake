uote data-lake-id="u25ccdb05" id="u25ccdb05" class="lake-alert lake-alert-info"><ol list="u2e5d76c9"><li fid="u13a0c753" data-lake-id="ua895fd83" id="ua895fd83" style="text-align: justify"><span data-lake-id="u62caed18" id="u62caed18">一个</span><code data-lake-id="u8d63fb6e" id="u8d63fb6e"><span data-lake-id="ud581789a" id="ud581789a">if</span></code><span data-lake-id="u7d33e681" id="u7d33e681">语句只能匹配</span><code data-lake-id="u55dec0cf" id="u55dec0cf"><span data-lake-id="u06fee56c" id="u06fee56c">1</span></code><span data-lake-id="u28ac6b34" id="u28ac6b34">个</span><code data-lake-id="u8b66fa96" id="u8b66fa96"><span data-lake-id="u7d706336" id="u7d706336">else</span></code><span data-lake-id="ue17c705f" id="ue17c705f">语句，但可以匹配多个</span><code data-lake-id="u7c7b66b4" id="u7c7b66b4"><span data-lake-id="ubf6ef924" id="ubf6ef924">elif</span></code><span data-lake-id="uef3cde7e" id="uef3cde7e">语句，并且</span><code data-lake-id="ufa82e8ae" id="ufa82e8ae"><span data-lake-id="uc1bb32d7" id="uc1bb32d7">else</span></code><span data-lake-id="u40162c2e" id="u40162c2e">语句要在所有的</span><code data-lake-id="u1101109b" id="u1101109b"><span data-lake-id="u510551b3" id="u510551b3">elif</span></code><span data-lake-id="u234bf135" id="u234bf135">语句之后。</span></li><li fid="u13a0c753" data-lake-id="u25b60279" id="u25b60279" style="text-align: justify"><span data-lake-id="u6d33f0b8" id="u6d33f0b8">一旦某个分支语句检测为</span><code data-lake-id="u5e0f19f6" id="u5e0f19f6"><span data-lake-id="u77a41a98" id="u77a41a98">true</span></code><span data-lake-id="u5056fd2c" id="u5056fd2c">，其他的</span><code data-lake-id="uc221cf51" id="uc221cf51"><span data-lake-id="u19e9a6f5" id="u19e9a6f5">elif</span></code><span data-lake-id="u657a6722" id="u657a6722">以及</span><code data-lake-id="u3c50c92b" id="u3c50c92b"><span data-lake-id="u6361f47b" id="u6361f47b">else</span></code><span data-lake-id="uc64ac234" id="uc64ac234">语句都将不再执行。</span></li></ol></blockquote><h3 data-lake-id="kCxIv" id="kCxIv" data-lake-index-type="2"><spa