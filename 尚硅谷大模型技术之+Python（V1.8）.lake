7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%23696763%22%2C%22id%22%3A%22ubd5740ac%22%7D"></card></p><p data-lake-id="uaf812697" id="uaf812697"><span data-lake-id="u827ce500" id="u827ce500">1️⃣</span><span data-lake-id="u03a0a72a" id="u03a0a72a">使用：</span><code data-lake-id="ufbbfcbca" id="ufbbfcbca"><span data-lake-id="ufcaa156a" id="ufcaa156a">列表.index(值)</span></code><span data-lake-id="u44a362ce" id="u44a362ce">，查找指定元素在列表中第一次出现的下标，返回值是元素下标。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22fruits%20%3D%20%5B'%E9%A6%99%E8%95%89'%2C%20'%E8%8B%B9%E6%9E%9C'%2C%20'%E6%A9%99%E5%AD%90'%2C%20'%E9%A6%99%E8%95%89'%5D%5Cnresult%20%3D%20fruits.index('%E9%A6%99%E8%95%89')%5Cnprint(result)%20%20%23%200%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22aApjF%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><p data-lake-id="u3f944413" id="u3f944413"><span data-lake-id="u4403779e" id="u4403779e">2️⃣</span><span data-lake-id="u192ba792" id="u192ba792">使用：</span><code data-lake-id="u504c66cc" id="u504c66cc"><span data-lake-id="uda577099" id="uda577099">列表.count(值)</span></code><span data-lake-id="udd439532" id="udd439532">，统计某个元素在列表中出现的次数，返回值是：元素出现的次数。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22nums%20%3D%20%5B10%2C%2020%2C%2010%2C%2030%2C%2010%2C%2040%2C%20%5B10%2C%2010%2C%2010%5D%5D%5Cnresult%20%3D%20nums.count(10)%5Cnprint(result)%20%20%23%203%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22HHWYZ%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><p data-lake-id="u86db3feb" id="u86db3feb"><span data-lake-id="u04056995" id="u04056995">3️⃣</span><span data-lake-id="uec33400d" id="uec33400d">使用：</span><code data-lake-id="u38d8e239" id="u38d8e239"><span data-lake-id="ube6078eb" id="ube6078eb">列表.reverse()</span></code><span data-lake-id="ub47f32e7" id="ub47f32e7">，反转列表（会改变原列表），无需参数，无返回值。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22nums%20%3D%20%5B23%2C%2011%2C%2032%2C%2030%2C%2017%2C%20%5B6%2C%207%2C%208%2C%209%5D%5D%5Cnnums.reverse()%5Cnprint(nums)%20%20%23%20%5B%5B6%2C%207%2C%208%2C%209%5D%2C%2017%2C%2030%2C%2032%2C%2011%2C%2023%5D%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22wM9GU%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><p data-lake-id="ua1f4a5f6" id="ua1f4a5f6"><span data-lake-id="u30a4c510" id="u30a4c510">4️⃣</span><span data-lake-id="ude3eaaa0" id="ude3eaaa0">使用：</span><code data-lake-id="u4912cabc" id="u4912cabc"><span data-lake-id="u8ea1736c" id="u8ea1736c">列表.sort(reverse=布尔值)</span></code><span data-lake-id="u4eec5d86" id="u4eec5d86">，对列表排序（从小到大，会改变原列表），</span><code data-lake-id="uc9989f17" id="uc9989f17"><span data-lake-id="u2ea29fc1" id="u2ea29fc1">reverse</span></code><span data-lake-id="u784b3545" id="u784b3545"> 用于控制排序方式，无返回值。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%204.%E4%BD%BF%E7%94%A8%20sort%20%E6%96%B9%E6%B3%95%EF%BC%8C%E5%AF%B9%E5%88%97%E8%A1%A8%E6%8E%92%E5%BA%8F%EF%BC%88%E9%BB%98%E8%AE%A4%E4%BB%8E%E5%B0%8F%E5%88%B0%E5%A4%A7%EF%BC%89%EF%BC%8C%E8%8B%A5%E6%83%B3%E4%BB%8E%E5%A4%A7%E5%88%B0%E5%B0%8F%EF%BC%8C%E5%8F%AF%E4%BB%A5%E5%B0%86%20reverse%20%E5%8F%82%E6%95%B0%E8%AE%BE%E4%B8%BATrue%E3%80%82%5Cn%23%204.1%20%E8%8B%A5%E5%88%97%E8%A1%A8%E4%B8%AD%E7%9A%84%E5%85%83%E7%B4%A0%EF%BC%9A%E9%83%BD%E6%98%AF%E6%95%B0%E5%AD%97%EF%BC%8C%E5%88%99%E6%8C%89%E7%85%A7%E6%95%B0%E5%AD%97%E7%9A%84%E5%A4%A7%E5%B0%8F%E9%A1%BA%E5%BA%8F%E8%BF%9B%E8%A1%8C%E6%8E%92%E5%BA%8F%E3%80%82%5Cnnums%20%3D%20%5B23%2C%2011%2C%2032%2C%2030%2C%2017%5D%5Cnnums.sort(reverse%3DTrue)%5Cnprint(nums)%20%20%23%20%5B32%2C%2030%2C%2023%2C%2017%2C%2011%5D%5Cn%5Cn%23%204.2%20%E8%8B%A5%E5%88%97%E8%A1%A8%E4%B8%AD%E7%9A%84%E5%85%83%E7%B4%A0%EF%BC%9A%E6%97%A2%E6%9C%89%E6%95%B0%E5%AD%97%EF%BC%8C%E5%8F%88%E6%9C%89%E5%AD%97%E7%AC%A6%E4%B8%B2%EF%BC%8C%E9%82%A3%E5%B0%B1%E4%BC%9A%E6%8A%A5%E9%94%99%E3%80%82%5Cnnums%20%3D%20%5B23%2C%2011%2C%2032%2C%2030%2C%2017%2C%20'%E5%B0%9A%E7%A1%85%E8%B0%B7'%5D%5Cnnums.sort()%5Cnprint(nums)%20%23%20%5B23%2C%2011%2C%2032%2C%2030%2C%2017%2C%20'%E5%B0%9A%E7%A1%85%E8%B0%B7'%5D%5Cn%5Cn%23%204.3%20%E8%8B%A5%E5%88%97%E8%A1%A8%E4%B8%AD%E7%9A%84%E5%85%83%E7%B4%A0%EF%BC%9A%E9%83%BD%E6%98%AF%E5%AD%97%E7%AC%A6%E4%B8%B2%EF%BC%8C%E5%88%99%E6%8C%89%E7%85%A7%E5%AD%97%E7%AC%A6%E4%B8%B2%E7%9A%84%20Unicode%20%E7%BC%96%E7%A0%81%E5%A4%A7%E5%B0%8F%E8%BF%9B%E8%A1%8C%E