2C%22style%22%3A%22none%22%2C%22ocrLocations%22%3A%5B%7B%22text%22%3A%22%E5%AD%97%E7%AC%A6%E4%B8%B2STRING%3AHELLO%22%2C%22x%22%3A19%2C%22y%22%3A15%2C%22width%22%3A399%2C%22height%22%3A41%7D%2C%7B%22text%22%3A%22%E6%B5%AE%E7%82%B9%E5%9E%8BFLOAT%3A%22%2C%22x%22%3A38%2C%22y%22%3A162%2C%22width%22%3A246%2C%22height%22%3A40%7D%2C%7B%22text%22%3A%2212000%22%2C%22x%22%3A583%2C%22y%22%3A87%2C%22width%22%3A151%2C%22height%22%3A41%7D%2C%7B%22text%22%3A%22%E5%B0%9A%E7%A1%85%E8%B0%B7%22%2C%22x%22%3A476%2C%22y%22%3A16%2C%22width%22%3A133%2C%22height%22%3A45%7D%2C%7B%22text%22%3A%22%E6%95%B4%E5%9E%8BINT%3A%22%2C%22x%22%3A107%2C%22y%22%3A86%2C%22width%22%3A170%2C%22height%22%3A38%7D%2C%7B%22text%22%3A%221.8E3%22%2C%22x%22%3A428%2C%22y%22%3A166%2C%22width%22%3A119%2C%22height%22%3A42%7D%2C%7B%22text%22%3A%2270.56%22%2C%22x%22%3A749%2C%22y%22%3A165%2C%22width%22%3A116%2C%22height%22%3A42%7D%2C%7B%22text%22%3A%2225.2%22%2C%22x%22%3A600%2C%22y%22%3A165%2C%22width%22%3A105%2C%22height%22%3A43%7D%2C%7B%22text%22%3A%22256%22%2C%22x%22%3A441%2C%22y%22%3A88%2C%22width%22%3A123%2C%22height%22%3A42%7D%2C%7B%22text%22%3A%2252.1%22%2C%22x%22%3A820%2C%22y%22%3A17%2C%22width%22%3A118%2C%22height%22%3A42%7D%2C%7B%22text%22%3A%2214.5%22%2C%22x%22%3A304%2C%22y%22%3A167%2C%22width%22%3A94%2C%22height%22%3A39%7D%2C%7B%22text%22%3A%22200%22%2C%22x%22%3A787%2C%22y%22%3A88%2C%22width%22%3A83%2C%22height%22%3A39%7D%2C%7B%22text%22%3A%22%5C%22100%22%2C%22x%22%3A666%2C%22y%22%3A17%2C%22width%22%3A100%2C%22height%22%3A39%7D%2C%7B%22text%22%3A%22108%22%2C%22x%22%3A315%2C%22y%22%3A93%2C%22width%22%3A73%2C%22height%22%3A36%7D%2C%7B%22text%22%3A%22OOOOO%22%2C%22x%22%3A903%2C%22y%22%3A99%2C%22width%22%3A74%2C%22height%22%3A19%7D%2C%7B%22text%22%3A%22OOOOOO%22%2C%22x%22%3A901%2C%22y%22%3A181%2C%22width%22%3A71%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22O%22%2C%22x%22%3A980%2C%22y%22%3A31%2C%22width%22%3A77%2C%22height%22%3A20%7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%23474747%22%2C%22id%22%3A%22BBapC%22%7D"></card></p><p data-lake-id="u87ca3d4d" id="u87ca3d4d"><span data-lake-id="u1fca6e57" id="u1fca6e57">但布尔类型的具体值，只有两个，分别是：</span><code data-lake-id="u31994a61" id="u31994a61"><span data-lake-id="u1cc753d2" id="u1cc753d2">True</span></code><span data-lake-id="ud8f0c399" id="ud8f0c399">和</span><code data-lake-id="u6acf5ea0" id="u6acf5ea0"><span data-lake-id="u50e83f4d" id="u50e83f4d">False</span></code><span data-lake-id="u6d6456c7" id="u6d6456c7">，其中：</span><code data-lake-id="u3dc6bb3e" id="u3dc6bb3e"><span data-lake-id="ue456aa4e" id="ue456aa4e">True</span></code><span data-lake-id="ue9707f3f" id="ue9707f3f">表示真，</span><code data-lake-id="u0e4ecea5" id="u0e4ecea5"><span data-lake-id="ubc3ab6fc" id="ubc3ab6fc">False</span></code><span data-lake-id="u448a3d3e" id="u448a3d3e">表示假。</span></p><p data-lake-id="u119e9d46" id="u119e9d46"><card type="inline" name="image" value="data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2025%2Fpng%2F35780599%2F1760689122751-f2e8c455-920c-464c-8e3e-aaed34394f22.png%22%2C%22taskId%22%3A%22u0f8b88fa-614c-4aa4-a2b8-5405d96a837%22%2C%22clientId%22%3A%22u9dc15b59-c913-4%22%2C%22originalType%22%3A%22binary%22%2C%22width%22%3A252.56668090820312%2C%22height%22%3A26%2C%22linkTarget%22%3A%22_blank%22%2C%22name%22%3A%22image.png%22%2C%22size%22%3A33773%2C%22from%22%3A%22paste%22%2C%22originWidth%22%3A623%2C%22originHeight%22%3A64%2C%22ratio%22%3A1.6500000953674316%2C%22status%22%3A%22done%22%2C%22style%22%3A%22none%22%2C%22ocrLocations%22%3A%5B%7B%22text%22%3A%22%E5%B8%83%E5%B0%94%E7%B1%BB%E5%9E%8BBOOLEAN%3A%22%2C%22x%22%3A6%2C%22y%22%3A11%2C%22width%22%3A333%2C%22height%22%3A37%7D%2C%7B%22text%22%3A%22FALSE%22%2C%22x%22%3A502%2C%22y%22%3A14%2C%22width%22%3A106%2C%22height%22%3A36%7D%2C%7B%22text%22%3A%22TRUE%22%2C%22x%22%3A365%2C%22y%22%3A13%2C%22width%22%3A98%2C%22height%22%3A35%7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%23605952%22%2C%22id%22%3A%22Hkl1t%22%7D"></card></p><p data-lake-id="u74d66c1b" id="u74d66c1b"><span data-lake-id="uf5f1d37e" id="uf5f1d37e">布尔值常用于表示：条件是否成立、事件是否发生、操作是否成功、等逻辑状态。</span></p><blockquote data-lake-id="u77bd707f" id="u77bd707f" class="lake-alert lake-alert-color4"><p data-lake-id="ub2fc6c43" id="ub2fc6c43"><span data-lake-id="udffd2ad8" id="udffd2ad8">📢</span><strong><span data-lake-id="u1b3ff333" id="u1b3ff333" style="color: #AD1A2B">注意：</span></strong><code data-lake-id="u60634b48" id="u60634b48"><span data-lake-id="u4da9a877" id="u4da9a877">True</span></code><span data-lake-id="u477e6a6a" id="u477e6a6a"> 和 </span><code data-lake-id="u5718bb2b" id="u5718bb2b"><span data-lake-id="ud5432b1d" id="ud5432b1d">False</span></code><span data-lake-id="uf879b20d" id="uf879b20d"> 的首字母必须大写。  </span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E5%B8%83%E5%B0%94%E5%80%BC%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E8%87%AA%E5%B7%B1%E5%AE%9A%E4%B9%89%E7%9A%84%E5%B8%83%E5%B0%94%E5%80%BC%5Cna%20%3D%20True%5Cnb%20%3D%20False%5Cn%5Cn%23%20%E9%9D%A0%E7%A8%8B%E5%BA%8F%E6%89%A7%E8%A1%8C%E5%BE%97%E5%88%B0%E7%9A%84%E5%B8%83%E5%B0%94%E5%80%BC%5Cnc%20%3D%205%20%3E%203%5Cnd%20%3D%207%20%3C%202%5Cn%5Cnprint(type(a)%2C%20a)%20%20%23%20True%5Cnprint(type(b)%2C%20b)%20%20%23%20Flase%5Cnprint(type(c)%2C%20c)%20%20%23%20True%5Cnprint(type(d)%2C%20d)%20%20%23%20Flase%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E5%B8%83%E5%B0%94%E5%80%BC%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22H1SLu%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="uabf5e662" id="uabf5e662"><span data-lake-id="u0ee6874f" id="u0ee6874f">布尔类型是</span><code data-lake-id="u4efa3020" id="u4efa3020"><span data-lake-id="u51bdb555" id="u51bdb555">int</span></code><span data-lake-id="ue2043b45" id="ue2043b45">类型的子类型，底层的本质是用</span><code data-lake-id="uec42bc5c" id="uec42bc5c"><span data-lake-id="u40b9f67e" id="u40b9f67e">1</span></code><span data-lake-id="u039a9f0e" id="u039a9f0e">表示</span><code data-lake-id="ua3f1a672" id="ua3f1a672"><span data-lake-id="ub50bf28d" id="ub50bf28d">True</span></code><span data-lake-id="u7a959c7f" id="u7a959c7f">，用</span><code data-lake-id="u8d7166b9" id="u8d7166b9"><span data-lake-id="u51f5ce44" id="u51f5ce44">0</span></code><span data-lake-id="u19e7de1b" id="u19e7de1b">表示</span><code data-lake-id="u47f04224" id="u47f04224"><span data-lake-id="u667d1580" id="u667d1580">False</span></code><span data-lake-id="uf2770d7f" id="uf2770d7f">。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%B8%83%E5%B0%94%E7%B1%BB%E5%9E%8B%E6%98%AFint%E7%B1%BB%E5%9E%8B%E7%9A%84%E5%AD%90%E7%B1%BB%E5%9E%8B%EF%BC%8C%E5%BA%95%E5%B1%82%E7%9A%84%E6%9C%AC%E8%B4%A8%E6%98%AF%E7%94%A81%E8%A1%A8%E7%A4%BATrue%EF%BC%8C%E7%94%A80%E8%A1%A8%E7%A4%BAFalse%5Cnprint(int(True))%20%20%20%23%201%5Cnprint(int(False))%20%20%23%200%5Cn%5Cnprint(4%20%2B%20True)%20%20%20%23%205%5Cnprint(8%20-%20False)%20%20%23%208%5Cn%5Cnprint(True%20%2B%20True)%20%20%20%23%202%5Cnprint(True%20-%20False)%20%20%23%201%5Cn%5Cnprint(7%20%3E%20True)%20%20%20%20%23%20True%5Cnprint(False%20%3C%3D%200)%20%20%23%20True%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Zt36r%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u0cfdb437" id="u0cfdb437"><span data-lake-id="u1f6515d1" id="u1f6515d1">Python中除</span><code data-lake-id="u97f14464" id="u97f14464"><span data-lake-id="u8ba40859" id="u8ba40859">0</span></code><span data-lake-id="u86802537" id="u86802537">以外的任何数，转为布尔值后都为 True</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E4%BD%BF%E7%94%A8bool()%E5%B0%86%E6%8C%87%E5%AE%9A%E5%86%85%E5%AE%B9%E8%BD%AC%E4%B8%BA%E5%B8%83%E5%B0%94%E7%B1%BB%E5%9E%8B%5Cnprint(bool(1))%20%20%23%20True%5Cnprint(bool(0))%20%20%23%20False%5Cn%5Cnprint(bool(300))%20%20%5Ct%23%20True%5Cnprint(bool(25.6))%20%20%5Ct%23%20True%5Cnprint(bool(1.8e3))%20%20%23%20True%5Cnprint(bool(12_000))%20%23%20True%5Cnprint(bool(-10))%20%20%5Ct%23%20True%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22WI1po%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u841c4a6a" id="u841c4a6a"><span data-lake-id="u7826262a" id="u7826262a">Python中除空字符串以外的任何字符串，转为布尔值都是 True</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(bool('hello'))%20%23%20True%5Cnprint(bool('0'))%5Ct%20%23%20True%5Cnprint(bool('18.5'))%5Ct%20%23%20True%5Cnprint(bool('-9'))%5Ct%20%23%20True%5Cnprint(bool(''))%5Ct%20%20%20%20%20%23%20False%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Ug55N%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="PDxa8" id="PDxa8" data-lake-index-type="2" style="text-align: justify"><strong><span data-lake-id="uf2a09710" id="uf2a09710" class="lake-fontsize-14">逻辑运算符</span></strong></h3><p data-lake-id="u7c0d6010" id="u7c0d6010"><span data-lake-id="uc1024cac" id="uc1024cac">常用的逻辑运算符如下：</span></p><p data-lake-id="u9ff01ebd" id="u9ff01ebd"><card type="inline" name="image" value="data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2025%2Fpng%2F35780599%2F1760842774737-97fad10e-bf66-4bc6-9918-513b0b2ba8ff.png%22%2C%22taskId%22%3A%22ufebbc29a-897a-4bc6-935b-f1c842c58de%22%2C%22clientId%22%3A%22uebac531c-c172-4%22%2C%22originalType%22%3A%22binary%22%2C%22width%22%3A386.77838134765625%2C%22height%22%3A135%2C%22linkTarget%22%3A%22_blank%22%2C%22name%22%3A%22image.png%22%2C%22size%22%3A335527%2C%22from%22%3A%22paste%22%2C%22originWidth%22%3A1570%2C%22originHeight%22%3A549%2C%22ratio%22%3A1.6500000953674316%2C%22status%22%3A%22done%22%2C%22style%22%3A%22none%22%2C%22ocrLocations%22%3A%5B%7B%22text%22%3A%22%E5%88%A4%E6%96%AD%E5%85%B6%E4%B8%A4%E4%BE%A7%E7%9A%84%E5%80%BC%2C%E6%98%AF%E5%90%A6%E8%87%B3%E5%B0%91%E6%9C%89%E4%B8%80%E4%B8%AA%E4%B8%BATRUE%22%2C%22x%22%3A528%2C%22y%22%3A301%2C%22width%22%3A1017%2C%22height%22%3A68%7D%2C%7B%22text%22%3A%22%E5%88%A4%E6%96%AD%E5%85%B6%E4%B8%A4%E4%BE%A7%E7%9A%84%E5%80%BC%2C%E6%98%AF%E5%90%A6%E9%83%BD%E4%B8%BATRUE%22%2C%22x%22%3A533%2C%22y%22%3A148%2C%22width%22%3A793%2C%22height%22%3A62%7D%2C%7B%22text%22%3A%22%E7%94%A8%E4%BA%8E%E5%AF%B9%E4%B8%80%E4%B8%AA%E5%80%BC%E5%8F%96%E5%8F%8D%22%2C%22x%22%3A538%2C%22y%22%3A442%2C%22width%22%3A448%2C%22height%22%3A62%7D%2C%7B%22text%22%3A%22%E5%8A%9F%E8%83%BD%E6%8F%8F%E8%BF%B0%22%2C%22x%22%3A888%2C%22y%22%3A11%2C%22width%22%3A224%2C%22height%22%3A59%7D%2C%7B%22text%22%3A%22%E9%80%BB%E8%BE%91%E6%88%96%22%2C%22x%22%3A310%2C%22y%22%3A303%2C%22width%22%3A178%2C%22height%22%3A61%7D%2C%7B%22text%22%3A%22%E9%80%BB%E8%BE%91%E4%B8%8E%22%2C%22x%22%3A308%2C%22y%22%3A148%2C%22width%22%3A176%2C%22height%22%3A62%7D%2C%7B%22text%22%3A%22%E8%BF%90%E7%AE%97%E7%AC%A6%22%2C%22x%22%3A50%2C%22y%22%3A15%2C%22width%22%3A176%2C%22height%22%3A61%7D%2C%7B%22text%22%3A%22%E7%BD%97%E8%BE%91%E9%9D%9E%22%2C%22x%22%3A313%2C%22y%22%3A446%2C%22width%22%3A173%2C%22height%22%3A62%7D%2C%7B%22text%22%3A%22AND%22%2C%22x%22%3A67%2C%22y%22%3A151%2C%22width%22%3A126%2C%22height%22%3A51%7D%2C%7B%22text%22%3A%22%E5%90%8D%E7%A7%B0%22%2C%22x%22%3A342%2C%22y%22%3A18%2C%22width%22%3A112%2C%22height%22%3A60%7D%2C%7B%22text%22%3A%22NOT%22%2C%22x%22%3A74%2C%22y%22%3A452%2C%22width%22%3A118%2C%22height%22%3A52%7D%2C%7B%22text%22%3A%22OR%22%2C%22x%22%3A94%2C%22y%22%3A307%2C%22width%22%3A77%2C%22height%22%3A48%7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%23515150%22%2C%22id%22%3A%22g9jyK%22%7D"></card></p><p data-lake-id="u23a982db" id="u23a982db"><span data-lake-id="uae00e819" id="uae00e819">1️⃣</span><strong><span data-lake-id="ud13af33f" id="ud13af33f">and 运算符：</span></strong><span data-lake-id="u992809cd" id="u992809cd">用于判断其两侧的值，是否都为</span><code data-lake-id="u557070f5" id="u557070f5"><span data-lake-id="u5eacd816" id="u5eacd816">True</span></code></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(True%20and%20True)%20%20%20%23%20True%5Cnprint(True%20and%20False)%20%20%23%20False%5Cnprint(False%20and%20True)%20%20%23%20False%5Cnprint(False%20and%20False)%20%23%20False%5Cn%5Cnprint(8%20%3E%207%20and%208%20%3E%207)%20%23%20True%5Cnprint(8%20%3E%207%20and%202%20%3E%203)%20%23%20False%5Cnprint(2%20%3E%203%20and%208%20%3E%207)%20%23%20False%5Cnprint(2%20%3E%203%20and%202%20%3E%203)%20%23%20False%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22ddXTX%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u9fd33ec2" id="u9fd33ec2"><code data-lake-id="ue561e178" id="ue561e178"><span data-lake-id="u104ae0f8" id="u104ae0f8">and</span></code><span data-lake-id="u873696d9" id="u873696d9">具备“逻辑短路”能力，以下代码中包含</span><code data-lake-id="u4330ef56" id="u4330ef56"><span data-lake-id="ucda15e3f" id="ucda15e3f">3/0</span></code><span data-lake-id="u9a4736ec" id="u9a4736ec">这种错误代码，但最终没有报错。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(False%20and%203%20%2F%200)%20%20%23%20False%5Cnprint(3%20%3E%209%20and%203%20%2F%200)%20%20%23%20False%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22kzt4x%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u6ea3573e" id="u6ea3573e"><code data-lake-id="u3cb9ca56" id="u3cb9ca56"><span data-lake-id="u8cdad74d" id="u8cdad74d">and</span></code><span data-lake-id="uc5e686db" id="uc5e686db">返回的不一定是布尔值，它返回的是某个参与计算的值本身，</span><code data-lake-id="ue6ec715f" id="ue6ec715f"><span data-lake-id="u780b0782" id="u780b0782">and</span></code><span data-lake-id="u366a3bce" id="u366a3bce">会先看左边，如果左边是“假”，就直接返回左边，否则返回右边；若参与</span><code data-lake-id="u7cbbb2e3" id="u7cbbb2e3"><span data-lake-id="uecf628ef" id="uecf628ef">and</span></code><span data-lake-id="ue85f6c12" id="ue85f6c12">运算的值不是布尔值，那 Python 会自动转为布尔值，然后再进行逻辑操作。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(2%20-%202%20and%20True)%20%23%200%5Cnprint(''%20and%20True)%5Cnprint(True%20and%208%20%2F%202)%20%20%23%204.0%5Cnprint(3%20%2B%203%20and%203%20*%204)%20%23%2012%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22gfZML%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u31f8ca51" id="u31f8ca51"><span data-lake-id="ue429f720" id="ue429f720">2️⃣</span><strong><span data-lake-id="u4ad0bf61" id="u4ad0bf61">or 运算符：</span></strong><span data-lake-id="u0d3d64e2" id="u0d3d64e2">用于判断其两侧，是否至少有一个为True（只要有一个是True，那就返回True）</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(True%20or%20True)%20%20%20%20%23%20True%5Cnprint(True%20or%20False)%20%20%20%23%20True%5Cnprint(False%20or%20True)%20%20%20%23%20True%5Cnprint(False%20or%20False)%20%20%23%20False%5Cn%5Cnprint(9%20%3E%202%20or%209%20%3E%202)%20%20%23%20True%5Cnprint(9%20%3E%202%20or%203%20%3C%201)%20%20%23%20True%5Cnprint(3%20%3C%201%20or%209%20%3E%202)%20%20%23%20True%5Cnprint(3%20%3C%201%20or%203%20%3C%201)%20%20%23%20False%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22qtIcg%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u8dbffe5a" id="u8dbffe5a"><code data-lake-id="ue3945ea7" id="ue3945ea7"><span data-lake-id="u7782e5c5" id="u7782e5c5">or</span></code><span data-lake-id="uc675c5ae" id="uc675c5ae">同样具备“逻辑短路”的能力，以下代码中包含</span><code data-lake-id="u9783e838" id="u9783e838"><span data-lake-id="u686da243" id="u686da243">3/0</span></code><span data-lake-id="uab4f470f" id="uab4f470f">这种错误代码，但最终没有报错。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(True%20or%203%20%2F%200)%20%23%20True%5Cnprint(9%20%3E%203%20or%203%20%2F%200)%20%23%20True%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22aHbf5%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u4727a46c" id="u4727a46c"><code data-lake-id="u628e4424" id="u628e4424"><span data-lake-id="u3e4b60f3" id="u3e4b60f3">or</span></code><span data-lake-id="u69f7d826" id="u69f7d826">返回的也不一定是布尔值，它返回的是参与计算的值本身，</span><code data-lake-id="u4e1a3ecf" id="u4e1a3ecf"><span data-lake-id="u7baa9b5d" id="u7baa9b5d">or</span></code><span data-lake-id="u41047ba3" id="u41047ba3">会先看左边，如果左边为“真”，就直接返回左边，否则返回右边；若参与</span><code data-lake-id="u7d155c29" id="u7d155c29"><span data-lake-id="u961f91e3" id="u961f91e3">or</span></code><span data-lake-id="u2ba65345" id="u2ba65345">运算的值不是布尔值，那 Python 会自动转为布尔值，然后再进行逻辑操作。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(7%20-%202%20or%20False)%20%20%20%20%23%205%5Cnprint('%E4%BD%A0%E5%A5%BD'%20or%20'%E5%B0%9A%E7%A1%85%E8%B0%B7')%20%23%20%E4%BD%A0%E5%A5%BD%5Cnprint(False%20or%208%20%2F%202)%5Ct%20%23%204.0%5Cnprint(2%20-%202%20or%203%20*%204)%20%20%20%20%23%2012%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22zgOQZ%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u4a4a06da" id="u4a4a06da"><span data-lake-id="u57d05535" id="u57d05535">3️⃣</span><strong><span data-lake-id="uc9b1f0e1" id="uc9b1f0e1">not 运算符：</span></strong><code data-lake-id="ude99ee88" id="ude99ee88"><span data-lake-id="u3bf6f445" id="u3bf6f445">not</span></code><span data-lake-id="ucda7fcf5" id="ucda7fcf5">用于取反，不过要注意：如果参与</span><code data-lake-id="uef1a807a" id="uef1a807a"><span data-lake-id="u05ddbbce" id="u05ddbbce">not</span></code><span data-lake-id="u5ffe07c1" id="u5ffe07c1">运算的值不是布尔值，那 Python 会自动将其转为布尔值，然后再进行逻辑操作。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(not%20True)%20%20%23%20False%5Cnprint(not%20False)%20%23%20True%5Cnprint(not%203%20%3E%202)%20%23%20False%5Cnprint(not%203%20%3C%202)%20%23%20True%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22KzqVp%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u952bb79c" id="u952bb79c"><code data-lake-id="ue72481b3" id="ue72481b3"><span data-lake-id="u4743f109" id="u4743f109">not</span></code><span data-lake-id="u1425cd15" id="u1425cd15">返回的值，一定是布尔值！</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22print(not%200)%20%5Ct%20%20%23%20True%5Cnprint(not%203%20%3E%202)%20%20%23%20False%5Cnprint(not%209%20%2F%2F%204)%20%23%20False%5Cnprint(not%20'abc')%20%20%23%20False%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22YqQtu%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="KFxGv" id="KFxGv" data-lake-index-type="2"><span data-lake-id="ue3a15692" id="ue3a15692">进制</span></h2><h3 data-lake-id="dOXXZ" id="dOXXZ" data-lake-index-type="2"><span data-lake-id="ufc7caf1d" id="ufc7caf1d">概述</span></h3><p data-lake-id="u5f9e1e43" id="u5f9e1e43"><span data-lake-id="uf2f81044" id="uf2f81044">进制是指：用多少个符号，来表示数值的一种『记数方式』。比如我们平时使用的『十进制』，就是用</span><code data-lake-id="ucd0583cb" id="ucd0583cb"><span data-lake-id="u892c7955" id="u892c7955">0 ~ 9</span></code><span data-lake-id="u80206af4" id="u80206af4">这十个符号来表示所有的数，而计算机中存储和运算的数据，都是二进制，常见的进制与规则如下：</span></p><blockquote data-lake-id="u7b1ec007" id="u7b1ec007" class="lake-alert lake-alert-info"><p data-lake-id="u0c738c9b" id="u0c738c9b"><strong><span data-lake-id="u652ff191" id="u652ff191">二进制</span></strong><span data-lake-id="u2f4b6bc0" id="u2f4b6bc0">：</span><code data-lake-id="uc7e759a0" id="uc7e759a0"><span data-lake-id="u46bfe60d" id="u46bfe60d">0 ~ 1</span></code><span data-lake-id="u8effae22" id="u8effae22">，满</span><code data-lake-id="u139fc33e" id="u139fc33e"><span data-lake-id="u80da162c" id="u80da162c">2</span></code><span data-lake-id="u1a5e92b4" id="u1a5e92b4">进</span><code data-lake-id="u7005d050" id="u7005d050"><span data-lake-id="u5aaa7a5f" id="u5aaa7a5f">1</span></code><span data-lake-id="u1865efd7" id="u1865efd7">。</span></p><p data-lake-id="u7ebd3b96" id="u7ebd3b96"><strong><span data-lake-id="uf24c8bf0" id="uf24c8bf0">八进制</span></strong><span data-lake-id="u3754b57f" id="u3754b57f">：</span><code data-lake-id="u215f23d9" id="u215f23d9"><span data-lake-id="u2c8414ac" id="u2c8414ac">0 ~ 7</span></code><span data-lake-id="u2cbd1f81" id="u2cbd1f81">，满</span><code data-lake-id="u02005771" id="u02005771"><span data-lake-id="u95e8845e" id="u95e8845e">8</span></code><span data-lake-id="u38612c39" id="u38612c39">进</span><code data-lake-id="ud3fb456f" id="ud3fb456f"><span data-lake-id="u6cb0604e" id="u6cb0604e">1</span></code><span data-lake-id="u05016d66" id="u05016d66">。</span></p><p data-lake-id="ub08e9425" id="ub08e9425"><strong><span data-lake-id="u7c0c4736" id="u7c0c4736">十进制</span></strong><span data-lake-id="ub1d93376" id="ub1d93376">：</span><code data-lake-id="uf94215b6" id="uf94215b6"><span data-lake-id="u133530a3" id="u133530a3">0 ~ 9</span></code><span data-lake-id="u834fe549" id="u834fe549">，满</span><code data-lake-id="u280dd4bd" id="u280dd4bd"><span data-lake-id="ua110feab" id="ua110feab">10</span></code><span data-lake-id="uf5e28c1c" id="uf5e28c1c">进</span><code data-lake-id="ue8d76dac" id="ue8d76dac"><span data-lake-id="uc5612386" id="uc5612386">1</span></code><span data-lake-id="ud168454b" id="ud168454b">。</span></p><p data-lake-id="u912900ef" id="u912900ef"><strong><span data-lake-id="u45fac37c" id="u45fac37c">十六进制</span></strong><span data-lake-id="udf570db2" id="udf570db2">：</span><code data-lake-id="ud9d6fa44" id="ud9d6fa44"><span data-lake-id="u2cd768c4" id="u2cd768c4">0 ~ 9</span></code><span data-lake-id="u9b0b9c2d" id="u9b0b9c2d">，</span><code data-lake-id="ud575f86e" id="ud575f86e"><span data-lake-id="u3366f568" id="u3366f568">A-F</span></code><span data-lake-id="u31cca3a0" id="u31cca3a0">，满</span><code data-lake-id="ub5f6d3ec" id="ub5f6d3ec"><span data-lake-id="u0d2e0188" id="u0d2e0188">16</span></code><span data-lake-id="ue55d80ba" id="ue55d80ba">进</span><code data-lake-id="udd0f0a90" id="udd0f0a90"><span data-lake-id="u3a24bda1" id="u3a24bda1">1</span></code><span data-lake-id="uf4be9eac" id="uf4be9eac">。</span></p></blockquote><blockquote data-lake-id="u79ed2477" id="u79ed2477" class="lake-alert lake-alert-tips"><p data-lake-id="ue23a351e" id="ue23a351e"><strong><span data-lake-id="u6f1d6e3e" id="u6f1d6e3e">📋</span></strong><strong><span data-lake-id="u9b702ab3" id="u9b702ab3">备注：</span></strong><span data-lake-id="u2a791dfc" id="u2a791dfc"> 在十六进制中，除了</span><code data-lake-id="u98171299" id="u98171299"><span data-lake-id="uf7a72ed8" id="uf7a72ed8">0 ~ 9</span></code><span data-lake-id="u04458cc1" id="u04458cc1">这十个数字外，还引入了字母，以便表示超过</span><code data-lake-id="ubbf62fc2" id="ubbf62fc2"><span data-lake-id="u51a99cd5" id="u51a99cd5">9</span></code><span data-lake-id="u584e4a99" id="u584e4a99">的值，字母</span><code data-lake-id="u83944134" id="u83944134"><span data-lake-id="udf105419" id="udf105419">A</span></code><span data-lake-id="ucd336b87" id="ucd336b87">对应十进制的</span><code data-lake-id="u084a5a65" id="u084a5a65"><span data-lake-id="uad06cf38" id="uad06cf38">10</span></code><span data-lake-id="ud37685a8" id="ud37685a8">，字母</span><code data-lake-id="u47c96e58" id="u47c96e58"><span data-lake-id="uff6f7ecb" id="uff6f7ecb">B</span></code><span data-lake-id="u40e5e5a3" id="u40e5e5a3">对应十进制的</span><code data-lake-id="u88ece83a" id="u88ece83a"><span data-lake-id="u808a6082" id="u808a6082">11</span></code><span data-lake-id="u1cca1165" id="u1cca1165">，同理字母 </span><code data-lake-id="ud6516c03" id="ud6516c03"><span data-lake-id="uc9990ca3" id="uc9990ca3">C</span></code><span data-lake-id="u3be90822" id="u3be90822">、</span><code data-lake-id="uee2c444e" id="uee2c444e"><span data-lake-id="u7685cafe" id="u7685cafe">D</span></code><span data-lake-id="u91e6aa5b" id="u91e6aa5b">、</span><code data-lake-id="ub01d26df" id="ub01d26df"><span data-lake-id="ucb658b8a" id="ucb658b8a">E</span></code><span data-lake-id="u490c77e1" id="u490c77e1">、</span><code data-lake-id="u962bb4f1" id="u962bb4f1"><span data-lake-id="u71e971e7" id="u71e971e7">F</span></code><span data-lake-id="uf1627b98" id="uf1627b98"> 分别对应十进制的：</span><code data-lake-id="uf4358b74" id="uf4358b74"><span data-lake-id="u99ed397f" id="u99ed397f">12</span></code><span data-lake-id="uc6753860" id="uc6753860">、</span><code data-lake-id="u8a2ab5ef" id="u8a2ab5ef"><span data-lake-id="uc486a4c3" id="uc486a4c3">13</span></code><span data-lake-id="u8e79c82e" id="u8e79c82e">、</span><code data-lake-id="u1e9ddc4c" id="u1e9ddc4c"><span data-lake-id="u1b668786" id="u1b668786">14</span></code><span data-lake-id="u330fd43e" id="u330fd43e">、</span><code data-lake-id="u2cec4c4f" id="u2cec4c4f"><span data-lake-id="ue078e72d" id="ue078e72d">15</span></code><span data-lake-id="u9e849762" id="u9e849762">。</span></p></blockquote><p data-lake-id="u8d9ff31c" id="u8d9ff31c"><span data-lake-id="u01da3bba" id="u01da3bba">各进制的表示如下图：</span></p><p data-lake-id="u50c5b2d6" id="u50c5b2d6"><card type="inline" name="image" value="data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2025%2Fpng%2F35780599%2F1760689897490-ff8343ae-f99c-4890-a68c-eb7f8efcffa1.png%22%2C%22taskId%22%3A%22ua423de98-b6d6-4648-8730-771eecb7cf2%22%2C%22clientId%22%3A%22u9dc15b59-c913-4%22%2C%22originalType%22%3A%22binary%22%2C%22