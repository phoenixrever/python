3%20%E6%B3%A8%E6%84%8F%E7%82%B9%EF%BC%9A%E7%B1%BB%E6%96%B9%E6%B3%95%EF%BC%8C%E4%B9%9F%E8%83%BD%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E8%B0%83%E7%94%A8%E5%88%B0%EF%BC%8C%E4%BD%86%E6%98%AF%E9%9D%9E%E5%B8%B8%E4%B8%8D%E6%8E%A8%E8%8D%90%5Cnp4%20%3D%20p1.create('%E6%9D%8E%E5%8D%8E-2003-%E5%A5%B3')%5Cnprint(p4.__dict__)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22T38Uo%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h3 data-lake-id="BpyQS" id="BpyQS" data-lake-index-type="2"><span data-lake-id="ud7071818" id="ud7071818">静态方法 </span></h3><p data-lake-id="ub089f58d" id="ub089f58d" style="text-indent: 2em"><strong><span data-lake-id="u69dd7a3d" id="u69dd7a3d">定义：</span></strong><span data-lake-id="u66e2e5ab" id="u66e2e5ab">使用</span><code data-lake-id="u81681a98" id="u81681a98"><span data-lake-id="udcd4ec3c" id="udcd4ec3c">@staticmethod</span></code><span data-lake-id="u3170be35" id="u3170be35">装饰器修饰，方法没有</span><code data-lake-id="u68812ab3" id="u68812ab3"><span data-lake-id="u1b20b189" id="u1b20b189">self</span></code><span data-lake-id="u32d4afeb" id="u32d4afeb">或</span><code data-lake-id="u14f7a95b" id="u14f7a95b"><span data-lake-id="ua3d2eb9c" id="ua3d2eb9c">cls</span></code><span data-lake-id="uf65760e3" id="uf65760e3">参数，只是单纯的定义在类中。</span></p><p data-lake-id="u9569ff5b" id="u9569ff5b" style="text-indent: 2em"><strong><span data-lake-id="u0a6b8fee" id="u0a6b8fee">特点：</span></strong></p><blockquote data-lake-id="ud9fb6f3a" id="ud9fb6f3a" hindent="2em" class="lake-alert lake-alert-info"><ol list="udd6055c7"><li fid="ue77567cc" data-lake-id="u2f7f06a2" id="u2f7f06a2"><span data-lake-id="u05077717" id="u05077717">可通过『类名』或『实例名』调用，但</span><strong><span data-lake-id="u801ef35a" id="u801ef35a">强烈推荐</span></strong><strong><span data-lake-id="ud5671c2c" id="ud5671c2c" style="color: #AD1A2B">通过类名调用</span></strong><span data-lake-id="u3e131be7" id="u3e131be7">以体现语义。  </span></li><li fid="ue77567cc" data-lake-id="u1b39a711" id="u1b39a711"><span data-lake-id="u75e1c2eb" id="u75e1c2eb">由于没有</span><code data-lake-id="uedd9463e" id="uedd9463e"><span data-lake-id="uc6edcaf5" id="uc6edcaf5">self</span></code><span data-lake-id="u3efa7878" id="u3efa7878">或</span><code data-lake-id="uf98f0526" id="uf98f0526"><span data-lake-id="u0df715a0" id="u0df715a0">cls</span></code><span data-lake-id="u2bbce655" id="u2bbce655">参数，所以静态方法中通常：不访问类属性，也不访问实例属性。</span></li><li fid="ue77567cc" data-lake-id="uea86075f" id="uea86075f"><span data-lake-id="u1327c773" id="u1327c773">一般用于：定义与类相关，但可以独立使用的</span><strong><span data-lake-id="uc056b4fa" id="uc056b4fa" style="color: #AD1A2B">工具方法</span></strong><span data-lake-id="u923bfcc2" id="u923bfcc2">。</span></li></ol></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20%23%20*******************************%5Cn%20%20%20%20%23%20*******************************%5Cn%20%20%20%20%23%20*******************************%5Cn%20%20%20%20%5Cn%20%20%20%20%23%20%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%5Cn%20%20%20%20%23%20%E4%BD%BF%E7%94%A8%20%40staticmethod%20%E8%A3%85%E9%A5%B0%E8%BF%87%E7%9A%84%E6%96%B9%E6%B3%95%EF%BC%8C%E5%B0%B1%E5%8F%AB%EF%BC%9A%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%EF%BC%8C%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%E4%B9%9F%E6%98%AF%E4%BF%9D%E5%AD%98%E5%9C%A8%E7%B1%BB%E8%BA%AB%E4%B8%8A%E7%9A%84%5Cn%20%20%20%20%23%20%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%E5%8F%AA%E6%98%AF%E5%8D%95%E7%BA%AF%E7%9A%84%E5%AE%9A%E4%B9%89%E5%9C%A8%E7%B1%BB%E4%B8%AD%EF%BC%8C%E5%AE%83%E4%B8%8D%E4%BC%9A%E6%94%B6%E5%88%B0%EF%BC%9Aself%E3%80%81cls%E5%8F%82%E6%95%B0%EF%BC%8C%E5%AE%83%E6%94%B6%E5%88%B0%E7%9A%84%E5%8F%82%E6%95%B0%E9%83%BD%E6%98%AF%E8%87%AA%E5%AE%9A%E4%B9%89%E5%8F%82%E6%95%B0%5Cn%20%20%20%20%23%20%E7%94%B1%E4%BA%8E%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%E6%B2%A1%E6%9C%89%E6%94%B6%E5%88%B0%EF%BC%9Aself%E3%80%81cls%E5%8F%82%E6%95%B0%EF%BC%8C%E6%89%80%E4%BB%A5%E5%85%B6%E5%86%85%E9%83%A8%E4%B8%8D%E4%BC%9A%E8%AE%BF%E9%97%AE%E4%BB%BB%E4%BD%95%EF%BC%9A%E7%B1%BB%E5%92%8C%E5%AE%9E%E4%BE%8B%E7%9B%B8%E5%85%B3%E7%9A%84%E5%86%85%E5%AE%B9%5Cn%20%20%20%20%23%20%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%E9%80%9A%E5%B8%B8%E7%94%A8%E4%BA%8E%E5%AE%9A%E4%B9%89%EF%BC%9A%E4%B8%8E%E7%B1%BB%E7%9B%B8%E5%85%B3%E7%9A%84%E5%B7%A5%E5%85%B7%E6%96%B9%E6%B3%95%5Cn%20%20%20%20%40staticmethod%5Cn%20%20%20%20def%20is_adult(year)%3A%5Cn%20%20%20%20%20%20%20%20%23%20%E8%8E%B7%E5%8F%96%E5%BD%93%E5%89%8D%E7%9A%84%E5%B9%B4%E4%BB%BD%5Cn%20%20%20%20%20%20%20%20current_year%20%3D%20datetime.now().year%5Cn%20%20%20%20%20%20%20%20%23%20%E8%AE%A1%E7%AE%97%E5%B9%B4%E9%BE%84%5Cn%20%20%20%20%20%20%20%20age%20%3D%20current_year%20-%20year%5Cn%20%20%20%20%20%20%20%20%23%20%E8%BF%94%E5%9B%9E%E7%BB%93%E6%9E%9C%EF%BC%88%E6%88%90%E5%B9%B4True%EF%BC%8C%E6%9C%AA%E6%88%90%E5%B9%B4False%EF%BC%89%5Cn%20%20%20%20%20%20%20%20return%20age%20%3E%3D%2018%5Cn%5Cn%20%20%20%20%40staticmethod%5Cn%20%20%20%20def%20mask_idcard(idcard)%3A%5Cn%20%20%20%20%20%20%20%20return%20idcard%5B%3A6%5D%20%2B%20'********'%20%2B%20idcard%5B-4%3A%5D%5Cn%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%EF%BC%9A%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%E4%B9%9F%E6%98%AF%E4%BF%9D%E5%AD%98%E5%9C%A8%E7%B1%BB%E8%BA%AB%E4%B8%8A%E7%9A%84%5Cn%23%20print(Person.__dict__)%5Cn%5Cn%23%20%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%E9%9C%80%E8%A6%81%E9%80%9A%E8%BF%87%E7%B1%BB%E5%8E%BB%E8%B0%83%E7%94%A8%5Cn%23%20result%20%3D%20Person.is_adult(2015)%5Cn%23%20print(result)%5Cn%23%20result2%20%3D%20Person.mask_idcard('212101198802030028')%5Cn%23%20print(result2)%5Cn%5Cn%23%20%E6%B3%A8%E6%84%8F%E7%82%B9%EF%BC%9A%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E4%B9%9F%E8%83%BD%E8%B0%83%E7%94%A8%E5%88%B0%E9%9D%99%E6%80%81%E6%96%B9%E6%B3%95%EF%BC%8C%E4%BD%86%E9%9D%9E%E5%B8%B8%E4%B8%8D%E6%8E%A8%E8%8D%90%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnres%20%3D%20p1.mask_idcard('212101198802030028')%5Cnprint(res)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22cjR01%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h2 data-lake-id="g6hCK" id="g6hCK" data-lake-index-type="2"><span data-lake-id="u171463a4" id="u171463a4">继承</span></h2><h3 data-lake-id="dyAyM" id="dyAyM" data-lake-index-type="2"><span data-lake-id="u159a513d" id="u159a513d">基本语法</span></h3><p data-lake-id="uaa64bc7f" id="uaa64bc7f" style="text-indent: 2em"><strong><span data-lake-id="u02e13110" id="u02e13110">概念：</span></strong><span data-lake-id="u11bb8d80" id="u11bb8d80">是指一个类，可以继承另一个类的属性和方法。</span></p><p data-lake-id="u90294ac1" id="u90294ac1" style="text-indent: 2em"><strong><span data-lake-id="ucfe7c08c" id="ucfe7c08c">作用：</span></strong><span data-lake-id="uced3a91d" id="uced3a91d">可以实现代码的复用与扩展，避免重复编写相同的代码，让程序结构更简洁、更高效。</span></p><p data-lake-id="ub62fd942" id="ub62fd942" style="text-indent: 2em"><strong><span data-lake-id="u1ec6dd93" id="u1ec6dd93">举例：</span></strong><span data-lake-id="ua1fdac1a" id="ua1fdac1a">就像生活中，孩子可以继承父母的：长相、性格、财产等，程序中的继承与之类似。  </span></p><p data-lake-id="u6ff174d8" id="u6ff174d8" style="text-indent: 2em"><strong><span data-lake-id="u6d48dc1b" id="u6d48dc1b">代码实例：</span></strong></p><p data-lake-id="u3a75ef6e" id="u3a75ef6e" style="text-indent: 2em"><span data-lake-id="ue15d3c91" id="ue15d3c91">如下代码中</span><code data-lake-id="u567e4861" id="u567e4861"><span data-lake-id="ub749257e" id="ub749257e">Person</span></code><span data-lake-id="u7481d17f" id="u7481d17f">为父类（又称：基类）</span><code data-lake-id="u4b2c9f8d" id="u4b2c9f8d"><span data-lake-id="u4a782bfc" id="u4a782bfc">Student</span></code><span data-lake-id="ucf9793ac" id="ucf9793ac">为子类（又称：派生类）</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%20%20%20%20def%20speak(self%2C%20msg)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%8F%AB%7Bself.name%7D%EF%BC%8C%20%E5%B9%B4%E9%BE%84%E6%98%AF%7Bself.age%7D%EF%BC%8C%20%E6%80%A7%E5%88%AB%E6%98%AF%7Bself.gender%7D%EF%BC%8C%E6%88%91%E6%83%B3%E8%AF%B4%EF%BC%9A%7Bmsg%7D')%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAStudent%E7%B1%BB%EF%BC%88%E5%AD%90%E7%B1%BB%E3%80%81%E6%B4%BE%E7%94%9F%E7%B1%BB%EF%BC%89%EF%BC%8C%20%E7%BB%A7%E6%89%BF%E8%87%AAPerson%E7%B1%BB%EF%BC%88%E7%88%B6%E7%B1%BB%E3%80%81%E8%B6%85%E7%B1%BB%E3%80%81%E5%9F%BA%E7%B1%BB%EF%BC%89%5Cnclass%20Student(Person)%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender%2C%20stu_id%2C%20grade)%3A%5Cn%20%20%20%20%20%20%20%20%23%20%E5%9C%A8%E5%AD%90%E7%B1%BB%E4%B8%AD%EF%BC%8C%E6%9C%89%E4%B8%A4%E7%A7%8D%E6%96%B9%E5%BC%8F%E5%8E%BB%E8%B0%83%E7%94%A8%E7%88%B6%E7%B1%BB%E7%9A%84%E5%88%9D%E5%A7%8B%E5%8C%96%E6%96%B9%E6%B3%95%EF%BC%8C%E6%9D%A5%E5%AE%9E%E7%8E%B0%E5%AF%B9%E7%BB%A7%E6%89%BF%E5%B1%9E%E6%80%A7%EF%BC%9Aname%2C%20age%2C%20gender%20%E5%88%9D%E5%A7%8B%E5%8C%96%E6%93%8D%E4%BD%9C%5Cn%20%20%20%20%20%20%20%20%23%20%E6%96%B9%E5%BC%8F1%EF%BC%88%E6%9B%B4%E6%8E%A8%E8%8D%90%EF%BC%89%5Cn%20%20%20%20%20%20%20%20super().__init__(name%2C%20age%2C%20gender)%5Cn%5Cn%20%20%20%20%20%20%20%20%23%20%E6%96%B9%E5%BC%8F2%5Cn%20%20%20%20%20%20%20%20%23%20Person.__init__(self%2C%20name%2C%20age%2C%20gender)%5Cn%5Cn%20%20%20%20%20%20%20%20%23%20%E5%AD%90%E7%B1%BB%E7%8B%AC%E6%9C%89%E7%9A%84%E5%B1%9E%E6%80%A7%EF%BC%8C%E9%9C%80%E8%A6%81%E8%87%AA%E5%B7%B1%E6%89%8B%E5%8A%A8%E5%AE%8C%E6%88%90%E5%88%9D%E5%A7%8B%E5%8C%96%5Cn%20%20%20%20%20%20%20%20self.stu_id%20%3D%20stu_id%5Cn%20%20%20%20%20%20%20%20self.grade%20%3D%20grade%5Cn%5Cn%20%20%20%20def%20study(self)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%8F%AB%7Bself.name%7D%EF%BC%8C%E6%88%91%E5%9C%A8%E5%8A%AA%E5%8A%9B%E7%9A%84%E5%AD%A6%E4%B9%A0%EF%BC%8C%E4%BA%89%E5%8F%96%E5%81%9A%E5%88%B0%7Bself.grade%7D%E5%B9%B4%E7%BA%A7%E7%9A%84%E7%AC%AC%E4%B8%80%E5%90%8D')%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAStudent%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cns1%20%3D%20Student('%E6%9D%8E%E5%8D%8E'%2C%2016%2C%20'%E7%94%B7'%2C%20'2025001'%2C%20'%E5%88%9D%E4%BA%8C')%5Cn%23%20print(s1.__dict__)%5Cn%23%20print(type(s1))%5Cn%5Cn%23%20%E6%9F%A5%E6%89%BEspeak%E6%96%B9%E6%B3%95%E7%9A%84%E8%BF%87%E7%A8%8B%EF%BC%9A1.%E5%AE%9E%E4%BE%8B%E8%87%AA%E8%BA%AB(s1)%20%3D%3E%202.Student%E7%B1%BB%20%3D%3E%203.Person%E7%B1%BB%5Cn%23%20s1.speak('%E4%BD%A0%E5%A5%BD')%5Cn%5Cn%23%20print(s1.__dict__)%5Cn%5Cn%23%20%E6%9F%A5%E6%89%BEstudy%E6%96%B9%E6%B3%95%E7%9A%84%E8%BF%87%E7%A8%8B%EF%BC%9A1.%E5%AE%9E%E4%BE%8B%E8%87%AA%E8%BA%AB(s1)%20%3D%3E%202.Student%E7%B1%BB%20%3D%3E%203.Person%E7%B1%BB%5Cn%23%20s1.study()%5Cn%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22gZsLb%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><p data-lake-id="uff57084a" id="uff57084a" style="text-indent: 2em"><strong><span data-lake-id="u2bf120b3" id="u2bf120b3">几个说明：</span></strong></p><blockquote data-lake-id="u0dfcc4ad" id="u0dfcc4ad" hindent="2em" class="lake-alert lake-alert-info"><ol list="ufc8c342e"><li fid="u5ae4141f" data-lake-id="u976a41d4" id="u976a41d4"><span data-lake-id="u1edd52be" id="u1edd52be">定义类时，在类名后写圆括号</span><code data-lake-id="u7fa5e0b2" id="u7fa5e0b2"><span data-lake-id="ubb35439a" id="ubb35439a">()</span></code><span data-lake-id="u1e6458ca" id="u1e6458ca">，并填入另一个类名，表示该类继承自另一个类。</span></li><li fid="u5ae4141f" data-lake-id="ua80978ce" id="ua80978ce"><span data-lake-id="u95d3fdf8" id="u95d3fdf8">在子类中，可以直接使用父类中定义的：属性、方法，也可以定义自己独有的内容。</span></li><li fid="u5ae4141f" data-lake-id="u3a81dffc" id="u3a81dffc"><code data-lake-id="uabac7588" id="uabac7588"><span data-lake-id="u050cc889" id="u050cc889">super().__init__()</span></code><span data-lake-id="u6569e147" id="u6569e147">的作用：调用父类的初始化方法。</span></li></ol></blockquote><h3 data-lake-id="YWJma" id="YWJma" data-lake-index-type="2"><span data-lake-id="u189f8116" id="u189f8116"> 方法重写</span></h3><p data-lake-id="ub23667c1" id="ub23667c1"><span data-lake-id="u2fa0e6f4" id="u2fa0e6f4"> 	如果子类中定义了与父类同名的方法，则会子类会“覆盖”父类中的方法，又称：“重写”。 </span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%20%20%20%20def%20speak(self%2C%20msg)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%8F%AB%7Bself.name%7D%EF%BC%8C%20%E5%B9%B4%E9%BE%84%E6%98%AF%7Bself.age%7D%EF%BC%8C%20%E6%80%A7%E5%88%AB%E6%98%AF%7Bself.gender%7D%EF%BC%8C%E6%88%91%E6%83%B3%E8%AF%B4%EF%BC%9A%7Bmsg%7D')%5Cn%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAStudent%E7%B1%BB%EF%BC%8C%E7%BB%A7%E6%89%BF%E8%87%AAPerson%E7%B1%BB%5Cnclass%20Student(Person)%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender%2C%20stu_id%2C%20grade)%3A%5Cn%20%20%20%20%20%20%20%20super().__init__(name%2C%20age%2C%20gender)%5Cn%20%20%20%20%20%20%20%20self.stu_id%20%3D%20stu_id%5Cn%20%20%20%20%20%20%20%20self.grade%20%3D%20grade%5Cn%5Cn%20%20%20%20%23%20%E6%96%B9%E6%B3%95%E9%87%8D%E5%86%99%EF%BC%9A%E5%BD%93%E5%AD%90%E7%B1%BB%E4%B8%AD%E5%AE%9A%E4%B9%89%E4%BA%86%E4%B8%80%E4%B8%AA%E4%B8%8E%E7%88%B6%E7%B1%BB%E4%B8%AD%E7%9B%B8%E5%90%8C%E7%9A%84%E6%96%B9%E6%B3%95%EF%BC%8C%E9%82%A3%E4%B9%88%E5%AD%90%E7%B1%BB%E4%B8%AD%E7%9A%84%E6%96%B9%E6%B3%95%E5%B0%B1%E4%BC%9A%E2%80%9C%E8%A6%86%E7%9B%96%E2%80%9D%E7%88%B6%E7%B1%BB%E7%9A%84%E6%96%B9%E6%B3%95%5Cn%20%20%20%20def%20speak(self%2C%20msg)%3A%5Cn%20%20%20%20%20%20%20%20super().speak(msg)%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E6%98%AF%E5%AD%A6%E7%94%9F%EF%BC%8C%E6%88%91%E7%9A%84%E5%AD%A6%E5%8F%B7%E6%98%AF%7Bself.stu_id%7D%EF%BC%8C%E6%88%91%E6%AD%A3%E5%9C%A8%E8%AF%BB%7Bself.grade%7D%EF%BC%8C%E6%88%91%E6%83%B3%E8%AF%B4%EF%BC%9A%7Bmsg%7D')%5Cn%5Cns1%20%3D%20Student('%E6%9D%8E%E5%8D%8E'%2C%2012%2C%20'%E7%94%B7'%2C%20'2025001'%2C%20'%E5%88%9D%E4%BA%8C')%5Cns1.speak('%E5%A5%BD%E5%A5%BD%E5%AD%A6%E4%B9%A0')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22iVxyR%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h3 data-lake-id="bmyJJ" id="bmyJJ" data-lake-index-type="2"><code data-lake-id="u7405fdb5" id="u7405fdb5"><span data-lake-id="u328905ca" id="u328905ca">isinstance()</span></code><span data-lake-id="udd4cb08a" id="udd4cb08a"> 和 </span><code data-lake-id="u39d383f9" id="u39d383f9"><span data-lake-id="ucdc29ac1" id="ucdc29ac1">issubclass()</span></code></h3><p data-lake-id="u52253a05" id="u52253a05" style="text-indent: 2em"><span data-lake-id="u879b1cf1" id="u879b1cf1">两个常用方法：</span></p><table data-lake-id="mcOQh" id="mcOQh" margin="true" row-head="#074A92;#FFFFFF" hindent="2em" class="lake-table" style="width: 651px"><colgroup><col width="270"><col width="381"></colgroup><tbody><tr data-lake-id="ued88c292" id="ued88c292"><td data-lake-id="u792e6cc0" id="u792e6cc0"><p data-lake-id="ua9d659cf" id="ua9d659cf" style="text-align: center"><span data-lake-id="u889e5f53" id="u889e5f53">函数</span></p></td><td data-lake-id="udecbc520" id="udecbc520"><p data-lake-id="u6bba20eb" id="u6bba20eb" style="text-align: center"><span data-lake-id="u48b2a953" id="u48b2a953">作用</span></p></td></tr><tr data-lake-id="u1a08231e" id="u1a08231e"><td data-lake-id="u0118e561" id="u0118e561"><p data-lake-id="u1b91f991" id="u1b91f991"><code data-lake-id="uab4348c5" id="uab4348c5"><span data-lake-id="u7aa9a4f6" id="u7aa9a4f6">isinstance(obj, Class)</span></code></p></td><td data-lake-id="ufadd8951" id="ufadd8951"><p data-lake-id="ub8862a53" id="ub8862a53"><span data-lake-id="u22d1bd81" id="u22d1bd81">判断对象是否为</span><strong><span data-lake-id="u06c3e4da" id="u06c3e4da">指定类</span></strong><span data-lake-id="u9face951" id="u9face951">或其</span><strong><span data-lake-id="u92f33ef9" id="u92f33ef9">子类</span></strong><span data-lake-id="ue6f1180f" id="ue6f1180f">的实例</span></p></td></tr><tr data-lake-id="u78dd6938" id="u78dd6938"><td data-lake-id="ucdaeacba" id="ucdaeacba"><p data-lake-id="ub0b42c0c" id="ub0b42c0c"><code data-lake-id="uc09ed961" id="uc09ed961"><span data-lake-id="u84dd81d3" id="u84dd81d3">issubclass(Sub, Super)</span></code></p></td><td data-lake-id="u1af815cc" id="u1af815cc"><p data-lake-id="u0cfe0b85" id="u0cfe0b85"><span data-lake-id="u1e030257" id="u1e030257">判断一个类是否是另一个类的</span><strong><span data-lake-id="uadfab3d3" id="uadfab3d3">子类</span></strong></p></td></tr></tbody></table><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAStudent%E7%B1%BB%EF%BC%8C%E7%BB%A7%E6%89%BF%E8%87%AAPerson%E7%B1%BB%5Cnclass%20Student(Person)%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender%2C%20stu_id%2C%20grade)%3A%5Cn%20%20%20%20%20%20%20%20super().__init__(name%2C%20age%2C%20gender)%5Cn%20%20%20%20%20%20%20%20self.stu_id%20%3D%20stu_id%5Cn%20%20%20%20%20%20%20%20self.grade%20%3D%20grade%5Cn%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cns1%20%3D%20Student('%E6%9D%8E%E5%8D%8E'%2C%2012%2C%20'%E7%94%B7'%2C%20'2025001'%2C%20'%E5%88%9D%E4%BA%8C')%5Cn%5Cn%23%20%E6%96%B9%E6%B3%951%EF%BC%9Aisinstance(instance%2C%20Class)%EF%BC%8C%E4%BD%9C%E7%94%A8%EF%BC%9A%E5%88%A4%E6%96%AD%E6%9F%90%E4%B8%AA%E5%AF%B9%E8%B1%A1%E6%98%AF%E5%90%A6%E4%B8%BA%E6%8C%87%E5%AE%9A%E7%B1%BB%E6%88%96%E5%85%B6%E5%AD%90%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%5Cnprint(isinstance(s1%2C%20Student))%5Cnprint(isinstance(p1%2C%20Person))%5Cnprint(isinstance(s1%2C%20Person))%5Cnprint(isinstance(p1%2C%20Student))%5Cn%5Cn%23%20%E6%96%B9%E6%B3%952%EF%BC%9Aissubclass(Class1%2C%20Class2)%EF%BC%8C%E4%BD%9C%E7%94%A8%EF%BC%9A%E5%88%A4%E6%96%AD%E6%9F%90%E4%B8%AA%E7%B1%BB%E6%98%AF%E5%90%A6%E6%98%AF%E5%8F%A6%E4%B8%80%E4%B8%AA%E7%B1%BB%E7%9A%84%E5%AD%90%E7%B1%BB%5Cnprint(issubclass(Student%2C%20Person))%5Cnprint(issubclass(Person%2C%20Student))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22ctacR%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h3 data-lake-id="s5T79" id="s5T79" data-lake-index-type="2"><span data-lake-id="u842bdf63" id="u842bdf63">多重继承</span></h3><p data-lake-id="u77fdf50a" id="u77fdf50a" style="padding-left: 2em"><strong><span data-lake-id="ud1e1c919" id="ud1e1c919">概念：</span></strong><span data-lake-id="u57f1f12d" id="u57f1f12d">多重继承指一个类同时继承多个父类，从而拥有多个父类的属性和方法。</span></p><p data-lake-id="u7d7d0198" id="u7d7d0198" style="padding-left: 2em"><strong><span data-lake-id="uf01a0a81" id="uf01a0a81">举例：</span></strong><span data-lake-id="u7b8fcd44" id="u7b8fcd44">就像孩子不仅继承爸爸的长相，还可能继承妈妈的性格。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22class%20%E5%AD%90%E7%B1%BB%E5%90%8D(%E7%88%B6%E7%B1%BBA%2C%20%E7%88%B6%E7%B1%BBB%2C%20...)%3A%5Cn%20%20%20%20%23%20%E5%AD%90%E7%B1%BB%E5%8F%AF%E4%BB%A5%E7%BB%A7%E6%89%BF%E5%A4%9A%E4%B8%AA%E7%88%B6%E7%B1%BB%E7%9A%84%E5%B1%9E%E6%80%A7%E5%92%8C%E6%96%B9%E6%B3%95%5Cn%20%20%20%20...%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22RsHef%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><p data-lake-id="ud0d8f894" id="ud0d8f894" style="padding-left: 2em"><strong><span data-lake-id="uc2231275" id="uc2231275">代码示例：</span></strong><span data-lake-id="u7501b382" id="u7501b382">如下代码中</span><code data-lake-id="u8ce7cc20" id="u8ce7cc20"><span data-lake-id="u4c4c8242" id="u4c4c8242">Student</span></code><span data-lake-id="uf93d2bf4" id="uf93d2bf4">类同时继承</span><code data-lake-id="ua572fcdc" id="ua572fcdc"><span data-lake-id="ubefaa41f" id="ubefaa41f">Person</span></code><span data-lake-id="ub8a6625a" id="ub8a6625a">类和</span><code data-lake-id="uea1617cb" id="uea1617cb"><span data-lake-id="u4e62907f" id="u4e62907f">Worker</span></code><span data-lake-id="u2dd5cde4" id="u2dd5cde4">类。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E6%89%80%E8%B0%93%E5%A4%9A%E9%87%8D%E7%BB%A7%E6%89%BF%EF%BC%8C%E5%B0%B1%E6%98%AF%E4%B8%80%E4%B8%AA%E7%B1%BB%EF%BC%8C%E5%8F%AF%E4%BB%A5%E5%90%8C%E6%97%B6%E7%BB%A7%E6%89%BF%E5%A4%9A%E4%B8%AA%E7%88%B6%E7%B1%BB%5Cn%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAPerson%E7%B1%BB%5Cnclass%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%8F%AB%7Bself.name%7D%EF%BC%8C%20%E5%B9%B4%E9%BE%84%E6%98%AF%7Bself.age%7D%EF%BC%8C%20%E6%80%A7%E5%88%AB%E6%98%AF%7Bself.gender%7D')%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAWorker%E7%B1%BB%5Cnclass%20Worker%3A%5Cn%20%20%20%20def%20__init__(self%2C%20company)%3A%5Cn%20%20%20%20%20%20%20%20self.company%20%3D%20company%5Cn%20%20%20%20def%20do_work(self)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%9C%A8%7Bself.company%7D%E5%81%9A%E5%85%BC%E8%81%8C')%5Cn%5Cn%23%20%E5%AE%9A%E4%B9%89%E4%B8%80%E4%B8%AAStudent%E7%B1%BB%EF%BC%8C%E7%BB%A7%E6%89%BF%E8%87%AA%EF%BC%9APerson%E7%B1%BB%E3%80%81Worker%E7%B1%BB%5Cnclass%20Student(Person%2C%20Worker)%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender%2C%20stu_id%2C%20grade%2C%20company)%3A%5Cn%20%20%20%20%20%20%20%20Person.__init__(self%2C%20name%2C%20age%2C%20gender)%5Cn%20%20%20%20%20%20%20%20Worker.__init__(self%2C%20company)%5Cn%20%20%20%20%20%20%20%20self.stu_id%20%3D%20stu_id%5Cn%20%20%20%20%20%20%20%20self.grade%20%3D%20grade%5Cn%20%20%20%20def%20study(self)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%88%91%E5%9C%A8%E5%BE%88%E5%8A%AA%E5%8A%9B%E7%9A%84%E5%AD%A6%E4%B9%A0%EF%BC%8C%E4%BA%89%E5%8F%96%E5%81%9A%7Bself.grade%7D%E5%B9%B4%E7%BA%A7%E7%9A%84%E7%AC%AC%E4%B8%80%E5%90%8D')%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAStudent%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cns1%20%3D%20Student('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7'%2C%20'2025001'%2C%20'%E5%88%9D%E4%BA%8C'%2C%20'%E9%BA%A6%E5%BD%93%E5%8A%B3')%5Cnprint(s1.__dict__)%5Cns1.speak()%5Cns1.do_work()%5Cns1.study()%5Cn%5Cn%23%20%E7%B1%BB%E7%9A%84__mro__%E5%B1%9E%E6%80%A7%EF%BC%9A%E7%94%A8%E4%BA%8E%E8%AE%B0%E5%BD%95%E5%B1%9E%E6%80%A7%E5%92%8C%E6%96%B9%E6%B3%95%E7%9A%84%E6%9F%A5%E6%89%BE%E9%A1%BA%E5%BA%8F%5Cn%23%20%E9%80%9A%E8%BF%87%E5%AE%9E%E4%BE%8B%E5%8E%BB%E6%9F%A5%E6%89%BE%E5%B1%9E%E6%80%A7%E6%88%96%E6%96%B9%E6%B3%95%E6%97%B6%EF%BC%8C%E4%BC%9A%E7%8E%B0%E5%9C%A8%E5%AE%9E%E4%BE%8B%E8%87%AA%E8%BA%AB%E4%B8%8A%E5%AF%BB%E6%89%BE%EF%BC%8C%E5%A6%82%E6%9E%9C%E6%B2%A1%E6%9C%89%EF%BC%8C%E5%B0%B1%E6%8C%89%E7%85%A7__mro__%E4%B8%AD%E6%89%80%E8%AE%B0%E5%BD%95%E7%9A%84%E9%A1%BA%E5%BA%8F%E5%8E%BB%E6%9F%A5%E6%89%BE%5Cnprint(Student.__mro__)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22a1uVt%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h2 data-lake-id="AV6NV" id="AV6NV" data-lake-index-type="2"><span data-lake-id="u0d8a08f6" id="u0d8a08f6">权限控制</span></h2><h3 data-lake-id="QUJYR" id="QUJYR" data-lake-index-type="2"><span data-lake-id="u18f2384b" id="u18f2384b">三种访问权限</span></h3><p data-lake-id="u94ef854a" id="u94ef854a"><span data-lake-id="u116739fa" id="u116739fa">在 Python 中，我们可以给属性赋予三种权限，分别是：公有属性、受保护属性、私有属性。</span></p><p data-lake-id="ubb91c027" id="ubb91c027"><span data-lake-id="u93d1c87c" id="u93d1c87c">下面是详细梳理</span><span data-lake-id="u41db142a" id="u41db142a">👇</span></p><table data-lake-id="eYDKr" id="eYDKr" margin="true" row-head="rgba(8,84,166,1);#FFFFFF" class="lake-table" style="width: 711px"><colgroup><col width="113"><col width="112"><col width="149"><col width="146"><col width="191"></colgroup><tbody><tr data-lake-id="u110631dd" id="u110631dd"><td data-lake-id="u17f80818" id="u17f80818"><p data-lake-id="u71e074d8" id="u71e074d8" style="text-align: center"><span data-lake-id="u12e1219b" id="u12e1219b">权限类型</span></p></td><td data-lake-id="uf019a3dc" id="uf019a3dc"><p data-lake-id="uf1548495" id="uf1548495" style="text-align: center"><span data-lake-id="ub139e1ef" id="ub139e1ef">定义方式</span></p></td><td data-lake-id="u9b788015" id="u9b788015"><p data-lake-id="u0ac82f51" id="u0ac82f51" style="text-align: center"><span data-lake-id="u43c4d7ff" id="u43c4d7ff">在当前类内部访问</span></p></td><td data-lake-id="u258421cd" id="u258421cd"><p data-lake-id="ua7c48df6" id="ua7c48df6" style="text-align: center"><span data-lake-id="u149c8176" id="u149c8176">在子类内部访问</span></p></td><td data-lake-id="uc8a9ea4f" id="uc8a9ea4f"><p data-lake-id="u28e24bae" id="u28e24bae" style="text-align: center"><span data-lake-id="u3dc46b9c" id="u3dc46b9c">在类外部访问</span></p></td></tr><tr data-lake-id="uf90625c2" id="uf90625c2" style="height: 38px"><td data-lake-id="uca58e496" id="uca58e496"><p data-lake-id="u631d10af" id="u631d10af" style="text-align: center"><span data-lake-id="ucc633330" id="ucc633330">公有属性</span></p></td><td data-lake-id="u43c5d041" id="u43c5d041"><p data-lake-id="ued8f5040" id="ued8f5040" style="text-align: center"><code data-lake-id="u637b3c10" id="u637b3c10"><strong><span data-lake-id="u836c0d4c" id="u836c0d4c">属性名</span></strong></code></p></td><td data-lake-id="u1cb27cf1" id="u1cb27cf1"><p data-lake-id="ua71a9afd" id="ua71a9afd" style="text-align: center"><span data-lake-id="u625ca152" id="u625ca152">✅</span><span data-lake-id="ue04b5ff0" id="ue04b5ff0"> 能</span></p></td><td data-lake-id="u42ebebc9" id="u42ebebc9"><p data-lake-id="uc6092112" id="uc6092112" style="text-align: center"><span data-lake-id="u5a8f36b2" id="u5a8f36b2">✅</span><span data-lake-id="ua0f2ab8b" id="ua0f2ab8b"> 能</span></p></td><td data-lake-id="u79dd1e67" id="u79dd1e67"><p data-lake-id="u2b02d815" id="u2b02d815" style="text-align: center"><span data-lake-id="u748b475d" id="u748b475d">✅</span><span data-lake-id="u8d678a69" id="u8d678a69"> 能</span></p></td></tr><tr data-lake-id="u60fa78d5" id="u60fa78d5" style="height: 38px"><td data-lake-id="u97978eab" id="u97978eab"><p data-lake-id="u91baa6c0" id="u91baa6c0" style="text-align: center"><span data-lake-id="ufb6c1e82" id="ufb6c1e82">受保护属性</span></p></td><td data-lake-id="u208dcbd1" id="u208dcbd1"><p data-lake-id="u795796d0" id="u795796d0" style="text-align: center"><code data-lake-id="u91708fa7" id="u91708fa7"><span data-lake-id="ub953dc7a" id="ub953dc7a">_</span><strong><span data-lake-id="u52c97e63" id="u52c97e63">属性名</span></strong></code></p></td><td data-lake-id="u21d1d85a" id="u21d1d85a"><p data-lake-id="u819bed40" id="u819bed40" style="text-align: center"><span data-lake-id="u84b70101" id="u84b70101">✅</span><span data-lake-id="u47267a17" id="u47267a17"> 能</span></p></td><td data-lake-id="ucf014550" id="ucf014550"><p data-lake-id="u9a2134cb" id="u9a2134cb" style="text-align: center"><span data-lake-id="u0d489061" id="u0d489061">✅</span><span data-lake-id="uffd6ee32" id="uffd6ee32"> 能</span></p></td><td data-lake-id="u80dfba17" id="u80dfba17"><p data-lake-id="uc13b014d" id="uc13b014d" style="text-align: center"><span data-lake-id="uca731f29" id="uca731f29">⚠️</span><span data-lake-id="u2fb11fcc" id="u2fb11fcc"> 能（但不推荐）</span></p></td></tr><tr data-lake-id="uc43e70c7" id="uc43e70c7"><td data-lake-id="u2843d50b" id="u2843d50b"><p data-lake-id="ub33ab006" id="ub33ab006" style="text-align: center"><span data-lake-id="u2bfee1e3" id="u2bfee1e3">私有属性</span></p></td><td data-lake-id="u89999384" id="u89999384"><p data-lake-id="u5b7bc478" id="u5b7bc478" style="text-align: center"><code data-lake-id="ue1894dc0" id="ue1894dc0"><span data-lake-id="ua36ec9a3" id="ua36ec9a3">__</span><strong><span data-lake-id="u6ca53faa" id="u6ca53faa">属性名</span></strong></code></p></td><td data-lake-id="u9052c81b" id="u9052c81b"><p data-lake-id="u6ea50dfb" id="u6ea50dfb" style="text-align: center"><span data-lake-id="ubc5832aa" id="ubc5832aa">✅</span><span data-lake-id="u54d5fb8a" id="u54d5fb8a"> 能</span></p></td><td data-lake-id="u5512f22d" id="u5512f22d"><p data-lake-id="u54b290bd" id="u54b290bd" style="text-align: center"><span data-lake-id="u01f30d4f" id="u01f30d4f">❌</span><span data-lake-id="u5fa9fba4" id="u5fa9fba4"> 不能</span></p></td><td data-lake-id="uf9738bc0" id="uf9738bc0"><p data-lake-id="u34bd8505" id="u34bd8505" style="text-align: center"><span data-lake-id="ucfe90eff" id="ucfe90eff">❌</span><span data-lake-id="u5189bb07" id="u5189bb07"> 不能</span></p></td></tr></tbody></table><p data-lake-id="u54c02ec6" id="u54c02ec6"><span data-lake-id="uee698228" id="uee698228">测试『类外部』访问：</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22class%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20idcard)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%20%20%20%20%20%20%20%20%23%20%E5%85%AC%E6%9C%89%E5%B1%9E%E6%80%A7%EF%BC%9A%E5%BD%93%E5%89%8D%E7%B1%BB%E5%86%85%E9%83%A8%E3%80%81%E5%AD%90%E7%B1%BB%E5%86%85%E9%83%A8%E3%80%81%E7%B1%BB%E5%A4%96%E9%83%A8%EF%BC%8C%E5%8F%AF%E9%83%BD%E5%8F%AF%E8%AE%BF%E9%97%AE%5Cn%20%20%20%20%20%20%20%20self._age%20%3D%20age%20%20%20%20%20%20%20%20%20%23%20%E5%8F%97%E4%BF%9D%E6%8A%A4%E5%B1%9E%E6%80%A7%EF%BC%9A%E5%BD%93%E5%89%8D%E7%B1%BB%E5%86%85%E9%83%A8%E3%80%81%E5%AD%90%E7%B1%BB%E5%86%85%E9%83%A8%EF%BC%8C%E5%8F%AF%E4%BB%A5%E8%AE%BF%E9%97%AE%5Cn%20%20%20%20%20%20%20%20self.__idcard%20%3D%20idcard%20%20%23%20%E7%A7%81%E6%9C%89%E5%B1%9E%E6%80%A7%EF%BC%9A%E4%BB%85%E8%83%BD%E5%9C%A8%E5%BD%93%E5%89%8D%E7%B1%BB%E5%86%85%E9%83%A8%E8%AE%BF%E9%97%AE%5Cn%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20%23%20%E7%B1%BB%E7%9A%84%E5%86%85%E9%83%A8%EF%BC%8C%E5%8F%AF%E4%BB%A5%E8%AE%BF%E9%97%AE%E4%BB%BB%E4%BD%95%E6%9D%83%E9%99%90%E7%9A%84%E5%B1%9E%E6%80%A7%EF%BC%88%E5%85%AC%E6%9C%89%E5%B1%9E%E6%80%A7%E3%80%81%E5%8F%97%E4%BF%9D%E6%8A%A4%E5%B1%9E%E6%80%A7%E3%80%81%E7%A7%81%E6%9C%89%E5%B1%9E%E6%80%A7%EF%BC%89%E3%80%82%5Cn%20%20%20%20%20%20%20%20print(f%5C%22%E6%88%91%E5%8F%AB%EF%BC%9A%7Bself.name%7D%EF%BC%8C%E5%B9%B4%E9%BE%84%EF%BC%9A%7Bself._age%7D%EF%BC%8C%E8%BA%AB%E4%BB%BD%E8%AF%81%EF%BC%9A%7Bself.__idcard%7D%5C%22)%5Cn%5Cnclass%20Student(Person)%3A%5Cn%20%20%20%20def%20hello(self)%3A%5Cn%20%20%20%20%20%20%20%20%23%20%E5%AD%90%E7%B1%BB%E7%9A%84%E5%86%85%E9%83%A8%E5%8F%AF%E4%BB%A5%E8%AE%BF%E9%97%AE%EF%BC%9A%E5%85%AC%E6%9C%89%E5%B1%9E%E6%80%A7%E3%80%81%E5%8F%97%E4%BF%9D%E6%8A%A4%E5%B1%9E%E6%80%A7%5Cn%20%20%20%20%20%20%20%20print(f%5C%22%E6%88%91%E6%98%AF%E5%AD%A6%E7%94%9F%EF%BC%8C%E6%88%91%E5%8F%AB%EF%BC%9A%7Bself.name%7D%EF%BC%8C%E5%B9%B4%E9%BE%84%EF%BC%9A%7Bself._age%7D%5C%22)%5Cn%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'110101199001011234')%5Cnprint(p1.name)%5Cn%5Cn%23%20%E7%B1%BB%E7%9A%84%E5%A4%96%E9%83%A8%EF%BC%8C%E4%BB%85%E8%83%BD%E8%AE%BF%E9%97%AE%E5%85%AC%E6%9C%89%E5%B1%9E%E6%80%A7%5Cn%23%20%E6%B3%A8%E6%84%8F%EF%BC%9A%E5%A6%82%E6%9E%9C%E5%9C%A8%E7%B1%BB%E7%9A%84%E5%A4%96%E9%83%A8%EF%BC%8C%E5%BC%BA%E5%88%B6%E8%AE%BF%E9%97%AE%E3%80%90%E5%8F%97%E4%BF%9D%E6%8A%A4%E7%9A%84%E5%B1%9E%E6%80%A7%E3%80%91%EF%BC%8C%E4%B9%9F%E8%83%BD%E8%AE%BF%E9%97%AE%EF%BC%8C%E4%BD%86%E6%9C%80%E5%A5%BD%E5%88%AB%E8%BF%99%E4%B9%88%E5%81%9A%5Cnprint(p1._age)%5Cn%5Cn%23%20%E5%BC%BA%E5%88%B6%E8%AE%BF%E9%97%AE%E3%80%90%E7%A7%81%E6%9C%89%E5%B1%9E%E6%80%A7%E3%80%91%E4%BC%9A%E6%8A%A5%E9%94%99%5Cn%23%20print(p1.__idcard)%5Cn%5Cn%23%20%E6%89%A9%E5%B1%95%EF%BC%9APython%E4%BF%9D%E6%8A%A4%E3%80%90%E7%A7%81%E6%9C%89%E5%B1%9E%E6%80%A7%E3%80%91%E7%9A%84%E6%96%B9%E5%BC%8F%EF%BC%8C%E6%98%AF%E9%87%8D%E5%91%BD%E5%90%8D%EF%BC%8C%E4%BE%8B%E5%A6%82%EF%BC%9A__idcard%E5%B1%9E%E6%80%A7%EF%BC%8C%E4%BC%9A%E8%A2%AB%E9%87%8D%E5%91%BD%E5%90%8D%E4%B8%BA%EF%BC%9A_Person__idcard%5Cnprint(p1.__dict__)%5Cnprint(p1._Person__idcard)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22Mijwm%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><h3 data-lake-id="kp1az" id="kp1az" data-lake-index-type="2"><span data-lake-id="ubeac0f50" id="ubeac0f50">getter 与 setter</span></h3><p data-lake-id="u4f08302e" id="u4f08302e"><span data-lake-id="u65e07bee" id="u65e07bee">在面向对象编程中，我们会把一些内部数据保护起来，但同时还想提供一个“安全的通道”让外部访问。这时候我们就用到：</span></p><ul list="u862f9b08"><li fid="u1f694ad4" data-lake-id="u762eee5a" id="u762eee5a"><strong><span data-lake-id="u1c09e422" id="u1c09e422">getter</span></strong><span data-lake-id="u4e43211c" id="u4e43211c">：读取属性的方法</span></li><li fid="u1f694ad4" data-lake-id="u85b79a46" id="u85b79a46"><strong><span data-lake-id="u2ae92c3a" id="u2ae92c3a">setter</span></strong><span data-lake-id="u0d623e2b" id="u0d623e2b">：修改属性的方法</span></li></ul><p data-lake-id="u9a78aea0" id="u9a78aea0"><span data-lake-id="ubadb1fd9" id="ubadb1fd9">在 Python 中：通过</span><code data-lake-id="udef3d506" id="udef3d506"><span data-lake-id="ub6d7bd65" id="ub6d7bd65">@property</span></code><span data-lake-id="u5b6a35ea" id="u5b6a35ea">和</span><code data-lake-id="u600ec3dc" id="u600ec3dc"><span data-lake-id="ud7da54cf" id="ud7da54cf">@xxx.setter</span></code><span data-lake-id="u9b2b35c8" id="u9b2b35c8">语法，把普通方法变成像属性一样使用的方法。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22class%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20idcard)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%20%20%20%20%20%20%20%20%23%20%E5%85%AC%E6%9C%89%E5%B1%9E%E6%80%A7%EF%BC%9A%E5%BD%93%E5%89%8D%E7%B1%BB%E5%86%85%E9%83%A8%E3%80%81%E5%AD%90%E7%B1%BB%E5%86%85%E9%83%A8%E3%80%81%E7%B1%BB%E5%A4%96%E9%83%A8%EF%BC%8C%E5%8F%AF%E9%83%BD%E5%8F%AF%E8%AE%BF%E9%97%AE%5Cn%20%20%20%20%20%20%20%20self._age%20%3D%20age%20%20%20%20%20%20%20%20%20%23%20%E5%8F%97%E4%BF%9D%E6%8A%A4%E5%B1%9E%E6%80%A7%EF%BC%9A%E5%BD%93%E5%89%8D%E7%B1%BB%E5%86%85%E9%83%A8%E3%80%81%E5%AD%90%E7%B1%BB%E5%86%85%E9%83%A8%EF%BC%8C%E5%8F%AF%E4%BB%A5%E8%AE%BF%E9%97%AE%5Cn%20%20%20%20%20%20%20%20self.__idcard%20%3D%20idcard%20%20%23%20%E7%A7%81%E6%9C%89%E5%B1%9E%E6%80%A7%EF%BC%9A%E4%BB%85%E8%83%BD%E5%9C%A8%E5%BD%93%E5%89%8D%E7%B1%BB%E5%86%85%E9%83%A8%E8%AE%BF%E9%97%AE%5Cn%5Cn%20%20%20%20%23%20%E6%B3%A8%E5%86%8C%20age%20%E5%B1%9E%E6%80%A7%E7%9A%84%20getter%20%E6%96%B9%E6%B3%95%EF%BC%9A%E5%BD%93%E8%AE%BF%E9%97%AE%20Person%20%E5%AE%9E%E4%BE%8B%E7%9A%84%20age%20%E5%B1%9E%E6%80%A7%E6%97%B6%EF%BC%8Cage%E6%96%B9%E6%B3%95%E4%BC%9A%E8%87%AA%E5%8A%A8%E8%B0%83%E7%94%A8%5Cn%20%20%20%20%40property%5Cn%20%20%20%20def%20age(self)%3A%5Cn%20%20%20%20%20%20%20%20return%20self._age%5Cn%5Cn%20%20%20%20%23%20%E6%B3%A8%E5%86%8C%20age%20%E5%B1%9E%E6%80%A7%E7%9A%84%20setter%20%E6%96%B9%E6%B3%95%EF%BC%9A%E5%BD%93%E7%BB%99%20Person%20%E5%AE%9E%E4%BE%8B%E7%9A%84%20age%20%E5%B1%9E%E6%80%A7%E8%B5%8B%E5%80%BC%E6%97%B6%EF%BC%8Cage%E6%96%B9%E6%B3%95%E4%BC%9A%E8%87%AA%E5%8A%A8%E8%B0%83%E7%94%A8%5Cn%20%20%20%20%40age.setter%5Cn%20%20%20%20def%20age(self%2C%20value)%3A%5Cn%20%20%20%20%20%20%20%20if%20value%20%3C%3D%20120%3A%5Cn%20%20%20%20%20%20%20%20%20%20%20%20self._age%20%3D%20value%5Cn%20%20%20%20%20%20%20%20else%3A%5Cn%20%20%20%20%20%20%20%20%20%20%20%20print('%E5%B9%B4%E9%BE%84%E9%9D%9E%E6%B3%95%EF%BC%8C%E5%B7%B2%E5%B0%86%E5%B9%B4%E9%BE%84%E5%8F%98%E4%B8%BA%E6%9C%80%E5%A4%A7%E5%80%BC120')%5Cn%20%20%20%20%20%20%20%20%20%20%20%20self._age%20%3D%20120%5Cn%5Cn%20%20%20%20%23%20%E6%B3%A8%E5%86%8C%20idcard%20%E5%B1%9E%E6%80%A7%E7%9A%84%20getter%20%E6%96%B9%E6%B3%95%EF%BC%9A%E5%BD%93%E8%AE%BF%E9%97%AE%20Person%20%E5%AE%9E%E4%BE%8B%E7%9A%84%20idcard%20%E5%B1%9E%E6%80%A7%E6%97%B6%EF%BC%8C%E4%BC%9A%E8%87%AA%E5%8A%A8%E8%B0%83%E7%94%A8%E6%AD%A4%E6%96%B9%E6%B3%95%5Cn%20%20%20%20%40property%5Cn%20%20%20%20def%20idcard(self)%3A%5Cn%20%20%20%20%20%20%20%20return%20self.__idcard%5B%3A6%5D%20%2B%20'********'%20%2B%20self.__idcard%5B-4%3A%5D%5Cn%5Cn%20%20%20%20%23%20%E6%B3%A8%E5%86%8C%20idcard%20%E5%B1%9E%E6%80%A7%E7%9A%84%20setter%20%E6%96%B9%E6%B3%95%EF%BC%8C%E5%BD%93%20idcard%20%E8%A2%AB%E4%BF%AE%E6%94%B9%E6%97%B6%E8%B0%83%E7%94%A8%EF%BC%8C%E5%86%85%E9%83%A8%E4%BC%9A%E7%A6%81%E6%AD%A2%E4%BF%AE%E6%94%B9%E8%BA%AB%E4%BB%BD%E8%AF%81%E5%8F%B7%E5%B9%B6%E7%BB%99%E5%87%BA%E6%8F%90%E7%A4%BA%E3%80%82%5Cn%20%20%20%20%40idcard.setter%5Cn%20%20%20%20def%20idcard(self%2C%20value)%3A%5Cn%20%20%20%20%20%20%20%20print(%5C%22%E6%8A%B1%E6%AD%89%EF%BC%8C%E8%BA%AB%E4%BB%BD%E8%AF%81%E5%8F%B7%E4%B8%8D%E5%85%81%E8%AE%B8%E9%9A%8F%E6%84%8F%E4%BF%AE%E6%94%B9%EF%BC%8C%E5%A6%82%E6%9C%89%E7%89%B9%E6%AE%8A%E9%9C%80%E6%B1%82%EF%BC%8C%E8%AF%B7%E8%81%94%E7%B3%BB%E7%AE%A1%E7%90%86%E5%91%98%EF%BC%81%5C%22)%5Cn%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'110101199001011234')%5Cnprint(p1.age)%5Cnprint(p1.idcard)%5Cn%5Cn%23%20%E6%B5%8B%E8%AF%95%E4%BF%AE%E6%94%B9age%5Cnp1._age%20%3D%2019%5Cnprint(p1.age)%5Cn%5Cn%23%20%E6%B5%8B%E8%AF%95%E4%BF%AE%E6%94%B9idcard%5Cnp1.idcard%20%3D%20'asd'%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22c6tnR%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><h2 data-lake-id="Fc0zR" id="Fc0zR" data-lake-index-type="2"><span data-lake-id="u6034eb5a" id="u6034eb5a">魔法方法</span></h2><blockquote data-lake-id="u7a21a9c1" id="u7a21a9c1" class="lake-alert lake-alert-info"><ul list="uf38e2551"><li fid="u540eaa08" data-lake-id="udeb15576" id="udeb15576"><strong><span data-lake-id="u451b0b76" id="u451b0b76">概念</span></strong><span data-lake-id="uc710b03a" id="uc710b03a">：以 </span><code data-lake-id="ubef14614" id="ubef14614"><strong><span data-lake-id="ub1457d04" id="ub1457d04">__xxx__</span></strong></code><span data-lake-id="u5f751fa5" id="u5f751fa5"> 命名的特殊方法（双下划线开头和结尾）。</span></li><li fid="u540eaa08" data-lake-id="u0153a200" id="u0153a200"><strong><span data-lake-id="uddff243e" id="uddff243e">特点：</span></strong><span data-lake-id="u62d12a33" id="u62d12a33">不需要手动调，在特定场景由 Python 自动调用。</span></li></ul></blockquote><p data-lake-id="u937291b2" id="u937291b2"><span data-lake-id="u6ecf4ec5" id="u6ecf4ec5">几个常用的魔法方法：</span></p><table data-lake-id="gezGv" id="gezGv" margin="true" width-mode="contain" row-head="rgba(8,84,166,1);#FFFFFF" class="lake-table" style="width: 489px"><colgroup><col width="160"><col width="329"></colgroup><tbody><tr data-lake-id="uedb0a040" id="uedb0a040"><td data-lake-id="uf407c06b" id="uf407c06b"><p data-lake-id="ucb7c4533" id="ucb7c4533" style="text-align: center"><span data-lake-id="uc4e7a360" id="uc4e7a360">方法</span></p></td><td data-lake-id="u7284044d" id="u7284044d"><p data-lake-id="u037f52a0" id="u037f52a0" style="text-align: center"><span data-lake-id="uc5c5d399" id="uc5c5d399">调用时机</span></p></td></tr><tr data-lake-id="u52722552" id="u52722552" style="height: 38px"><td data-lake-id="u2653f6ec" id="u2653f6ec"><p data-lake-id="u2d79ad9f" id="u2d79ad9f"><strong><span data-lake-id="u3460fd98" id="u3460fd98">1️⃣</span></strong><code data-lake-id="u983aadbb" id="u983aadbb"><strong><span data-lake-id="ua0d73861" id="ua0d73861">__str__</span></strong></code><strong><span data-lake-id="u37c58477" id="u37c58477"> </span></strong><span data-lake-id="ufe57784e" id="ufe57784e">​</span></p></td><td data-lake-id="u8225cf49" id="u8225cf49"><p data-lake-id="u2a8346d4" id="u2a8346d4"><span data-lake-id="u2c1b866b" id="u2c1b866b">当调用 </span><code data-lake-id="u7f669ee7" id="u7f669ee7"><strong><span data-lake-id="uf74b04d8" id="uf74b04d8">print(对象)</span></strong></code><span data-lake-id="ueb2fb519" id="ueb2fb519">或</span><code data-lake-id="u20dd16cb" id="u20dd16cb"><strong><span data-lake-id="u4fc5a489" id="u4fc5a489">str(对象)</span></strong></code><span data-lake-id="uf51c10ea" id="uf51c10ea"> 时</span></p></td></tr><tr data-lake-id="u3f850428" id="u3f850428"><td data-lake-id="ueeacd711" id="ueeacd711"><p data-lake-id="u4b914838" id="u4b914838"><strong><span data-lake-id="u66bfe1fb" id="u66bfe1fb">2️⃣</span></strong><code data-lake-id="u4066a5dc" id="u4066a5dc"><strong><span data-lake-id="u0c57d2ac" id="u0c57d2ac">__len__</span></strong></code><strong><span data-lake-id="u2145a352" id="u2145a352"> </span></strong><span data-lake-id="ufc405c06" id="ufc405c06">​</span></p></td><td data-lake-id="u99323b50" id="u99323b50"><p data-lake-id="u760876fe" id="u760876fe"><span data-lake-id="uc60874af" id="uc60874af">当调用</span><code data-lake-id="ubdc279bf" id="ubdc279bf"><strong><span data-lake-id="u4123bf06" id="u4123bf06">len(对象)</span></strong></code><span data-lake-id="u5268c811" id="u5268c811">时</span></p></td></tr><tr data-lake-id="ueca56127" id="ueca56127"><td data-lake-id="ud5b89a66" id="ud5b89a66"><p data-lake-id="udf8c394f" id="udf8c394f"><strong><span data-lake-id="u30c6e57b" id="u30c6e57b">3️⃣</span></strong><code data-lake-id="u78ec6f73" id="u78ec6f73"><strong><span data-lake-id="u08f95def" id="u08f95def">__lt__</span></strong></code><strong><span data-lake-id="u5c4d3f9f" id="u5c4d3f9f"> </span></strong><span data-lake-id="u0941fbba" id="u0941fbba">​</span></p></td><td data-lake-id="ubf4a0219" id="ubf4a0219"><p data-lake-id="uc03d33d2" id="uc03d33d2"><span data-lake-id="u10048200" id="u10048200">当执行</span><code data-lake-id="u5c8ffba0" id="u5c8ffba0"><strong><span data-lake-id="u6fa4a11c" id="u6fa4a11c">对象1 &lt; 对象2</span></strong></code><span data-lake-id="u8c56398c" id="u8c56398c">时</span></p></td></tr><tr data-lake-id="u3d4c53a5" id="u3d4c53a5"><td data-lake-id="u834d2e36" id="u834d2e36"><p data-lake-id="u75f202a3" id="u75f202a3"><strong><span data-lake-id="uad4cef1a" id="uad4cef1a">4️⃣</span></strong><code data-lake-id="u9c7df74c" id="u9c7df74c"><strong><span data-lake-id="u685bdaa3" id="u685bdaa3">__gt__</span></strong></code><strong><span data-lake-id="uc308447c" id="uc308447c"> </span></strong></p></td><td data-lake-id="u9d93ff05" id="u9d93ff05"><p data-lake-id="u44bd5a21" id="u44bd5a21"><span data-lake-id="ua15ecc28" id="ua15ecc28">当执行</span><code data-lake-id="u5adf75af" id="u5adf75af"><strong><span data-lake-id="ufbe83788" id="ufbe83788">对象1 &gt; 对象2</span></strong></code><span data-lake-id="u46fdba03" id="u46fdba03">时</span></p></td></tr><tr data-lake-id="u9d4a8519" id="u9d4a8519"><td data-lake-id="u63d05b49" id="u63d05b49"><p data-lake-id="ubdd23725" id="ubdd23725"><strong><span data-lake-id="ucb0214ba" id="ucb0214ba">5️⃣</span></strong><code data-lake-id="u1b628b54" id="u1b628b54"><strong><span data-lake-id="uc92106ab" id="uc92106ab">__eq__</span></strong></code><strong><span data-lake-id="u8f11876d" id="u8f11876d"> </span></strong></p></td><td data-lake-id="u33ab7a1d" id="u33ab7a1d"><p data-lake-id="ufe58d9f8" id="ufe58d9f8"><span data-lake-id="u9207b985" id="u9207b985">当执行</span><code data-lake-id="u48fca937" id="u48fca937"><strong><span data-lake-id="u3ef2b6c5" id="u3ef2b6c5">对象1 == 对象2</span></strong></code><span data-lake-id="u4f4e8558" id="u4f4e8558">时</span></p></td></tr><tr data-lake-id="ud7f0b141" id="ud7f0b141"><td data-lake-id="u10ac2a46" id="u10ac2a46"><p data-lake-id="u4b10d7ca" id="u4b10d7ca"><strong><span data-lake-id="u139986d1" id="u139986d1">6️⃣</span></strong><code data-lake-id="u53ad7621" id="u53ad7621"><strong><span data-lake-id="u3b50c10e" id="u3b50c10e">__getattr__</span></strong></code></p></td><td data-lake-id="u43cf16a7" id="u43cf16a7"><p data-lake-id="u1fd5fda6" id="u1fd5fda6"><span data-lake-id="ucbebe41a" id="ucbebe41a">当访问不存在的属性时</span></p></td></tr></tbody></table><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E7%B1%BB%E4%B8%AD%E4%BB%A5%E5%8F%8C%E4%B8%8B%E5%88%92%E7%BA%BF%E5%BC%80%E5%A4%B4%E5%92%8C%E7%BB%93%E5%B0%BE%E7%9A%84%E6%96%B9%E6%B3%95%EF%BC%8C%E5%8F%AB%E9%AD%94%E6%B3%95%E6%96%B9%E6%B3%95%EF%BC%88%E9%AD%94%E6%9C%AF%E6%96%B9%E6%B3%95%EF%BC%89%E3%80%82%5Cn%23%20%E9%AD%94%E6%B3%95%E6%96%B9%E6%B3%95%E4%B8%8D%E9%9C%80%E8%A6%81%E6%89%8B%E5%8A%A8%E8%B0%83%E7%94%A8%EF%BC%8CPython%E4%BC%9A%E5%9C%A8%E7%89%B9%E5%AE%9A%E5%9C%BA%E6%99%AF%E8%87%AA%E5%8A%A8%E8%B0%83%E7%94%A8%E3%80%82%5Cnclass%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%20%20%20%20%23%20__str__%20%E6%96%B9%E6%B3%95%EF%BC%8C%E6%89%A7%E8%A1%8C%E6%97%B6%E6%9C%BA%EF%BC%9A%E5%BD%93%E8%B0%83%E7%94%A8%20print(%E5%AF%B9%E8%B1%A1)%E6%88%96str(%E5%AF%B9%E8%B1%A1)%20%E6%97%B6%5Cn%20%20%20%20def%20__str__(self)%3A%5Cn%20%20%20%20%20%20%20%20return%20f'%E5%A7%93%E5%90%8D%EF%BC%9A%7Bself.name%7D%EF%BC%8C%20%E5%B9%B4%E9%BE%84%EF%BC%9A%7Bself.age%7D%EF%BC%8C%20%E6%80%A7%E5%88%AB%EF%BC%9A%7Bself.gender%7D'%5Cn%5Cn%20%20%20%20%23%20__len__%20%E6%96%B9%E6%B3%95%EF%BC%8C%E6%89%A7%E8%A1%8C%E6%97%B6%E6%9C%BA%EF%BC%9A%E5%BD%93%E8%B0%83%E7%94%A8len(%E5%AF%B9%E8%B1%A1)%E6%97%B6%5Cn%20%20%20%20def%20__len__(self)%3A%5Cn%20%20%20%20%20%20%20%20return%20len(self.__dict__)%5Cn%5Cn%20%20%20%20%23%20__lt__%E6%96%B9%E6%B3%95%EF%BC%8C%E6%89%A7%E8%A1%8C%E6%97%B6%E6%9C%BA%EF%BC%9A%E5%BD%93%E6%89%A7%E8%A1%8C%20%E5%AF%B9%E8%B1%A11%20%3C%20%E5%AF%B9%E8%B1%A12%20%E6%97%B6%5Cn%20%20%20%20def%20__lt__(self%2C%20other)%3A%5Cn%20%20%20%20%20%20%20%20return%20self.age%20%3C%20other.age%5Cn%5Cn%20%20%20%20%23%20__gt__%E6%96%B9%E6%B3%95%EF%BC%8C%E6%89%A7%E8%A1%8C%E6%97%B6%E6%9C%BA%EF%BC%9A%E5%BD%93%E6%89%A7%E8%A1%8C%20%E5%AF%B9%E8%B1%A11%20%3E%20%E5%AF%B9%E8%B1%A12%20%E6%97%B6%5Cn%20%20%20%20def%20__gt__(self%2C%20other)%3A%5Cn%20%20%20%20%20%20%20%20return%20self.age%20%3E%20other.age%5Cn%5Cn%20%20%20%20%23%20__eq__%E6%96%B9%E6%B3%95%EF%BC%8C%E6%89%A7%E8%A1%8C%E6%97%B6%E6%9C%BA%EF%BC%9A%E5%BD%93%E6%89%A7%E8%A1%8C%20%E5%AF%B9%E8%B1%A11%20%3D%3D%20%E5%AF%B9%E8%B1%A12%20%E6%97%B6%5Cn%20%20%20%20def%20__eq__(self%2C%20other)%3A%5Cn%20%20%20%20%20%20%20%20return%20self.__dict__%20%3D%3D%20other.__dict__%5Cn%5Cn%20%20%20%20%23%20__getattr__%E6%96%B9%E6%B3%95%EF%BC%8C%E6%89%A7%E8%A1%8C%E6%97%B6%E6%9C%BA%EF%BC%9A%E5%BD%93%E8%AE%BF%E9%97%AE%E4%BA%86%E5%AF%B9%E8%B1%A1%E4%B8%8D%E5%AD%98%E5%9C%A8%E7%9A%84%E5%B1%9E%E6%80%A7%E6%97%B6%5Cn%20%20%20%20def%20__getattr__(self%2C%20item)%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E6%82%A8%E8%AE%BF%E9%97%AE%E7%9A%84%7Bitem%7D%E5%B1%9E%E6%80%A7%EF%BC%8C%E4%B8%8D%E5%AD%98%E5%9C%A8%EF%BC%81')%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BAPerson%E5%AE%9E%E4%BE%8B%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnp2%20%3D%20Person('%E6%9D%8E%E5%9B%9B'%2C%2022%2C%20'%E5%A5%B3')%5Cn%5Cn%23%20%E6%B5%8B%E8%AF%95%E4%BB%A3%E7%A0%81%5Cnprint(p1)%5Cnprint(str(p1))%5Cnprint(len(p1))%5Cnprint(p1%20%3C%20p2)%5Cnprint(p1%20%3E%20p2)%5Cnprint(p1%20%3D%3D%20p2)%5Cnprint(p1.address)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22sdD9M%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="FV5WT" id="FV5WT" data-lake-index-type="2"><span data-lake-id="u3cfb7a40" id="u3cfb7a40">object 类</span></h2><ul list="u2785c5f4"><li fid="u0f3145a7" data-lake-id="u2e9775ad" id="u2e9775ad"><code data-lake-id="ucfd4658b" id="ucfd4658b"><span data-lake-id="ua6d5105b" id="ua6d5105b">object</span></code><span data-lake-id="u248adbe6" id="u248adbe6">是所有类的最终祖先，所有的类，无论写与不写，都继承自</span><code data-lake-id="u1cf8e166" id="u1cf8e166"><span data-lake-id="u198b47a7" id="u198b47a7">object</span></code><span data-lake-id="u2baab500" id="u2baab500">。</span></li><li fid="u0f3145a7" data-lake-id="uad6bc989" id="uad6bc989"><code data-lake-id="uf6fa6e9a" id="uf6fa6e9a"><span data-lake-id="u549ce0eb" id="u549ce0eb">object</span></code><span data-lake-id="ufef872c5" id="ufef872c5">提供了所有对象都会有的一组最基本方法，例如：</span></li></ul><table data-lake-id="Y72hK" id="Y72hK" margin="true" row-head="#074A92;#FFFFFF" fit-width="true" hindent="2em" class="lake-table" style="width: 577px"><colgroup><col width="202"><col width="375"></colgroup><tbody><tr data-lake-id="ue117e584" id="ue117e584"><td data-lake-id="ue46688dd" id="ue46688dd"><p data-lake-id="u04e5ef62" id="u04e5ef62" style="text-align: center"><span data-lake-id="ud8a0ef0f" id="ud8a0ef0f">方法名</span></p></td><td data-lake-id="u4aba45f0" id="u4aba45f0"><p data-lake-id="ue3753ddc" id="ue3753ddc" style="text-align: center"><span data-lake-id="u56a5e3c3" id="u56a5e3c3">作用简述</span></p></td></tr><tr data-lake-id="u244a46f2" id="u244a46f2" style="height: 38px"><td data-lake-id="ua39c3bd8" id="ua39c3bd8"><p data-lake-id="u34f4098e" id="u34f4098e"><code data-lake-id="u77a79861" id="u77a79861"><span data-lake-id="u5959994d" id="u5959994d">__init__(self)</span></code></p></td><td data-lake-id="u1d1e2ddc" id="u1d1e2ddc"><p data-lake-id="uf0e5c8b2" id="uf0e5c8b2"><span data-lake-id="ub1ade60f" id="ub1ade60f">在对实例对象初始化时调用</span></p></td></tr><tr data-lake-id="u0e731b5d" id="u0e731b5d"><td data-lake-id="uc224e835" id="uc224e835"><p data-lake-id="u5259dbb9" id="u5259dbb9"><code data-lake-id="u6876db07" id="u6876db07"><span data-lake-id="ucd986c31" id="ucd986c31">__str__(self)</span></code></p></td><td data-lake-id="uaec9525b" id="uaec9525b"><p data-lake-id="ue6d675b6" id="ue6d675b6"><code data-lake-id="uab9bed5c" id="uab9bed5c"><span data-lake-id="ud2490c52" id="ud2490c52">print(obj)</span></code><span data-lake-id="ub6dee8ff" id="ub6dee8ff">或 </span><code data-lake-id="u076ae233" id="u076ae233"><span data-lake-id="uc9baa300" id="uc9baa300">int(obj)</span></code><span data-lake-id="udd08f461" id="udd08f461">时调用</span></p></td></tr><tr data-lake-id="u3b0229cc" id="u3b0229cc"><td data-lake-id="u8efaa571" id="u8efaa571"><p data-lake-id="uc4b5eb80" id="uc4b5eb80"><code data-lake-id="u00c976e4" id="u00c976e4"><span data-lake-id="u33258ecc" id="u33258ecc">__class__</span></code></p></td><td data-lake-id="u632f8d0f" id="u632f8d0f"><p data-lake-id="ua5f5d61b" id="ua5f5d61b"><span data-lake-id="u9a32ab7c" id="u9a32ab7c">返回对象所属的类</span></p></td></tr><tr data-lake-id="uffc241a4" id="uffc241a4"><td data-lake-id="ue1c364a5" id="ue1c364a5" colSpan="2"><p data-lake-id="uaad0f428" id="uaad0f428" style="text-align: center"><span data-lake-id="u42ac024b" id="u42ac024b">......</span></p></td></tr></tbody></table><blockquote data-lake-id="ue2f0a372" id="ue2f0a372" hindent="2em" class="lake-alert lake-alert-tips"><p data-lake-id="u718aa6d7" id="u718aa6d7"><span data-lake-id="u99c8c138" id="u99c8c138">备注：上述这些方法，如果我们不去重写，Python 会自动继承并使用默认版本。</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20Python%20%E4%B8%AD%EF%BC%8C%E6%89%80%E6%9C%89%E7%9A%84%E7%B1%BB%E9%83%BD%E7%BB%A7%E6%89%BF%E4%BA%86%20object%20%E7%B1%BB%EF%BC%8C%E5%8D%B3%EF%BC%9Aobject%20%E7%B1%BB%E6%98%AF%E6%89%80%E6%9C%89%E7%B1%BB%E7%9A%84%E9%A1%B6%E5%B1%82%E7%88%B6%E7%B1%BB%E3%80%82%5Cnclass%20Person%3A%5Cn%20%20%20%20def%20__init__(self%2C%20name%2C%20age%2C%20gender)%3A%5Cn%20%20%20%20%20%20%20%20self.name%20%3D%20name%5Cn%20%20%20%20%20%20%20%20self.age%20%3D%20age%5Cn%20%20%20%20%20%20%20%20self.gender%20%3D%20gender%5Cn%5Cn%23%20%E9%AA%8C%E8%AF%81%E4%B8%80%E4%B8%8B%EF%BC%9A%E6%89%80%E6%9C%89%E7%9A%84%E7%B1%BB%E9%83%BD%E7%BB%A7%E6%89%BF%E4%BA%86%20object%20%E7%B1%BB%5Cnprint(issubclass(Person%2C%20object))%5Cnprint(issubclass(int%2C%20object))%5Cnprint(issubclass(str%2C%20object))%5Cnprint(issubclass(list%2C%20object))%5Cnprint(issubclass(tuple%2C%20object))%5Cnprint(issubclass(bool%2C%20object))%5Cn%5Cn%23%20%E5%9B%A0%E4%B8%BA%20object%20%E6%98%AF%E6%89%80%E6%9C%89%E7%B1%BB%E7%9A%84%E7%88%B6%E7%B1%BB%EF%BC%8C%E6%89%80%E4%BB%A5%20Python%20%E4%B8%AD%E7%9A%84%E6%89%80%E6%9C%89%E5%AF%B9%E8%B1%A1%EF%BC%8C%E9%83%BD%E9%97%B4%E6%8E%A5%E6%98%AF%20object%20%E7%B1%BB%E7%9A%84%E5%AE%9E%E4%BE%8B%E3%80%82%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnprint(isinstance(p1%2C%20object))%5Cnprint(isinstance(100%2C%20object))%5Cnprint(isinstance('hello'%2C%20object))%5Cnprint(isinstance(True%2C%20object))%5Cnprint(isinstance(None%2C%20object))%5Cnprint(isinstance(%5B10%2C%2020%2C%2030%5D%2C%20object))%5Cnprint(isinstance(%7B'%E5%90%83%E9%A5%AD'%2C'%E7%9D%A1%E8%A7%89'%7D%2C%20object))%5Cn%5Cn%23%20%E6%89%80%E6%9C%89%E5%AF%B9%E8%B1%A1%E9%83%BD%E7%BB%A7%E6%89%BF%E4%BA%86%20object%20%E7%B1%BB%E6%89%80%E6%8F%90%E4%BE%9B%E7%9A%84%EF%BC%9A%E5%90%84%E7%A7%8D%E5%B1%9E%E6%80%A7%E5%92%8C%E6%96%B9%E6%B3%95%EF%BC%8C%E4%BB%8E%E8%80%8C%E4%BF%9D%E8%AF%81%E6%AF%8F%E4%B8%AA%E5%AF%B9%E8%B1%A1%E9%83%BD%E5%85%B7%E5%A4%87%E7%BB%9F%E4%B8%80%E7%9A%84%E5%9F%BA%E6%9C%AC%E8%83%BD%E5%8A%9B%E3%80%82%5Cnfor%20key%20in%20object.__dict__%3A%5Cn%20%20%20%20print(key)%5Cn%5Cnp1%20%3D%20Person('%E5%BC%A0%E4%B8%89'%2C%2018%2C%20'%E7%94%B7')%5Cnprint(p1.__dict__)%20%20%23%20%E6%89%93%E5%8D%B0%E5%AF%B9%E8%B1%A1%E8%87%AA%E5%B7%B1%E8%BA%AB%E4%B8%8A%E7%9A%84%E4%B8%9C%E8%A5%BF%5Cnprint(dir(p1))%20%20%20%20%20%20%23%20%E6%89%93%E5%8D%B0%E5%AF%B9%E8%B1%A1%E8%83%BD%E8%AE%BF%E9%97%AE%E5%88%B0%E7%9A%84%E4%B8%9C%E8%A5%BF%5Cn%5Cnprint(p1.__str__())%5Cnprint(p1)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22QsjHe%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h2 data-lake-id="ByeRi" id="ByeRi" data-lake-index-type="2"><span data-lake-id="u7ba03f3d" id="u7ba03f3d">多态</span></h2><h3 data-lake-id="XeDUs" id="XeDUs" data-lake-index-type="2"><span data-lake-id="u7c2f56ab" id="u7c2f56ab">何为多态</span></h3><p data-lake-id="u27e8e947" id="u27e8e947" style="text-indent: 2em"><span data-lake-id="u95c4252d" id="u95c4252d">多态就是“多种形态”，即：不同的对象调使用同一个方法名调用方法时，会表现出不同的行为。</span></p><h3 data-lake-id="jIyaT" id="jIyaT" data-lake-index-type="2"><span data-lake-id="u592db7d1" id="u592db7d1">标准多态</span></h3><blockquote data-lake-id="ue02f6a1a" id="ue02f6a1a" class="lake-alert lake-alert-info"><ul list="u77bef63e"><li fid="u0362b9e3" data-lake-id="u0cb9c4a4" id="u0cb9c4a4"><strong><span data-lake-id="ub8e389a4" id="ub8e389a4">​</span></strong><span data-lake-id="uf71bcedf" id="uf71bcedf">基于继承实现多态，又叫：『传统多态』或『标准多态』。</span></li><li fid="u0362b9e3" data-lake-id="u3ddd9650" id="u3ddd9650"><span data-lake-id="u6d162757" id="u6d162757">常见于</span><code data-lake-id="ub337fe64" id="ub337fe64"><span data-lake-id="ud7f1020b" id="ud7f1020b">Java</span></code><span data-lake-id="ue5656c60" id="ue5656c60">、</span><code data-lake-id="ue01f09b9" id="ue01f09b9"><span data-lake-id="udb8395e7" id="udb8395e7">C++</span></code><span data-lake-id="u4e1d3fd6" id="u4e1d3fd6"> 这样的强类型语言中，</span><code data-lake-id="ue0377d26" id="ue0377d26"><span data-lake-id="u70ccb23a" id="u70ccb23a">Python</span></code><span data-lake-id="u4e28785e" id="u4e28785e">支持『标准多态』。</span></li></ul></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E6%A0%87%E5%87%86%E5%A4%9A%E6%80%81%EF%BC%88%E5%9F%BA%E4%BA%8E%E7%BB%A7%E6%89%BF%E3%80%81%E6%96%B9%E6%B3%95%E9%87%8D%E5%86%99%E6%9D%A5%E5%AE%9E%E7%8E%B0%EF%BC%89%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E5%A4%9A%E6%80%81%E6%98%AF%E6%8C%87%EF%BC%9A%E5%90%8C%E4%B8%80%E4%B8%AA%E6%96%B9%E6%B3%95%E5%90%8D%EF%BC%8C%E5%9C%A8%E4%B8%8D%E5%90%8C%E7%9A%84%E5%AF%B9%E8%B1%A1%E4%B8%8A%E8%B0%83%E7%94%A8%E6%97%B6%EF%BC%8C%E8%83%BD%E5%91%88%E7%8E%B0%E5%87%BA%E4%B8%8D%E5%90%8C%E7%9A%84%E8%A1%8C%E4%B8%BA%E3%80%82%5Cn%23%20Python%E4%B8%AD%E6%94%AF%E6%8C%81%EF%BC%9A%E6%A0%87%E5%87%86%E5%A4%9A%E6%80%81%E3%80%81%E9%B8%AD%E5%AD%90%E5%A4%9A%E6%80%81%5Cn%5Cn%23%20%E6%A0%87%E5%87%86%E5%A4%9A%E6%80%81%EF%BC%9A%5Cnclass%20Animal%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E5%8A%A8%E7%89%A9%E6%AD%A3%E5%9C%A8%E5%8F%91%E5%87%BA%E5%A3%B0%E9%9F%B3')%5Cn%5Cnclass%20Dog(Animal)%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E6%B1%AA%E6%B1%AA%E6%B1%AA%EF%BC%81')%5Cn%5Cnclass%20Cat(Animal)%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E5%96%B5%E5%96%B5%E5%96%B5%EF%BC%81')%5Cn%5Cn%23%20%E6%B3%A8%E6%84%8FPig%E7%B1%BB%E6%B2%A1%E6%9C%89%E7%BB%A7%E6%89%BFAnimal%E7%B1%BB%5Cnclass%20Pig%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E5%93%BC%E5%93%BC%E5%93%BC%EF%BC%81')%5Cn%5Cn%23%20make_sound%E5%87%BD%E6%95%B0%E8%A6%81%E6%B1%82%EF%BC%9A%E4%BC%A0%E5%85%A5%E7%9A%84%E5%AF%B9%E8%B1%A1%EF%BC%8C%E5%BF%85%E9%A1%BB%E6%98%AF%20Animal%20%E7%B1%BB%E5%9E%8B%EF%BC%88%E6%88%96%E5%85%B6%E5%AD%90%E7%B1%BB%E5%9E%8B%EF%BC%89%EF%BC%8C%E6%89%8D%E8%83%BD%E4%BF%9D%E8%AF%81%E5%8F%AF%E4%BB%A5%E8%B0%83%E7%94%A8%E5%88%B0sepak%E6%96%B9%E6%B3%95%5Cndef%20make_sound(animal%3AAnimal)%3A%5Cn%20%20%20%20animal.speak()%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BA%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cna1%20%3D%20Animal()%5Cnd1%20%3D%20Dog()%5Cnc1%20%3D%20Cat()%5Cn%5Cn%23%20%E5%A4%9A%E6%80%81%E7%9A%84%E4%BD%93%E7%8E%B0%EF%BC%9A%E5%90%8C%E4%B8%80%E5%87%BD%E6%95%B0%EF%BC%8C%E4%B8%8D%E5%90%8C%E5%AF%B9%E8%B1%A1%20%E2%86%92%20%E4%B8%8D%E5%90%8C%E8%A1%8C%E4%B8%BA%5Cnmake_sound(a1)%20%20%23%20%E5%8A%A8%E7%89%A9%E6%AD%A3%E5%9C%A8%E5%8F%91%E5%87%BA%E5%A3%B0%E9%9F%B3%5Cnmake_sound(d1)%20%20%23%20%E6%B1%AA%E6%B1%AA%E6%B1%AA%EF%BC%81%5Cnmake_sound(c1)%20%20%23%20%E5%96%B5%E5%96%B5%E5%96%B5%EF%BC%81%5Cn%5Cn%23%20%E6%8C%89%E6%A0%87%E5%87%86%E5%A4%9A%E6%80%81%E8%A7%84%E5%88%99%EF%BC%9APig%20%E6%B2%A1%E6%9C%89%E7%BB%A7%E6%89%BF%20Animal%EF%BC%8C%E7%B1%BB%E5%9E%8B%E4%B8%8D%E5%8C%B9%E9%85%8D%EF%BC%88%E4%BC%9A%E5%87%BA%E7%8E%B0%E7%B1%BB%E5%9E%8B%E8%AD%A6%E5%91%8A%EF%BC%89%5Cnp1%20%3D%20Pig()%5Cnmake_sound(p1)%20%20%23%20%E5%9C%A8%E5%85%B6%E5%AE%83%E8%AF%AD%E8%A8%80%E4%B8%AD%E4%BC%9A%E6%8A%A5%E9%94%99%EF%BC%8C%E8%99%BD%E7%84%B6%20Python%20%E4%B8%AD%E8%83%BD%E8%BF%90%E8%A1%8C%EF%BC%8C%E4%BD%86%E8%BF%99%E4%B8%8D%E5%B1%9E%E4%BA%8E%E6%A0%87%E5%87%86%E5%A4%9A%E6%80%81%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E6%A0%87%E5%87%86%E5%A4%9A%E6%80%81%EF%BC%88%E5%9F%BA%E4%BA%8E%E7%BB%A7%E6%89%BF%E3%80%81%E6%96%B9%E6%B3%95%E9%87%8D%E5%86%99%E6%9D%A5%E5%AE%9E%E7%8E%B0%EF%BC%89%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22reJCI%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="z1CRk" id="z1CRk" data-lake-index-type="2"><span data-lake-id="u64e33f04" id="u64e33f04">鸭子多态</span></h3><blockquote data-lake-id="u17afaf70" id="u17afaf70"><p data-lake-id="u4dc23277" id="u4dc23277"><span data-lake-id="uea0adae8" id="uea0adae8">鸭子类型：如果一个东西看起来像鸭子，叫起来也像鸭子，那它就是鸭子，鸭子类型指一种编程风格，它并不依靠查找对象类型，来确定其是否具有正确的实现，而是直接调用或使用其方法或属性。</span></p><p data-lake-id="u82a46d5e" id="u82a46d5e"><span data-lake-id="uc5370423" id="uc5370423">官方文档地址：</span><a href="https://docs.python.org/zh-cn/3.13/glossary.html#term-duck-typing" target="_blank" data-lake-id="ua4cfd947" id="ua4cfd947"><span data-lake-id="ufa21a648" id="ufa21a648">https://docs.python.org/zh-cn/3.13/glossary.html#term-duck-typing</span></a></p></blockquote><blockquote data-lake-id="u29e61dc9" id="u29e61dc9" class="lake-alert lake-alert-info"><ul list="ud029c818"><li fid="ud9a5916a" data-lake-id="ua08376cc" id="ua08376cc"><span data-lake-id="ud7788ddb" id="ud7788ddb">特点：不需要继承，只要传进来的对象，有对应实现就可以。</span></li><li fid="ud9a5916a" data-lake-id="udab5147c" id="udab5147c"><span data-lake-id="u858aa4c4" id="u858aa4c4">Python 中支持“鸭子多态”。</span></li></ul></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E9%B8%AD%E5%AD%90%E7%B1%BB%E5%9E%8B%E5%A4%9A%E6%80%81%EF%BC%88%E4%B8%8D%E5%9F%BA%E4%BA%8E%E7%BB%A7%E6%89%BF%EF%BC%89%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E6%A0%B8%E5%BF%83%E7%90%86%E5%BF%B5%EF%BC%9A%E5%A6%82%E6%9E%9C%E4%B8%80%E4%B8%AA%E4%B8%9C%E8%A5%BF%E7%9C%8B%E8%B5%B7%E6%9D%A5%E5%83%8F%E9%B8%AD%E5%AD%90%EF%BC%8C%E5%8F%AB%E8%B5%B7%E6%9D%A5%E4%B9%9F%E5%83%8F%E9%B8%AD%E5%AD%90%EF%BC%8C%E9%82%A3%E5%AE%83%E5%B0%B1%E6%98%AF%E9%B8%AD%E5%AD%90%E3%80%82%5Cn%23%20%E9%B8%AD%E5%AD%90%E7%B1%BB%E5%9E%8B%E6%98%AF%E4%B8%80%E7%A7%8D%E7%BC%96%E7%A8%8B%E9%A3%8E%E6%A0%BC%EF%BC%8C%E5%AE%83%E4%B8%8D%E6%A3%80%E6%9F%A5%E5%AF%B9%E8%B1%A1%E7%9A%84%E7%B1%BB%E5%9E%8B%EF%BC%8C%E5%8F%AA%E5%85%B3%E6%B3%A8%E5%AF%B9%E8%B1%A1%E8%83%BD%E5%90%A6%E2%80%9C%E5%81%9A%E6%9F%90%E4%BB%B6%E4%BA%8B%E2%80%9D%EF%BC%88%E6%98%AF%E5%90%A6%E6%9C%89%E5%AF%B9%E5%BA%94%E7%9A%84%E6%96%B9%E6%B3%95%EF%BC%89%E3%80%82%5Cn%5Cnclass%20Dog%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E6%B1%AA%E6%B1%AA%E6%B1%AA%EF%BC%81')%5Cn%5Cnclass%20Cat%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E5%96%B5%E5%96%B5%E5%96%B5%EF%BC%81')%5Cn%5Cnclass%20Pig%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E5%93%BC%E5%93%BC%E5%93%BC%EF%BC%81')%5Cn%5Cnclass%20Fish%3A%5Cn%20%20%20%20def%20speak(self)%3A%5Cn%20%20%20%20%20%20%20%20print('%E5%92%95%E5%99%9C%E5%99%9C%EF%BC%81')%5Cn%5Cn%23%20%E4%B8%8D%E5%86%8D%E5%AF%B9animal%E7%9A%84%E7%B1%BB%E5%9E%8B%E5%81%9A%E9%99%90%E5%88%B6%EF%BC%8Canimal%E5%8F%AF%E4%BB%A5%E6%98%AF%E4%BB%BB%E4%BD%95%E7%B1%BB%E5%9E%8B%EF%BC%8C%E5%8F%AA%E8%A6%81%E8%83%BD%E8%B0%83%E7%94%A8speak%E6%96%B9%E6%B3%95%E5%B0%B1%E5%8F%AF%E4%BB%A5%5Cndef%20make_sound(animal)%3A%5Cn%20%20%20%20animal.speak()%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BA%E5%AE%9E%E4%BE%8B%E5%AF%B9%E8%B1%A1%5Cnd1%20%3D%20Dog()%5Cnc1%20%3D%20Cat()%5Cnp1%20%3D%20Pig()%5Cnf1%20%3D%20Fish()%5Cn%5Cnmake_sound(d1)%5Cnmake_sound(c1)%5Cnmake_sound(p1)%5Cnmake_sound(f1)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22%E9%B8%AD%E5%AD%90%E7%B1%BB%E5%9E%8B%E5%A4%9A%E6%80%81%EF%BC%88%E4%B8%8D%E5%9F%BA%E4%BA%8E%E7%BB%A7%E6%89%BF%EF%BC%89%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22kXhva%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="F5Mli" id="F5Mli" data-lake-index-type="2"><span data-lake-id="u5a9869e7" id="u5a9869e7">抽象类</span></h2><ul list="ua293eaa1"><li fid="ue34f088a" data-lake-id="ucde9d7f1" id="ucde9d7f1"><strong><span data-lake-id="u89c03da5" id="u89c03da5">概念：</span></strong><span data-lake-id="u19bb1e8b" id="u19bb1e8b">抽象类（Abstract Class） 是一种 不能被直接实例化 的类，通常作为“规范”，让子类去继承并实现其中定义的抽象方法，本身只定义规范，不需要提供完整实现。</span></li><li fid="ue34f088a" data-lake-id="uc31ed926" id="uc31ed926"><strong><span data-lake-id="u7a30f9d5" id="u7a30f9d5">例如：</span></strong><span data-lake-id="u0c377b52" id="u0c377b52">动物会叫、飞行器会飞、支付方式会支付。</span></li></ul><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22from%20abc%20import%20ABC%2C%20abstractmethod%5Cn%5Cn%23%E3%80%90%E6%8A%BD%E8%B1%A1%E7%B1%BB%E3%80%91%E6%98%AF%E4%B8%80%E7%A7%8D%E4%B8%8D%E8%83%BD%E7%9B%B4%E6%8E%A5%E5%AE%9E%E4%BE%8B%E5%8C%96%E7%9A%84%E7%B1%BB%EF%BC%8C%E5%AE%83%E9%80%9A%E5%B8%B8%E4%BD%9C%E4%B8%BA%E2%80%9C%E8%A7%84%E8%8C%83%E2%80%9D%EF%BC%8C%E8%AE%A