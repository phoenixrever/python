5Cn%23%20%E4%BD%BF%E7%94%A8%E5%AE%89%E8%A3%85%E5%9C%A8%E5%BD%93%E5%89%8D%E8%99%9A%E6%8B%9F%E7%8E%AF%E5%A2%83%E4%B8%AD%E7%9A%84%E7%AC%AC%E4%B8%89%E6%96%B9%E5%8C%85cn2an%5Cnimport%20cn2an%5Cnprint(cn2an.cn2an('%E4%B9%9D%E5%8D%83%E4%B8%83%E7%99%BE%E5%9B%9B%E5%8D%81%E4%B8%89'))%5Cn%5Cn%5Cn%23%20%E4%BD%BF%E7%94%A8%E5%85%A8%E5%B1%80%E7%9A%84%E6%A0%87%E5%87%86%E5%BA%93%5Cnfrom%20collections%20import%20Counter%5Cnlist1%20%3D%20%5B10%2C%2020%2C%2030%2C%2040%2C%2020%2C%2030%2C%2020%2C%2030%2C%2010%2C%2010%2C%2010%5D%5Cnres%20%3D%20Counter(list1)%5Cnprint(res)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22DC7cB%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u947f7ab5" id="u947f7ab5"><span data-lake-id="u0b7dcc64" id="u0b7dcc64">结论：基于虚拟环境的项目，可以使用：虚拟环境中的第三方包，也可以使用全局的标准库。</span></p><h1 data-lake-id="o98ka" id="o98ka"><span data-lake-id="uf06ef766" id="uf06ef766">第 11 章 迭代器 vs 生成器</span></h1><h2 data-lake-id="CAnpo" id="CAnpo" data-lake-index-type="2"><span data-lake-id="u6c97bfe1" id="u6c97bfe1">迭代器</span></h2><p data-lake-id="u0c1a1f71" id="u0c1a1f71"><span data-lake-id="u118cf3e7" id="u118cf3e7">先区分两个概念：可迭代对象（iterable）、迭代器（iterator）</span></p><h3 data-lake-id="rPSwZ" id="rPSwZ"><span data-lake-id="uec743939" id="uec743939">1️⃣</span><span data-lake-id="udabf0cd4" id="udabf0cd4">可迭代对象（iterable）</span></h3><p data-lake-id="u066ee29f" id="u066ee29f"><span data-lake-id="uc6e765fd" id="uc6e765fd">概念：能被 for 循环遍历的对象，就是可迭代对象（iterable）</span></p><p data-lake-id="u315ad24a" id="u315ad24a"><span data-lake-id="u0a8c9354" id="u0a8c9354">如下这些都是可迭代对象（iterable）：</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cncitys%20%3D%20('%E5%8C%97%E4%BA%AC'%2C%20'%E4%B8%8A%E6%B5%B7'%2C%20'%E6%B7%B1%E5%9C%B3')%5Cnmsg%20%3D%20'hello'%5Cn%5Cnfor%20item%20in%20names%3A%5Cn%20%20%20%20print(item)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22wOm0U%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u952cd3b0" id="u952cd3b0"><span data-lake-id="u6ad7499e" id="u6ad7499e">如下这些不是可迭代对象（iterable）：</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22age%20%3D%2010%5Cndef%20test()%3A%5Cn%20%20%20%20pass%5Cn%5Cnfor%20item%20in%20test%3A%5Cn%20%20%20%20print(item)%5Cnendregion%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22sbP3q%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="ud1cc8d7b" id="ud1cc8d7b"><span data-lake-id="u772c4999" id="u772c4999">可迭代对象都拥有</span><code data-lake-id="ubeefa878" id="ubeefa878"><span data-lake-id="u4b178ab4" id="u4b178ab4">__iter__</span></code><span data-lake-id="ua5ef9cdf" id="ua5ef9cdf">方法。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cncitys%20%3D%20('%E5%8C%97%E4%BA%AC'%2C%20'%E4%B8%8A%E6%B5%B7'%2C%20'%E6%B7%B1%E5%9C%B3')%5Cnmsg%20%3D%20'hello'%5Cnage%20%3D%2010%5Cndef%20test()%3A%5Cn%20%20%20%20pass%5Cn%5Cnnames.__iter__()%5Cncitys.__iter__()%5Cnmsg.__iter__()%5Cn%5Cnprint(hasattr(names%2C%20'__iter__'))%5Cnprint(hasattr(citys%2C%20'__iter__'))%5Cnprint(hasattr(msg%2C%20'__iter__'))%5Cnprint(hasattr(age%2C%20'__iter__'))%5Cnprint(hasattr(test%2C%20'__iter__'))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22JWASD%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="Q1sjt" id="Q1sjt"><span data-lake-id="uca50e42b" id="uca50e42b">2️⃣</span><span data-lake-id="ua8459130" id="ua8459130">迭代器（iterator）</span></h3><p data-lake-id="ube903eee" id="ube903eee"><span data-lake-id="u7f83eb6d" id="u7f83eb6d">调用</span><code data-lake-id="udd6a1b71" id="udd6a1b71"><span data-lake-id="u6a12c2f5" id="u6a12c2f5">__iter__</span></code><span data-lake-id="uc38537aa" id="uc38537aa">方法会得到：迭代器(iterator)</span></p><ul list="u57ea4ece"><li fid="uec7e6992" data-lake-id="u6d75fbbb" id="u6d75fbbb"><span data-lake-id="u5e741f10" id="u5e741f10">备注1：</span><code data-lake-id="ub932c85c" id="ub932c85c"><span data-lake-id="ucd785395" id="ucd785395">__iter__</span></code><span data-lake-id="u9f5ea5b3" id="u9f5ea5b3">是一个魔法方法，当调用</span><code data-lake-id="uf0ee56c2" id="uf0ee56c2"><span data-lake-id="u48214f8c" id="u48214f8c">iter</span></code><span data-lake-id="u63d0b57e" id="u63d0b57e">函数时，</span><code data-lake-id="u68fcc6ea" id="u68fcc6ea"><span data-lake-id="u4b205a03" id="u4b205a03">__iter__</span></code><span data-lake-id="uee009689" id="uee009689">会自动调用。</span></li><li fid="uec7e6992" data-lake-id="u81e36d4b" id="u81e36d4b"><span data-lake-id="u254d0191" id="u254d0191">备注2：</span><code data-lake-id="u51e09d2a" id="u51e09d2a"><span data-lake-id="uee35a53b" id="uee35a53b">可迭代对象.__iter__()</span></code><span data-lake-id="u1678572b" id="u1678572b">  等价于： </span><code data-lake-id="u85d05fd2" id="u85d05fd2"><span data-lake-id="u571942d0" id="u571942d0">iter(可迭代对象)</span></code><span data-lake-id="ud6437551" id="ud6437551">。</span></li><li fid="uec7e6992" data-lake-id="u0ee06dee" id="u0ee06dee"><span data-lake-id="u3707cdc9" id="u3707cdc9">备注3：如果</span><code data-lake-id="u4f0d5243" id="u4f0d5243"><span data-lake-id="ue5a0e935" id="ue5a0e935">iter(obj)</span></code><span data-lake-id="u437517bf" id="u437517bf">能得到一个迭代器(iterator)，那</span><code data-lake-id="u4db9a698" id="u4db9a698"><span data-lake-id="uaf80aa53" id="uaf80aa53">obj</span></code><span data-lake-id="udec730af" id="udec730af">就是可迭代对象。</span></li></ul><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cncitys%20%3D%20('%E5%8C%97%E4%BA%AC'%2C%20'%E4%B8%8A%E6%B5%B7'%2C%20'%E6%B7%B1%E5%9C%B3')%5Cnmsg%20%3D%20'hello'%5Cn%5Cnprint(names.__iter__())%5Cnprint(citys.__iter__())%5Cnprint(msg.__iter__())%5Cn%5Cnprint(iter(names))%5Cnprint(iter(citys))%5Cnprint(iter(msg))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22hmc1R%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="uad47f631" id="uad47f631"><span data-lake-id="u0fc4475c" id="u0fc4475c">迭代器（iterator）拥有</span><code data-lake-id="u0e502520" id="u0e502520"><span data-lake-id="u2edc493b" id="u2edc493b">__next__</span></code><span data-lake-id="udeb20b93" id="udeb20b93">方法，每次调用都会根据当前的状态，返回下一个元素。</span></p><ul list="uea8a6f16"><li fid="u2579dc12" data-lake-id="u763eda87" id="u763eda87"><span data-lake-id="ud56a85ff" id="ud56a85ff">备注1：</span><code data-lake-id="u07eb9e1e" id="u07eb9e1e"><span data-lake-id="u5e8a8aa6" id="u5e8a8aa6">迭代器.__next__()</span></code><span data-lake-id="u8e50b009" id="u8e50b009"> 等价于  </span><code data-lake-id="ufef7f51c" id="ufef7f51c"><span data-lake-id="udc569d08" id="udc569d08">next(迭代器)</span></code><span data-lake-id="ud9961034" id="ud9961034">。</span></li><li fid="u2579dc12" data-lake-id="ue68892ce" id="ue68892ce"><span data-lake-id="ud0ae481f" id="ud0ae481f">备注2：当所有元素全都取出后，若继续调用</span><code data-lake-id="ufb1b1952" id="ufb1b1952"><span data-lake-id="u01f45de6" id="u01f45de6">__next__</span></code><span data-lake-id="u5146e33d" id="u5146e33d">，Python会抛出</span><code data-lake-id="u34abc570" id="u34abc570"><span data-lake-id="u72d817b5" id="u72d817b5">StopIteration</span></code><span data-lake-id="u8b17ec2b" id="u8b17ec2b">异常。</span></li></ul><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cnit%20%3D%20iter(names)%5Cnprint(it.__next__())%5Cnprint(it.__next__())%5Cnprint(it.__next__())%5Cnprint(it.__next__())%5Cn%5Cnprint(next(it))%5Cnprint(next(it))%5Cnprint(next(it))%5Cnprint(next(it))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Q3gbY%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u270035bf" id="u270035bf"><span data-lake-id="ub949addd" id="ub949addd">编写</span><code data-lake-id="ua05fe8e1" id="ua05fe8e1"><span data-lake-id="u3d49bcac" id="u3d49bcac">for</span></code><span data-lake-id="ufbacaaea" id="ufbacaaea">循环遍历</span><code data-lake-id="u06341e27" id="u06341e27"><span data-lake-id="u4bd946a7" id="u4bd946a7">names</span></code><span data-lake-id="ud531bf0d" id="ud531bf0d">列表</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%E7%BC%96%E5%86%99for%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86names%E5%88%97%E8%A1%A8%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cnfor%20item%20in%20names%3A%5Cn%20%20%20%20print(item)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%E7%BC%96%E5%86%99for%E5%BE%AA%E7%8E%AF%E9%81%8D%E5%8E%86names%E5%88%97%E8%A1%A8%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22AAqi4%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="udca55520" id="udca55520"><code data-lake-id="u37148491" id="u37148491"><span data-lake-id="uaae57247" id="uaae57247">for</span></code><span data-lake-id="u5037ed61" id="u5037ed61">循环背后的逻辑</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cn%23%201%EF%B8%8F%E2%83%A3%E8%B0%83%E7%94%A8%E3%80%90%E5%8F%AF%E8%BF%AD%E4%BB%A3%E5%AF%B9%E8%B1%A1%E7%9A%84__iter__%E6%96%B9%E6%B3%95%E3%80%91%E8%8E%B7%E5%8F%96%E5%88%B0%E4%B8%80%E4%B8%AA%E8%BF%AD%E4%BB%A3%E5%99%A8(iterator)%5Cnit%20%3D%20iter(names)%5Cn%23%202%EF%B8%8F%E2%83%A3%E5%BC%80%E5%90%AF%E4%B8%80%E4%B8%AA%E6%97%A0%E9%99%90%E5%BE%AA%E7%8E%AF%5Cnwhile%20True%3A%5Cn%20%20%20%20try%3A%5Cn%20%20%20%20%20%20%20%20%23%203%EF%B8%8F%E2%83%A3%E8%B0%83%E7%94%A8__next__%E6%96%B9%E6%B3%95%EF%BC%8C%E8%8E%B7%E5%8F%96%E4%B8%8B%E4%B8%80%E4%B8%AA%E5%85%83%E7%B4%A0%5Cn%20%20%20%20%20%20%20%20item%20%3D%20next(it)%5Cn%20%20%20%20%20%20%20%20print(item)%5Cn%20%20%20%20except%20StopIteration%3A%5Cn%20%20%20%20%20%20%20%20%23%204%EF%B8%8F%E2%83%A3%E6%8D%95%E8%8E%B7%20StopIteration%20%E5%BC%82%E5%B8%B8%EF%BC%8C%E9%9A%8F%E5%90%8E%E7%BB%93%E6%9D%9F%E5%BE%AA%E7%8E%AF%5Cn%20%20%20%20%20%20%20%20break%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22BKrzC%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="uf6cdfbec" id="uf6cdfbec"><span data-lake-id="u755fc17b" id="u755fc17b">迭代器（iterator）也拥有</span><code data-lake-id="ud77e789e" id="ud77e789e"><span data-lake-id="u4b7792e7" id="u4b7792e7">__iter__</span></code><span data-lake-id="ue83e6f0f" id="ue83e6f0f">方法，并且其返回值是迭代器自身。</span></p><blockquote data-lake-id="u296bf279" id="u296bf279"><p data-lake-id="uc5f4bdce" id="uc5f4bdce"><span data-lake-id="u45d9c590" id="u45d9c590">这么设计的原因：让 for 循环也能遍历迭代器（即：为了让 iter(迭代器) 不出错）。</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cn%5Cnit%20%3D%20iter(names)%5Cnprint(it)%5Cn%5Cnresult%20%3D%20iter(it)%5Cnprint(result)%5Cn%5Cnx%20%3D%20iter(result)%5Cnprint(x)%5Cn%5Cnit%20%3D%20iter(names)%5Cnfor%20item%20in%20it%3A%5Cn%20%20%20%20print(item)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22GGgcx%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><blockquote data-lake-id="u3f6b8228" id="u3f6b8228" class="lake-alert lake-alert-info"><p data-lake-id="ub35f0b1f" id="ub35f0b1f"><span data-lake-id="u0de2e28b" id="u0de2e28b">迭代器协议：一个对象如果同时满足如下规范，那该对象就是一个迭代器：</span></p><ol list="u403101ac"><li fid="uf9df8a14" data-lake-id="u84fcedc6" id="u84fcedc6"><span data-lake-id="ub2bae794" id="ub2bae794">能被</span><code data-lake-id="u78a9e3aa" id="u78a9e3aa"><span data-lake-id="uf604df1d" id="uf604df1d">iter()</span></code><span data-lake-id="u71d5ed91" id="u71d5ed91">接受。</span></li><li fid="uf9df8a14" data-lake-id="u94ab0aec" id="u94ab0aec"><span data-lake-id="ub43afb0d" id="ub43afb0d">能被</span><code data-lake-id="ue6853cab" id="ue6853cab"><span data-lake-id="uf1fa4f59" id="uf1fa4f59">next()</span></code><span data-lake-id="ua233ad10" id="ua233ad10">一步一步取值。</span></li></ol></blockquote><p data-lake-id="u72b14003" id="u72b14003"><span data-lake-id="u36fc4cd3" id="u36fc4cd3">迭代器是一次性的，状态只会向前推进，且不会自动重置（迭代器在遍历的过程中会被“消耗”）。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22names%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%5D%5Cnit1%20%3D%20iter(names)%5Cnit2%20%3D%20iter(names)%5Cn%5Cnprint(it1)%5Cnprint(it2)%5Cn%5Cnprint(next(it1))%5Cnprint(next(it1))%5Cnprint(next(it1))%5Cnprint(next(it1))%20%23%20%E6%AD%A4%E8%A1%8C%E4%BB%A3%E7%A0%81%E4%BC%9A%E6%8A%9B%E5%87%BA%E5%BC%82%E5%B8%B8%EF%BC%8C%E5%9B%A0%E4%B8%BA%E6%AD%A4%E6%97%B6%E8%BF%AD%E4%BB%A3%E5%99%A8%E5%B7%B2%E7%BB%8F%E8%A2%AB%E8%80%97%E5%B0%BD%E4%BA%86%5Cn%5Cn%23%20%E5%A6%82%E6%83%B3%E9%87%8D%E6%96%B0%E4%BE%9D%E6%AC%A1%E8%8E%B7%E5%8F%96%E5%85%83%E7%B4%A0%EF%BC%8C%E9%9C%80%E8%A6%81%E4%BD%BF%E7%94%A8%E6%96%B0%E7%9A%84%E8%BF%AD%E4%BB%A3%E5%99%A8it2%5Cnprint(next(it2))%5Cnprint(next(it2))%5Cnprint(next(it2))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22CS3gq%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="spJnC" id="spJnC"><span data-lake-id="ud318cd8c" id="ud318cd8c">3️⃣</span><span data-lake-id="u5a69c360" id="u5a69c360">迭代器的应用</span></h3><p data-lake-id="u7e0d1514" id="u7e0d1514"><span data-lake-id="u411c0a49" id="u411c0a49">需求：让</span><code data-lake-id="u2b47deb7" id="u2b47deb7"><span data-lake-id="u0d093ee7" id="u0d093ee7">for</span></code><span data-lake-id="u23368b4f" id="u23368b4f">循环可以遍历</span><code data-lake-id="uc00856e8" id="uc00856e8"><span data-lake-id="uf832fa06" id="uf832fa06">Person</span></code><span data-lake-id="uc3e5b0a6" id="uc3e5b0a6">的实例对象。</span></p><p data-lake-id="u9dda168c" id="u9dda168c"><span data-lake-id="u5bd27049" id="u5bd27049">实现方式</span><span data-lake-id="u834a6a23" id="u834a6a23">