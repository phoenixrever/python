)%5Cn%20%20%20%20elif%200%20%3C%3D%20age%20%3C%2018%3A%5Cn%20%20%20%20%20%20%20%20print('%E6%9C%AA%E6%88%90%E5%B9%B4')%5Cn%20%20%20%20else%3A%5Cn%20%20%20%20%20%20%20%20%23%20print('%E8%BE%93%E5%85%A5%E7%9A%84%E5%B9%B4%E9%BE%84%E6%9C%89%E8%AF%AF%EF%BC%81%EF%BC%88%E5%B9%B4%E9%BE%84%E5%BA%94%E8%AF%A5%E4%B8%BA0~120%E7%9A%84%E6%95%B4%E6%95%B0%EF%BC%89')%5Cn%20%20%20%20%20%20%20%20raise%20ValueError('%E5%B9%B4%E9%BE%84%E5%BA%94%E8%AF%A5%E4%B8%BA0~120%E7%9A%84%E6%95%B4%E6%95%B0')%5Cnexcept%20Exception%20as%20e%3A%5Cn%20%20%20%20print(f'%E7%A8%8B%E5%BA%8F%E5%BC%82%E5%B8%B8%EF%BC%9A%7Be%7D')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22e5lVt%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="JuGBl" id="JuGBl" data-lake-index-type="2"><span data-lake-id="u56741bc1" id="u56741bc1">异常的传递机制</span></h2><ol list="u0823e637"><li fid="u17df6a32" data-lake-id="ua1fed149" id="ua1fed149"><span data-lake-id="u3f46afb4" id="u3f46afb4">如果异常没有被当前代码块所捕获处理，那该异常就会沿着调用链，逐层传递给其调用者。</span></li><li fid="u17df6a32" data-lake-id="uceaa2deb" id="uceaa2deb"><span data-lake-id="u443e089e" id="u443e089e">如果所有调用者，都没有捕获该异常，那最终程序将因【未处理异常】而意外终止。</span></li></ol><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22def%20test1()%3A%5Cn%20%20%20%20print('******test1%E5%BC%80%E5%A7%8B******')%5Cn%20%20%20%20result%20%3D%20'100'%20%2B%20100%5Cn%20%20%20%20print('******test1%E7%BB%93%E6%9D%9F******')%5Cn%5Cndef%20test2()%3A%5Cn%20%20%20%20print('******test2%E5%BC%80%E5%A7%8B******')%5Cn%20%20%20%20try%3A%5Cn%20%20%20%20%20%20%20%20test1()%5Cn%20%20%20%20except%20Exception%20as%20e%3A%5Cn%20%20%20%20%20%20%20%20print(f'%E7%A8%8B%E5%BA%8F%E5%BC%82%E5%B8%B8%EF%BC%9A%7Be%7D')%5Cn%20%20%20%20print('******test2%E7%BB%93%E6%9D%9F******')%5Cn%5Cndef%20test3()%3A%5Cn%20%20%20%20print('******test3%E5%BC%80%E5%A7%8B******')%5Cn%20%20%20%20test2()%5Cn%20%20%20%20print('******test3%E7%BB%93%E6%9D%9F******')%5Cn%5Cntest3()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22joUx4%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="u01fa8d08" id="u01fa8d08"><span data-lake-id="uafadf66e" id="uafadf66e">执行以上代码，控制最终会输出</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22plain%22%2C%22code%22%3A%22******test3%E5%BC%80%E5%A7%8B******%5Cn******test2%E5%BC%80%E5%A7%8B******%5Cn******test1%E5%BC%80%E5%A7%8B******%5Cn%E7%A8%8B%E5%BA%8F%E5%BC%82%E5%B8%B8%EF%BC%9Acan%20only%20concatenate%20str%20(not%20%5C%22int%5C%22)%20to%20str%5Cn******test2%E7%BB%93%E6%9D%9F******%5Cn******test3%E7%BB%93%E6%9D%9F******%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22n8q4s%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="UGV0N" id="UGV0N" data-lake-index-type="2"><span data-lake-id="u0c9d17e1" id="u0c9d17e1">自定义异常类</span></h2><ol list="ubdf6d167"><li fid="ub17401d5" data-lake-id="u51f102ad" id="u51f102ad"><span data-lake-id="u2460ee37" id="u2460ee37">由开发人员自己定义一个异常类，用来表示代码中“更具体、更有业务含义”的异常。</span></li><li fid="ub17401d5" data-lake-id="ue6059dd7" id="ue6059dd7"><span data-lake-id="u0393efe8" id="u0393efe8">具体规则：定义一个类（类名通常以</span><code data-lake-id="u97b8b36e" id="u97b8b36e"><span data-lake-id="u14c7eb88" id="u14c7eb88">Error</span></code><span data-lake-id="u695fc36e" id="u695fc36e">结尾），继承</span><code data-lake-id="u853040a5" id="u853040a5"><span data-lake-id="u0ad38408" id="u0ad38408">Exception</span></code><span data-lake-id="u0fee7247" id="u0fee7247">类或它的子类。</span></li></ol><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22class%20SchoolNameError(Exception)%3A%5Cn%20%20%20%20def%20__init__(self%2C%20msg)%3A%5Cn%20%20%20%20%20%20%20%20super().__init__('%E3%80%90%E6%A0%A1%E5%90%8D%E5%BC%82%E5%B8%B8%E3%80%91'%20%2B%20msg)%5Cn%5Cndef%20check_school_name(name)%3A%5Cn%20%20%20%20if%20len(name)%20%3E%2010%3A%5Cn%20%20%20%20%20%20%20%20raise%20SchoolNameError('%E5%AD%A6%E6%A0%A1%E5%90%8D%E8%BF%87%E9%95%BF')%5Cn%20%20%20%20else%3A%5Cn%20%20%20%20%20%20%20%20print('%E5%AD%A6%E6%A0%A1%E5%90%8D%E6%98%AF%E5%90%88%E6%B3%95%E7%9A%84')%5Cn%5Cntry%3A%5Cn%20%20%20%20check_school_name('atguiguuuuuuuuuuuuuuu')%5Cnexcept%20SchoolNameError%20as%20e%3A%5Cn%20%20%20%20print(f'%E7%A8%8B%E5%BA%8F%E5%BC%82%E5%B8%B8%EF%BC%9A%7Be%7D')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22jjL8x%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h1 data-lake-id="e37ef" id="e37ef"><span data-lake-id="u1502f22a" id="u1502f22a">第 10 章 模块与包</span></h1><h2 data-lake-id="U7r5T" id="U7r5T" data-lake-index-type="2"><span data-lake-id="u6e09fc8b" id="u6e09fc8b">模块</span></h2><h3 data-lake-id="BzsKY" id="BzsKY" data-lake-index-type="2"><span data-lake-id="u5051c7ad" id="u5051c7ad">概述</span></h3><ul list="u1aa90a5b"><li fid="u343625fa" data-lake-id="u5d6d63fb" id="u5d6d63fb"><span data-lake-id="u0a83dd2c" id="u0a83dd2c">在 Python 中，一个</span><code data-lake-id="u050e93d5" id="u050e93d5"><span data-lake-id="u3dde50ad" id="u3dde50ad">.py</span></code><span data-lake-id="u3e221069" id="u3e221069">文件就是一个模块（</span><code data-lake-id="u0047007b" id="u0047007b"><span data-lake-id="u53215855" id="u53215855">Module</span></code><span data-lake-id="u5ba8b29b" id="u5ba8b29b">）。</span></li><li fid="u343625fa" data-lake-id="u679a1f26" id="u679a1f26"><span data-lake-id="u3fe1d5b7" id="u3fe1d5b7">模块中可以包含：变量、函数、类、等很多内容。</span></li><li fid="u343625fa" data-lake-id="u99a4737b" id="u99a4737b"><span data-lake-id="uc6b3cc99" id="uc6b3cc99">通常把能够实现某一特定功能的代码，集中放在一个模块中（模块就类似于一个工具箱）。</span></li><li fid="u343625fa" data-lake-id="u75a7e4d0" id="u75a7e4d0"><span data-lake-id="u1d6fea06" id="u1d6fea06">模块可以提高代码的可维护性 与 可复用性，还可以避免命名冲突。</span></li></ul><h3 data-lake-id="Gk1z7" id="Gk1z7" data-lake-index-type="2"><span data-lake-id="u16716ed5" id="u16716ed5">模块的分类</span></h3><p data-lake-id="ud7dfbbf1" id="ud7dfbbf1" style="text-indent: 2em"><span data-lake-id="u80336894" id="u80336894">Python 中的模块分为三类，分别是：标准库模块、自定义模块、第三方模块。</span></p><h3 data-lake-id="qsMYg" id="qsMYg" data-lake-index-type="2"><span data-lake-id="u353574a7" id="u353574a7">创建模块</span></h3><p data-lake-id="u0b715966" id="u0b715966" style="text-indent: 2em"><span data-lake-id="uf47046d3" id="uf47046d3">模块命名注意点：</span></p><blockquote data-lake-id="ua0f130ef" id="ua0f130ef" hindent="2em" class="lake-alert lake-alert-info"><ol list="uf1ec3fad"><li fid="u751284d1" data-lake-id="u4209b476" id="u4209b476"><span data-lake-id="u4fb22127" id="u4fb22127">要符合标识符命名规则</span></li><li fid="u751284d1" data-lake-id="uda4e69ff" id="uda4e69ff"><span data-lake-id="ub347b799" id="ub347b799">模块名（</span><code data-lake-id="ub33d382c" id="ub33d382c"><span data-lake-id="ud1108112" id="ud1108112">.py</span></code><span data-lake-id="u84ac87b8" id="u84ac87b8">文件名）区分大小写</span></li><li fid="u751284d1" data-lake-id="ue45be335" id="ue45be335"><span data-lake-id="uc4fd0662" id="uc4fd0662">不要与标准库模块同名（一旦同名，</span><code data-lake-id="ub75b355d" id="ub75b355d"><span data-lake-id="u7df4db61" id="u7df4db61">Python</span></code><span data-lake-id="u96cf6d6e" id="u96cf6d6e">会优先引入标准库模块）</span></li></ol></blockquote><p data-lake-id="u02f8e45b" id="u02f8e45b" style="text-indent: 2em"><span data-lake-id="u6676317a" id="u6676317a">创建如下文件：</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22plain%22%2C%22code%22%3A%22%E2%94%9C%E2%94%80%E2%94%80%20order.py%20%20%20%23%20%E8%AE%A2%E5%8D%95%E6%A8%A1%E5%9D%97%5Cn%E2%94%94%E2%94%80%E2%94%80%20pay.py%20%20%20%20%20%23%20%E6%94%AF%E4%BB%98%E6%A8%A1%E5%9D%97%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22ITh78%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><p data-lake-id="u9427b014" id="u9427b014" style="text-indent: 2em"><code data-lake-id="ucd7576c9" id="ucd7576c9"><span data-lake-id="ud3fe0a75" id="ud3fe0a75">order</span></code><span data-lake-id="ubbd72734" id="ubbd72734">模块中包含：创建订单、关闭订单，相关的功能函。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22order.py%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E8%AE%A2%E5%8D%95%E6%9C%80%E5%A4%A7%E9%87%91%E9%A2%9D%5Cnmax_order_amount%20%3D%201000000%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BA%E8%AE%A2%E5%8D%95%5Cndef%20create_order()%3A%5Cn%20%20%20%20print('%E8%AE%A2%E5%8D%95%E5%88%9B%E5%BB%BA%E6%88%90%E5%8A%9F%EF%BC%81')%5Cn%5Cn%23%20%E5%85%B3%E9%97%AD%E8%AE%A2%E5%8D%95%5Cndef%20cancel_order()%3A%5Cn%20%20%20%20print('%E8%AE%A2%E5%8D%95%E5%85%B3%E9%97%AD%E6%88%90%E5%8A%9F%EF%BC%81')%5Cn%5Cn%23%20%E6%8F%90%E7%A4%BA%E5%87%BD%E6%95%B0%5Cndef%20show_info()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E6%9D%A5%E8%87%AA%E3%80%90%E8%AE%A2%E5%8D%95%E3%80%91%E6%A8%A1%E5%9D%97%E7%9A%84%E6%8F%90%E7%A4%BA%EF%BC%81')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22order.py%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22aJ4k9%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><p data-lake-id="ua65523da" id="ua65523da" style="text-indent: 2em"><code data-lake-id="ue860b378" id="ue860b378"><span data-lake-id="uec86fe50" id="uec86fe50">pay</span></code><span data-lake-id="ub5599ff8" id="ub5599ff8">模块中包含：微信支付、支付宝支付，等相关功能。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22pay.py%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E6%94%AF%E4%BB%98%E8%B6%85%E6%97%B6%E6%97%B6%E9%97%B4%5Cntimeout%20%3D%201800%5Cn%5Cn%23%20%E5%BE%AE%E4%BF%A1%E6%94%AF%E4%BB%98%5Cndef%20wechat_pay()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E5%BE%AE%E4%BF%A1%E6%94%AF%E4%BB%98%EF%BC%81')%5Cn%5Cn%23%20%E6%94%AF%E4%BB%98%E5%AE%9D%E6%94%AF%E4%BB%98%5Cndef%20ali_pay()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E6%94%AF%E4%BB%98%E5%AE%9D%E6%94%AF%E4%BB%98%EF%BC%81')%5Cn%5Cn%23%20%E6%8F%90%E7%A4%BA%E5%87%BD%E6%95%B0%5Cndef%20show_info()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E6%9D%A5%E8%87%AA%E3%80%90%E6%94%AF%E4%BB%98%E3%80%91%E6%A8%A1%E5%9D%97%E7%9A%84%E6%8F%90%E7%A4%BA%EF%BC%81')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22pay.py%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22Vv6wE%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D" hindent="2em"></card><h3 data-lake-id="tnhEl" id="tnhEl" data-lake-index-type="2"><span data-lake-id="u66f4e880" id="u66f4e880">导入模块</span></h3><h4 data-lake-id="hnMl7" id="hnMl7"><span data-lake-id="ud45701dd" id="ud45701dd">1️⃣</span><span data-lake-id="ube4aa768" id="ube4aa768">import 模块名</span></h4><p data-lake-id="u0e304b03" id="u0e304b03"><span data-lake-id="ua314eafa" id="ua314eafa">如下写法，会导入</span><code data-lake-id="uce2fa9a8" id="uce2fa9a8"><span data-lake-id="u387334e5" id="u387334e5">order</span></code><span data-lake-id="u516b7c63" id="u516b7c63">模块，和</span><code data-lake-id="ucb9bc4c5" id="ucb9bc4c5"><span data-lake-id="ud884c291" id="ud884c291">pay</span></code><span data-lake-id="uf0d22510" id="uf0d22510">模块的全部内容，又叫</span><strong><span data-lake-id="u448d1853" id="u448d1853">全部导入，</span></strong><span data-lake-id="u5f2f47a1" id="u5f2f47a1">是最简单的导入方式 。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22import%20order%5Cnimport%20pay%5Cn%5Cnprint(order.max_order_amount)%5Cnorder.create_order()%5Cnorder.cancel_order()%5Cnorder.show_info()%5Cn%5Cnprint('*'%20*%2010)%5Cn%5Cnprint(pay.timeout)%5Cnpay.wechat_pay()%5Cnpay.ali_pay()%5Cnpay.show_info()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22__widthMode%22%3A%22normal%22%2C%22id%22%3A%22DnMZy%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22widthMode%22%3A%22normal%22%7D"></card><blockquote data-lake-id="u0fa5a555" id="u0fa5a555" class="lake-alert lake-alert-color4"><p data-lake-id="uabc4b872" id="uabc4b872"><strong><span data-lake-id="u83d6a2cf" id="u83d6a2cf" style="color: #DF2A3F">注意：</span></strong></p><ol list="uc69e463c"><li fid="uef10bde9" data-lake-id="ucd9be6e9" id="ucd9be6e9"><span data-lake-id="u63b15eba" id="u63b15eba">Python 中导入模块的时，会执行对应模块中的代码。</span></li><li fid="uef10bde9" data-lake-id="ufe643119" id="ufe643119"><span data-lake-id="u7ddf0529" id="u7ddf0529">模块只加载一次，后续再次导入，直接复用缓存。</span></li></ol></blockquote><h4 data-lake-id="D1p6F" id="D1p6F"><span data-lake-id="ucb311b24" id="ucb311b24"> </span><span data-lake-id="u16811807" id="u16811807">2️⃣</span><span data-lake-id="u8eefe883" id="u8eefe883">import 模块名 as 别名</span></h4><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22import%20order%20as%20dd%5Cnimport%20pay%20as%20zf%5Cn%5Cnprint(dd.max_order_amount)%5Cndd.create_order()%5Cndd.cancel_order()%5Cndd.show_info()%5Cn%5Cnprint('*'%20*%2010)%5Cn%5Cnprint(zf.timeout)%5Cnzf.wechat_pay()%5Cnzf.ali_pay()%5Cnzf.show_info()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22YHXuI%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h4 data-lake-id="tFJ5A" id="tFJ5A"><span data-lake-id="u852068d3" id="u852068d3"> </span><span data-lake-id="u9f5268d6" id="u9f5268d6">3️⃣</span><span data-lake-id="ub93faa4f" id="ub93faa4f">from 模块名 import 具体内容1, 具体内容2, ......</span></h4><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22from%20order%20import%20max_order_amount%2C%20show_info%5Cnfrom%20pay%20import%20wechat_pay%2C%20ali_pay%5Cn%5Cnprint(max_order_amount)%5Cnshow_info()%5Cnwechat_pay()%5Cnali_pay()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22pmlaQ%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h4 data-lake-id="U6x7g" id="U6x7g"><span data-lake-id="ud291c344" id="ud291c344"> </span><span data-lake-id="uc259679d" id="uc259679d">4️⃣</span><span data-lake-id="u6b9b971d" id="u6b9b971d">from 模块名 import 具体内容 as 别名</span></h4><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22from%20order%20import%20max_order_amount%20as%20max_amt%2C%20show_info%20as%20show1%5Cnfrom%20pay%20import%20timeout%20as%20tm%2C%20show_info%20as%20show2%5Cn%5Cnprint(max_amt)%5Cnprint(tm)%5Cnshow1()%5Cnshow2()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22SxN4H%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h4 data-lake-id="jRwTo" id="jRwTo"><span data-lake-id="ub6542892" id="ub6542892"> </span><span data-lake-id="u54187adb" id="u54187adb">5️⃣</span><span data-lake-id="ue627e546" id="ue627e546">from 模块名 import *</span></h4><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22from%20order%20import%20*%5Cnfrom%20pay%20import%20*%5Cn%5Cnmax_order_amount%20%3D%2010%5Cn%5Cnprint(max_order_amount)%5Cncreate_order()%5Cncancel_order()%5Cnshow_info()%5Cn%5Cnprint(timeout)%5Cnwechat_pay()%5Cnali_pay()%5Cnshow_info()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22AuC85%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="yPr0M" id="yPr0M" data-lake-index-type="2"><code data-lake-id="u93544871" id="u93544871"><strong><span data-lake-id="u81db0788" id="u81db0788">__all__</span></strong></code><strong><span data-lake-id="u6c015133" id="u6c015133">  与  </span></strong><code data-lake-id="u1b2b2759" id="u1b2b2759"><strong><span data-lake-id="u2c545f71" id="u2c545f71">__name__</span></strong></code></h3><p data-lake-id="u54cf8d16" id="u54cf8d16"><span data-lake-id="ud440a167" id="ud440a167">关于</span><code data-lake-id="ue2062e7e" id="ue2062e7e"><span data-lake-id="u04cd61f1" id="u04cd61f1">__all__</span></code><span data-lake-id="u9be61924" id="u9be61924">：</span></p><blockquote data-lake-id="ud879dc0c" id="ud879dc0c" class="lake-alert lake-alert-info"><ul list="u4f726e5c"><li fid="u967d0532" data-lake-id="ub6c81841" id="ub6c81841"><span data-lake-id="u814f9a58" id="u814f9a58">在 Python 模块中，可通过 </span><code data-lake-id="u7836ac5d" id="u7836ac5d"><span data-lake-id="u79c645e1" id="u79c645e1">__all__</span></code><span data-lake-id="u8da1c64f" id="u8da1c64f"> 来控制</span><code data-lake-id="u52128eef" id="u52128eef"><span data-lake-id="uc83877df" id="uc83877df">from 模块 import *</span></code><span data-lake-id="udea936c4" id="udea936c4">能导入哪些内容。</span></li><li fid="u967d0532" data-lake-id="u8d30afa6" id="u8d30afa6"><code data-lake-id="uc9894698" id="uc9894698"><span data-lake-id="u72556190" id="u72556190">__all__</span></code><span data-lake-id="u04d7f35b" id="u04d7f35b"> 的值可以是：列表、元组。</span></li></ul></blockquote><p data-lake-id="ufd8a73e8" id="ufd8a73e8"><span data-lake-id="u4f50b2c5" id="u4f50b2c5">关于</span><code data-lake-id="u3136317e" id="u3136317e"><span data-lake-id="u576c6782" id="u576c6782">__name__</span></code><span data-lake-id="ufd0030b3" id="ufd0030b3">:</span></p><blockquote data-lake-id="uef0634d0" id="uef0634d0" class="lake-alert lake-alert-info"><ul list="u5d4e3f42"><li fid="uf4b29f4e" data-lake-id="u393ae08b" id="u393ae08b"><code data-lake-id="u5dbb5fc9" id="u5dbb5fc9"><span data-lake-id="u6ecf06d1" id="u6ecf06d1">__name__</span></code><span data-lake-id="udabe0e56" id="udabe0e56">是每个 Python 模块（</span><code data-lake-id="uf676d62a" id="uf676d62a"><span data-lake-id="u3b000398" id="u3b000398">.py</span></code><span data-lake-id="u8e3f2e3f" id="u8e3f2e3f">文件）都拥有的一个内置变量。</span></li><li fid="uf4b29f4e" data-lake-id="u52fa6ab1" id="u52fa6ab1"><span data-lake-id="uf5192a0a" id="uf5192a0a">它的具体值取决于模块的运行方式：</span></li></ul><p data-lake-id="u8968c233" id="u8968c233" style="text-indent: 2em; padding-left: 2em"><span data-lake-id="ua2754116" id="ua2754116">(1). 作为主程序直接运行，</span><code data-lake-id="u8bbe36ca" id="u8bbe36ca"><span data-lake-id="uc94f6c4f" id="uc94f6c4f">__name__</span></code><span data-lake-id="u5b6a30ad" id="u5b6a30ad"> 的值是 </span><code data-lake-id="u5096fc3d" id="u5096fc3d"><span data-lake-id="u8068d0ef" id="u8068d0ef">__main__</span></code></p><p data-lake-id="ua582ce14" id="ua582ce14" style="text-indent: 2em; padding-left: 2em"><span data-lake-id="u0c1f97ee" id="u0c1f97ee">(2). 作为模块被导入到其他程序中运行，</span><code data-lake-id="uf8a30b6e" id="uf8a30b6e"><span data-lake-id="u4c338009" id="u4c338009">__name__</span></code><span data-lake-id="ub944e43f" id="ub944e43f">的模块的文件名（不带</span><code data-lake-id="u1690903a" id="u1690903a"><span data-lake-id="udd91f89f" id="udd91f89f">.py</span></code><span data-lake-id="ued8decee" id="ued8decee">）。</span></p></blockquote><h3 data-lake-id="Ug1A8" id="Ug1A8" data-lake-index-type="2"><span data-lake-id="u4be1d30a" id="u4be1d30a">标准库模块</span></h3><ol list="u8ab518b3"><li fid="u41770f34" data-lake-id="u114b4c31" id="u114b4c31"><span data-lake-id="u67e3c959" id="u67e3c959">Python 中的模块分为三类，分别是：标准库模块、自定义模块、第三方模块。</span></li><li fid="u41770f34" data-lake-id="ue65fd9a4" id="ue65fd9a4"><span data-lake-id="uefe255c2" id="uefe255c2">标准库模块：随着 Python 一起安装在我们电脑上的那些模块。</span></li><li fid="u41770f34" data-lake-id="u71e3e506" id="u71e3e506"><span data-lake-id="uf442e756" id="uf442e756">有一些标准库模块是用</span><code data-lake-id="ua13c4f68" id="ua13c4f68"><span data-lake-id="u26abfa66" id="u26abfa66">C</span></code><span data-lake-id="u76902a7a" id="u76902a7a">语言实现的，这些用C语言实现的模块，又称：【内置模块】。</span></li></ol><blockquote data-lake-id="ufc200da0" id="ufc200da0"><p data-lake-id="ud73655e3" id="ud73655e3"><span data-lake-id="uc08886d1" id="uc08886d1">标准库模块保存在</span><code data-lake-id="u15d13079" id="u15d13079"><span data-lake-id="uba98519f" id="uba98519f">Python</span></code><span data-lake-id="ueb71dba0" id="ueb71dba0">安装目录中的</span><code data-lake-id="ua072e33a" id="ua072e33a"><span data-lake-id="uc1fbfbe6" id="uc1fbfbe6">Lib</span></code><span data-lake-id="udc899e3e" id="udc899e3e">文件夹中，但内置模块无法在</span><code data-lake-id="uafa2e5ae" id="uafa2e5ae"><span data-lake-id="u327b3277" id="u327b3277">Lib</span></code><span data-lake-id="u3c074faf" id="u3c074faf">中看到。</span></p></blockquote><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22import%20copy%20%20%20%20%20%23%20%E6%8B%B7%E8%B4%9D%E5%AF%B9%E8%B1%A1%EF%BC%88%E6%B5%85%E6%8B%B7%E8%B4%9D%E3%80%81%E6%B7%B1%E6%8B%B7%E8%B4%9D%EF%BC%89%5Cnimport%20os%20%20%20%20%20%20%20%23%20%E6%93%8D%E4%BD%9C%E7%B3%BB%E7%BB%9F%E7%9B%B8%E5%85%B3%E6%93%8D%E4%BD%9C%EF%BC%88%E6%96%87%E4%BB%B6%E3%80%81%E6%96%87%E4%BB%B6%E5%A4%B9%E3%80%81%E8%B7%AF%E5%BE%84%E7%B3%BB%E7%BB%9F%E5%B1%82%E9%9D%A2%E7%9A%84%E6%93%8D%E4%BD%9C%EF%BC%89%5Cnimport%20random%20%20%20%23%20%E9%9A%8F%E6%9C%BA%E6%95%B0%E7%9B%B8%E5%85%B3%EF%BC%88%E7%94%9F%E6%88%90%E9%9A%8F%E6%9C%BA%E6%95%B0%E3%80%81%E9%9A%8F%E6%9C%BA%E9%80%89%E6%8B%A9%E3%80%81%E6%B4%97%E7%89%8C%EF%BC%89%5Cn%5Cn%23%20%E4%B8%8A%E9%9D%A2%E7%9A%84copy%E3%80%81os%E3%80%81random%E6%98%AF%E6%A0%87%E5%87%86%E5%BA%93%E6%A8%A1%E5%9D%97%E4%B8%AD%E7%9A%84%E3%80%90%E9%9D%9E%E5%86%85%E7%BD%AE%E6%A8%A1%E5%9D%97%E3%80%91%EF%BC%8C%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87__file__%E6%9F%A5%E7%9C%8B%E6%96%87%E4%BB%B6%E4%BD%8D%E7%BD%AE%5Cn%23%20print(copy.__file__)%5Cn%23%20print(os.__file__)%5Cn%23%20print(random.__file__)%5Cn%5Cn%23%20%E5%A6%82%E4%B8%8B%E7%9A%84%E8%BF%99%E4%BA%9B%E6%A8%A1%E5%9D%97%EF%BC%8C%E5%B1%9E%E4%BA%8E%E5%86%85%E7%BD%AE%E6%A8%A1%E5%9D%97%EF%BC%88%E6%97%A0%E6%B3%95%E7%9C%8B%E5%88%B0%E5%85%B7%E4%BD%93%E5%AE%9E%E7%8E%B0%EF%BC%8C%E4%B9%9F%E6%B2%A1%E6%9C%89__file__%E5%B1%9E%E6%80%A7%EF%BC%89%5Cnimport%20time%20%20%20%20%20%23%20%E6%97%B6%E9%97%B4%E7%9B%B8%E5%85%B3%E6%93%8D%E4%BD%9C%EF%BC%88%E8%8E%B7%E5%8F%96%E6%97%B6%E9%97%B4%E3%80%81%E5%BB%B6%E6%97%B6%E3%80%81%E6%A0%BC%E5%BC%8F%E5%8C%96%E6%97%B6%E9%97%B4%E7%AD%89%E3%80%82%EF%BC%89%5Cnimport%20math%20%20%20%20%20%23%20%E6%95%B0%E5%AD%A6%E7%9B%B8%E5%85%B3%EF%BC%88%E5%BC%80%E5%B9%B3%E6%96%B9%E3%80%81%E5%8F%96%E7%BB%9D%E5%AF%B9%E5%80%BC%20%E7%AD%89%E7%AD%89%EF%BC%89%5Cnimport%20sys%20%20%20%20%20%20%23%20Python%20%E8%A7%A3%E9%87%8A%E5%99%A8%E7%9B%B8%E5%85%B3%E6%93%8D%E4%BD%9C%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BA%E4%B8%80%E4%B8%AA%E6%96%87%E4%BB%B6%E5%A4%B9%5Cnos.mkdir('demo')%5Cn%5Cn%23%20%E9%9A%8F%E6%9C%BA%E9%80%89%E6%8B%A9%E4%B8%80%E4%B8%AA%E4%BA%BA%5Cnnames%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%2C%20'%E6%9D%8E%E5%8D%8E'%5D%5Cnprint(random.choice(names))%5Cn%5Cn%23%20%E6%B4%97%E7%89%8C%5Cnnames%20%3D%20%5B'%E5%BC%A0%E4%B8%89'%2C%20'%E6%9D%8E%E5%9B%9B'%2C%20'%E7%8E%8B%E4%BA%94'%2C%20'%E6%9D%8E%E5%8D%8E'%5D%5Cnrandom.shuffle(names)%5Cnprint(names)%5Cn%5Cn%23%20%E4%BC%91%E7%9C%A0%5Cntime.sleep(2)%5Cnprint('ok')%5Cn%5Cn%23%20%E8%8E%B7%E5%8F%96%E5%BD%93%E5%89%8D%E6%97%B6%E9%97%B4%5Cnprint(time.strftime('%25H%3A%25M%3A%25S'))%5Cnprint(time.strftime('%25p%20%25I%3A%25M%3A%25S'))%5Cn%5Cn%23%20%E5%BC%80%E5%B9%B3%E6%96%B9%5Cnprint(math.sqrt(4))%5Cn%5Cn%23%20%E5%8F%96%E7%BB%9D%E5%AF%B9%E5%80%BC%5Cnprint(math.fabs(-11.2))%5Cn%5Cn%23%20%E8%8E%B7%E5%8F%96Python%E8%A7%A3%E9%87%8A%E5%99%A8%E7%9A%84%E7%89%88%E6%9C%AC%5Cnprint(sys.version)%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Wjtx4%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h2 data-lake-id="BsjR7" id="BsjR7" data-lake-index-type="2"><span data-lake-id="u6fa097b7" id="u6fa097b7">包</span></h2><h3 data-lake-id="qvNXq" id="qvNXq" data-lake-index-type="2"><span data-lake-id="u5d7c053c" id="u5d7c053c">概述</span></h3><ul list="u0b532310"><li fid="ua8ffff27" data-lake-id="u675d59cf" id="u675d59cf"><span data-lake-id="ue9bdb7cd" id="ue9bdb7cd">包是一种组织模块的方式，包中可以包含：各种模块、子包、其他资源等。</span></li><li fid="ua8ffff27" data-lake-id="u559da629" id="u559da629"><span data-lake-id="u33830300" id="u33830300">在 Python 中，【包含</span><code data-lake-id="u5cc42fa5" id="u5cc42fa5"><span data-lake-id="u2d6e71be" id="u2d6e71be">__init__.py</span></code><span data-lake-id="ub07ef76b" id="ub07ef76b"> 的文件夹】就是一个包（Package）。</span></li><li fid="ua8ffff27" data-lake-id="u47287bc2" id="u47287bc2"><span data-lake-id="uf1fa0b29" id="uf1fa0b29">我们通常会把【某个特定功能相关的所有模块】放入一个包中。</span></li><li fid="ua8ffff27" data-lake-id="uba92f370" id="uba92f370"><span data-lake-id="u5cf5743c" id="u5cf5743c">使用包可以进一步提升代码的：可维护性、可复用性，便于管理大型项目。</span></li></ul><h3 data-lake-id="DKG5I" id="DKG5I" data-lake-index-type="2"><span data-lake-id="u150a8293" id="u150a8293">包与模块的关系</span></h3><ul list="ueeede0ae"><li fid="ua2b4b4ec" data-lake-id="u85965ef5" id="u85965ef5"><span data-lake-id="ub88201cc" id="ub88201cc">一个模块就是一个</span><code data-lake-id="ua12ae64b" id="ua12ae64b"><span data-lake-id="u837d34cf" id="u837d34cf">.py</span></code><span data-lake-id="u050d51fa" id="u050d51fa">文件 ，包是用来“管理模块”的目录(文件夹)。</span></li><li fid="ua2b4b4ec" data-lake-id="ufc6cd883" id="ufc6cd883"><span data-lake-id="uad36dbc9" id="uad36dbc9">一个包中可以有多个模块，也可以有多个子包。</span></li></ul><h3 data-lake-id="u9Y2p" id="u9Y2p" data-lake-index-type="2"><span data-lake-id="ueedb80d7" id="ueedb80d7">包的分类</span></h3><p data-lake-id="ubc1faaf8" id="ubc1faaf8"><span data-lake-id="uec0bbdb2" id="uec0bbdb2">Python 中的包分为三类，分别是：标准库包、自定义包、第三方包。</span></p><h3 data-lake-id="ZFzhq" id="ZFzhq" data-lake-index-type="2"><span data-lake-id="u4954d4b3" id="u4954d4b3">创建包</span></h3><blockquote data-lake-id="u3775dafe" id="u3775dafe" class="lake-alert lake-alert-info"><p data-lake-id="u12df7706" id="u12df7706"><span data-lake-id="u1d748f86" id="u1d748f86">包命名注意点：</span></p><ol list="u2fde60b7"><li fid="uae885f32" data-lake-id="u9ce0b021" id="u9ce0b021"><span data-lake-id="u0dd40e46" id="u0dd40e46">要符合标识符命名规范。</span></li><li fid="uae885f32" data-lake-id="ue6e44cf6" id="ue6e44cf6"><span data-lake-id="u40f62764" id="u40f62764">包名区分大小写（建议全部使用小写字母）</span></li><li fid="uae885f32" data-lake-id="u48ce92e3" id="u48ce92e3"><span data-lake-id="ueca81c03" id="ueca81c03">不要与标准库包同名。</span></li></ol></blockquote><p data-lake-id="uc6106c4c" id="uc6106c4c"><span data-lake-id="u080a928b" id="u080a928b">创建如下文件结构，由于</span><code data-lake-id="u2dd1e912" id="u2dd1e912"><span data-lake-id="ua2a3c49c" id="ua2a3c49c">trade</span></code><span data-lake-id="ub2551642" id="ub2551642">文件中包含了</span><code data-lake-id="u3e743a47" id="u3e743a47"><span data-lake-id="u7c9e97be" id="u7c9e97be">__init__.py</span></code><span data-lake-id="ub427e9a3" id="ub427e9a3">文件，所以</span><code data-lake-id="u9a079d7b" id="u9a079d7b"><span data-lake-id="u399341d7" id="u399341d7">trade</span></code><span data-lake-id="ubd1b8703" id="ubd1b8703">就可以称之为『包』。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22plain%22%2C%22code%22%3A%22%E2%94%94%E2%94%80%E2%94%80%20trade%2F%5Cn%20%20%20%20%E2%94%9C%E2%94%80%E2%94%80%20__init__.py%5Cn%20%20%20%20%E2%94%9C%E2%94%80%E2%94%80%20order.py%5Cn%20%20%20%20%E2%94%94%E2%94%80%E2%94%80%20pay.py%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22uwgDY%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><p data-lake-id="uba50a54a" id="uba50a54a"><span data-lake-id="u19f4d663" id="u19f4d663">各文件内容如下：</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22__init__.py%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E8%AF%A5%E6%96%87%E4%BB%B6%E6%9A%82%E6%97%B6%E7%95%99%E7%99%BD%EF%BC%8C%E4%B8%8D%E7%BC%96%E5%86%99%E4%BB%BB%E4%BD%95%E4%BB%A3%E7%A0%81%EF%BC%8C%E5%90%8E%E9%9D%A2%E4%BC%9A%E5%AF%B9%E8%AF%A5%E6%96%87%E4%BB%B6%E8%AF%A6%E7%BB%86%E8%AE%B2%E8%A7%A3%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22__init__.py%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22Djvdw%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22order.py%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E8%AE%A2%E5%8D%95%E6%9C%80%E5%A4%A7%E9%87%91%E9%A2%9D%5Cnmax_order_amount%20%3D%201000000%5Cn%5Cn%23%20%E5%88%9B%E5%BB%BA%E8%AE%A2%E5%8D%95%5Cndef%20create_order()%3A%5Cn%20%20%20%20print('%E8%AE%A2%E5%8D%95%E5%88%9B%E5%BB%BA%E6%88%90%E5%8A%9F%EF%BC%81')%5Cn%5Cn%23%20%E5%85%B3%E9%97%AD%E8%AE%A2%E5%8D%95%5Cndef%20cancel_order()%3A%5Cn%20%20%20%20print('%E8%AE%A2%E5%8D%95%E5%85%B3%E9%97%AD%E6%88%90%E5%8A%9F%EF%BC%81')%5Cn%5Cn%23%20%E6%8F%90%E7%A4%BA%E5%87%BD%E6%95%B0%5Cndef%20show_info()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E6%9D%A5%E8%87%AA%E3%80%90%E8%AE%A2%E5%8D%95%E3%80%91%E6%A8%A1%E5%9D%97%E7%9A%84%E6%8F%90%E7%A4%BA%EF%BC%81')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22order.py%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22HDQMb%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22pay.py%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22%23%20%E6%94%AF%E4%BB%98%E8%B6%85%E6%97%B6%E6%97%B6%E9%97%B4%5Cntimeout%20%3D%201800%5Cn%5Cn%23%20%E5%BE%AE%E4%BF%A1%E6%94%AF%E4%BB%98%5Cndef%20wechat_pay()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E5%BE%AE%E4%BF%A1%E6%94%AF%E4%BB%98%EF%BC%81')%5Cn%5Cn%23%20%E6%94%AF%E4%BB%98%E5%AE%9D%E6%94%AF%E4%BB%98%5Cndef%20ali_pay()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E6%94%AF%E4%BB%98%E5%AE%9D%E6%94%AF%E4%BB%98%EF%BC%81')%5Cn%5Cn%23%20%E6%8F%90%E7%A4%BA%E5%87%BD%E6%95%B0%5Cndef%20show_info()%3A%5Cn%20%20%20%20print('%E6%88%91%E6%98%AF%E6%9D%A5%E8%87%AA%E3%80%90%E6%94%AF%E4%BB%98%E3%80%91%E6%A8%A1%E5%9D%97%E7%9A%84%E6%8F%90%E7%A4%BA%EF%BC%81')%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Afalse%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Afalse%2C%22name%22%3A%22pay.py%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22fontSize%22%3A14%2C%22customStyle%22%3A%5B%5D%2C%22__spacing%22%3A%22both%22%2C%22id%22%3A%22vcVmI%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D"></card><h3 data-lake-id="CdqjU" id="CdqjU" data-lake-index-type="2"><span data-lake-id="u6b773873" id="u6b773873">导入包</span></h3><h4 data-lake-id="d1TLp" id="d1TLp"><span data-lake-id="u683380e8" id="u683380e8">1️⃣</span><span data-lake-id="u6cf787dd" id="u6cf787dd">import 包名.模块名</span></h4><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22python%22%2C%22code%22%3A%22import%20trade.order%5Cnimport%20trade.pay%5Cn%5Cntrade.order.create_order()%5Cntrade.pay.wechat_pay()%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Af